<form
  action="/search"
  method="get"
  class="pc-search-inline"
  role="search"
>
  <input type="hidden" name="type" value="product">
  <label for="pc-search-input" class="visually-hidden">
    Search products
  </label>
  <input
    id="pc-search-input"
    type="search"
    name="q"
    placeholder="Search for products..."
    autocomplete="off"
    class="pc-search-inline__input"
    aria-label="Search for products"
  >
  <button
    type="submit"
    class="pc-search-inline__button"
    aria-label="Submit search"
  >
    <span class="pc-search-button-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></span>Search
  </button>
</form>
