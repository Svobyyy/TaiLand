{% doc %}
  Renders reusable cart drawer markup for both initial page loads and Section Rendering API responses.

  @param {boolean} [render_wrapper] - When true, wraps the drawer in the section wrapper that the Section Rendering API adds automatically.
{% enddoc %}

{%- liquid
  assign render_wrapper = render_wrapper | default: true, allow_false: true
-%}

{%- if settings.cart_type == 'drawer' and template.name != 'cart' -%}
  {% if render_wrapper %}
    <div
      id="shopify-section-cart-drawer-section"
      class="shopify-section"
    >
  {% endif %}

  <script
    type="module"
    src="{{ 'cart-drawer.js' | asset_url }}"
    fetchpriority="low"
  ></script>
  <script
    type="module"
    src="{{ 'component-cart-items.js' | asset_url }}"
    fetchpriority="low"
  ></script>
  <script
    type="module"
    src="{{ 'component-cart-quantity-selector.js' | asset_url }}"
    fetchpriority="low"
  ></script>
  <script type="module">
    import { morphSection, sectionRenderer } from '@theme/section-renderer';
    window._tailandMorphSection = morphSection;
    window._tailandSectionRenderer = sectionRenderer;
  </script>

  {% capture empty_cart_drawer_content %}
    <div
      class="cart-drawer__content"
      aria-label="{{ 'accessibility.cart' | t }}"
    >
      <h2
        class="theme-drawer__title h4"
        id="cart-drawer-heading"
      >
        {{ 'content.your_cart_is_empty' | t }}
      </h2>

      <div class="cart-drawer__items">
        <div class="tp-cart-empty__inner">
          <p class="tp-cart-empty__msg">Your cart is waiting for some pawsome picks.</p>
          <a href="/collections/best-sellers" class="tp-cart-empty__btn">Shop Best Sellers</a>
        </div>
      </div>
    </div>
    {% endcapture %}

  <theme-drawer
    id="cart-drawer"
    data-skip-node-update
  >
    <dialog
      ref="panel"
      class="theme-drawer__dialog color-custom-drawer"
      aria-labelledby="cart-drawer-heading"
      cart-summary-sticky="true"
    >
      <cart-drawer-component
        {% if settings.auto_open_cart_drawer and template.name != 'cart' %}
          auto-open
        {% endif %}
      >
        <template id="empty-cart-template">
          {{ empty_cart_drawer_content }}
        </template>

        <div
          class="cart-drawer__inner{% if cart.empty? %} cart-drawer--empty{% endif %}"
          data-hydration-key="cart-drawer-inner"
        >
          {%- if cart.empty? -%}
            <div class="theme-drawer__header">
              <button
                on:click="#cart-drawer/close"
                class="theme-drawer__close-button cart-drawer__close-button--empty"
                type="button"
                aria-label="{{ 'actions.close' | t }}"
              >
                <span class="svg-wrapper">
                  {{- 'icon-close.svg' | inline_asset_content -}}
                </span>
              </button>
            </div>
          {%- else -%}
            {% capture cart_badge_html %}
              <span
                class="theme-drawer__badge{% if cart.item_count == 0 %} visually-hidden{% endif %}"
                aria-hidden="true"
                {% if cart.item_count <= 99 %}
                  data-maintain-ratio
                {% endif %}
              >
                {{- cart.item_count -}}
              </span>
              {% if cart.item_count > 0 %}
                <span class="visually-hidden">
                  {{ 'accessibility.cart_count' | t }}: {{ cart.item_count }}
                </span>
              {% endif %}
            {% endcapture %}
            {% assign cart_drawer_title = 'content.cart_title' | t %}
            {% capture cart_clear_btn %}
              <button
                type="button"
                id="tc-cart-clear-btn"
                class="tc-cart-clear-btn"
                aria-label="Delete all items from cart"
              >
                <svg aria-hidden="true" focusable="false" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="3 6 5 6 21 6"/>
                  <path d="M19 6l-1 14H6L5 6"/>
                  <path d="M10 11v6M14 11v6"/>
                  <path d="M9 6V4h6v2"/>
                </svg>
                <span class="tc-cart-clear-btn__text">Delete all</span>
              </button>
            {% endcapture %}
            {% render 'theme-drawer-header',
              title: cart_drawer_title,
              drawer_id: 'cart-drawer',
              heading_id: 'cart-drawer-heading',
              title_append: cart_badge_html,
              header_actions: cart_clear_btn
            %}
          {%- endif -%}

          {% capture cart_items_children %}
            {%- if cart.empty? -%}
              {{ empty_cart_drawer_content }}
            {%- else -%}
              <scroll-hint
                class="cart-drawer__content"
                aria-label="{{ 'accessibility.cart' | t }}"
                style="--header-height: 60px;"
              >
                <scroll-hint class="cart-drawer__items">
                  {%- assign tc_fs_threshold = section.settings.free_shipping_threshold | default: 60 -%}
                  {%- if tc_fs_threshold > 0 -%}
                    {%- assign tc_exchange = localization.country.currency.exchange_rate | default: 1 -%}
                    {%- if tc_exchange == 0 -%}{%- assign tc_exchange = 1 -%}{%- endif -%}
                    {%- assign tc_fs_cents = tc_fs_threshold | times: tc_exchange | times: 100 | round -%}
                    {%- assign tc_fs_unlocked = false -%}
                    {%- if cart.total_price >= tc_fs_cents -%}{%- assign tc_fs_unlocked = true -%}{%- endif -%}
                    {%- assign tc_fs_remaining = tc_fs_cents | minus: cart.total_price -%}
                    {%- assign tc_fs_pct = cart.total_price | times: 100 | divided_by: tc_fs_cents | at_most: 100 -%}
                    <div class="tc-freeship{% if tc_fs_unlocked %} tc-freeship--unlocked{% endif %}"
                         id="tc-freeship"
                         data-free-shipping-progress
                         data-fs-usd-cents="{{ tc_fs_threshold | times: 100 }}"
                         data-free-shipping-prefix="You are"
                         data-free-shipping-suffix="away from free shipping">
                      <div class="tc-freeship__text">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                        <span data-free-shipping-message>
                          {%- if tc_fs_unlocked -%}
                            Free shipping unlocked
                          {%- else -%}
                            You are <strong>{{ tc_fs_remaining | money }}</strong> away from free shipping
                          {%- endif -%}
                        </span>
                      </div>
                      <div class="tc-freeship__track">
                        <div class="tc-freeship__fill" data-free-shipping-bar style="width:{{ tc_fs_pct }}%"></div>
                      </div>
                    </div>
                  {%- endif -%}
                  {%- render 'cart-deal-banner' -%}
                  {% render 'cart-products', context: 'drawer' %}
                  {%- render 'cart-fbt', fbt_limit: 3, fbt_mode: 'drawer' -%}
                </scroll-hint>
              </scroll-hint>

              <div class="cart-drawer__summary">
                {% render 'cart-summary', section_id: 'cart-drawer-section' %}
              </div>
            {%- endif -%}
          {% endcapture %}
          {% render 'cart-items-component',
            children: cart_items_children,
            is_drawer: true,
            section_id: 'cart-drawer-section'
          %}
        </div>
      </cart-drawer-component>
    </dialog>
  </theme-drawer>

  {% if render_wrapper %}
    </div>
  {% endif %}

  <script src="{{ 'tailand-fbt.js' | asset_url }}" defer></script>

  <script>
    (function () {
      var cartDrawer = document.getElementById('cart-drawer');
      if (!cartDrawer) return;

      // Scrim — desktop-only backdrop; clicking it closes the drawer
      var scrim = document.createElement('div');
      scrim.className = 'tc-cart-scrim';
      document.body.appendChild(scrim);
      scrim.addEventListener('click', function () {
        if (typeof cartDrawer.close === 'function') cartDrawer.close();
      });

      var desktopQuery = window.matchMedia('(min-width: 990px)');

      // On desktop, theme-drawer.js calls dialog.show() (non-modal — loses to the sticky header).
      // Session restore calls dialog.setAttribute('open','') directly, also bypassing showModal().
      // Both paths are intercepted to use showModal() (browser top layer), matching mobile.
      if (desktopQuery.matches) {
        var desktopDialog = cartDrawer.querySelector('dialog');
        if (desktopDialog) {
          desktopDialog.show = function () {
            if (!this.open) HTMLDialogElement.prototype.showModal.call(this);
          };
          new MutationObserver(function () {
            if (desktopDialog.hasAttribute('open') && !desktopDialog.matches(':modal')) {
              desktopDialog.close();
              HTMLDialogElement.prototype.showModal.call(desktopDialog);
            }
          }).observe(desktopDialog, { attributes: true, attributeFilter: ['open'] });
        }
      }

      // Body class drives the scrim fade and header z-index via CSS
      function syncDrawerClass() {
        document.body.classList.toggle('tc-cart-drawer-open', cartDrawer.hasAttribute('open'));
      }

      desktopQuery.addEventListener('change', syncDrawerClass);
      new MutationObserver(syncDrawerClass).observe(cartDrawer, {
        attributes: true,
        attributeFilter: ['open'],
      });
      syncDrawerClass();
    })();

    // ── Delete-all clear cart ────────────────────────────────────────
    (function () {
      var CONFIRM_MS  = 3500;
      var clearTimer  = null;
      var isCartPage  = /^\/cart(\/|$|\?)/.test(window.location.pathname);
      var root        = (window.Shopify && window.Shopify.routes.root) || '/';

      function getBtn() { return document.getElementById('tc-cart-clear-btn'); }

      function setBtnState(btn, state, text) {
        btn.dataset.state = state || '';
        var span = btn.querySelector('.tc-cart-clear-btn__text');
        if (span) span.textContent = text;
        btn.disabled = (state === 'loading');
      }

      function resetBtn() {
        clearTimer && clearTimeout(clearTimer);
        clearTimer = null;
        var btn = getBtn();
        if (btn) setBtnState(btn, '', 'Delete all');
      }

      function updateBadges() {
        document.querySelectorAll(
          '.theme-drawer__badge, .cart-bubble__text-count, [data-cart-count]'
        ).forEach(function (el) { el.textContent = '0'; });
      }

      function refreshDrawer() {
        var sr = window._tailandSectionRenderer;
        if (sr && typeof sr.renderSection === 'function') {
          return sr.renderSection('cart-drawer-section', {
            cache: false,
            mode: 'hydration',
            injectStylesheet: true
          });
        }
        // Fallback when module bridge not yet loaded
        return fetch('/?sections=cart-drawer-section')
          .then(function (r) { return r.json(); })
          .then(function (data) {
            var html = data['cart-drawer-section'];
            if (!html) return;
            var parser = new DOMParser();
            var doc    = parser.parseFromString(html, 'text/html');
            var newEl  = doc.querySelector('[data-hydration-key="cart-drawer-inner"]');
            var curEl  = document.querySelector('[data-hydration-key="cart-drawer-inner"]');
            if (newEl && curEl) curEl.replaceWith(newEl);
          });
      }

      function doClearCart() {
        var btn = getBtn();
        if (!btn) return;
        clearTimer && clearTimeout(clearTimer);
        setBtnState(btn, 'loading', '...');

        fetch(root + 'cart/clear.js', {
          method: 'POST',
          headers: { 'Accept': 'application/json' }
        })
        .then(function (r) {
          if (!r.ok) throw new Error('clear failed');
          updateBadges();
          if (window.tcUpdateFSBars) window.tcUpdateFSBars();
          if (isCartPage) {
            setTimeout(function () { window.location.reload(); }, 600);
            return;
          }
          return refreshDrawer();
        })
        .catch(function () {
          var b = getBtn();
          if (!b) return;
          setBtnState(b, '', 'Error, try again');
          setTimeout(resetBtn, 2500);
        });
      }

      document.addEventListener('click', function (e) {
        var btn = e.target.closest('#tc-cart-clear-btn');

        if (!btn) {
          var active = getBtn();
          if (active && active.dataset.state === 'confirm') resetBtn();
          return;
        }

        if (btn.disabled || btn.dataset.state === 'loading') return;

        if (btn.dataset.state !== 'confirm') {
          clearTimer && clearTimeout(clearTimer);
          setBtnState(btn, 'confirm', 'Confirm?');
          clearTimer = setTimeout(resetBtn, CONFIRM_MS);
        } else {
          doClearCart();
        }
      });
    })();

    // ── Populate drawer on open (cart-icon click without cart change) ────────
    // cart-items-component starts empty and only fills via CartLinesUpdateEvent.
    // When opened via cart icon (no cart change), we fetch SRA ourselves.
    // Timing: the drawer opens BEFORE CartLinesUpdateEvent fires on Add to Cart,
    // so we delay 700ms to let the native SRA complete first, then double-check
    // inside .then() before writing — avoids the race condition entirely.
    (function () {
      var themeDrawer = document.getElementById('cart-drawer');
      if (!themeDrawer) return;

      function ensureLoaded() {
        var cic = document.querySelector('cart-items-component[data-drawer]');
        if (!cic) return;
        // No items in cart yet — nothing to fix.
        if (!cic.querySelector('table.cart-items__table')) return;
        // Items exist AND are inside the .cart-drawer__items grid context — layout is correct.
        if (cic.querySelector('.cart-drawer__items .cart-items__table-row')) return;
        // Items exist but NOT inside .cart-drawer__items — the empty→non-empty morph left
        // the layout broken. Do a full section refresh to recover.
        refreshDrawer();
      }

      new MutationObserver(function (muts) {
        for (var i = 0; i < muts.length; i++) {
          if (muts[i].attributeName === 'open' && themeDrawer.hasAttribute('open')) {
            // Delay 700ms: gives CartLinesUpdateEvent's own SRA time to complete.
            // On Add to Cart the bar will be present by then → double-check bails out.
            // On cart-icon open there's no pending SRA → we fetch after the delay.
            setTimeout(ensureLoaded, 700);
            return;
          }
        }
      }).observe(themeDrawer, { attributes: true, attributeFilter: ['open'] });
    })();
  </script>
{%- endif -%}

<script>
  window.tcUpdateFSBars = window.tcUpdateFSBars || (function () {
      var SHOP_CURRENCY = {{ shop.currency | json }};

      /* Trailing debounce: an add-to-cart fires this from several places at
         once (section re-render callback + CartLinesUpdateEvent + cart:updated)
         — collapse the burst into one /cart.js fetch; the last call wins. */
      var _fsDebounce;
      function run() {
        clearTimeout(_fsDebounce);
        _fsDebounce = setTimeout(runNow, 150);
      }

      function runNow() {
        var info = window.tcCurrencyInfo ? window.tcCurrencyInfo() : { rate: 1, active: SHOP_CURRENCY };
        var rate = info.rate;
        var active = info.active;

        fetch('/cart.js')
          .then(function (r) { return r.json(); })
          .then(function (cart) {
            var cartTotal = cart.total_price;
            var cartCurrency = cart.currency;

            document.querySelectorAll('[data-free-shipping-progress]').forEach(function (el) {
              var baseCents = parseInt(el.dataset.fsUsdCents || '0', 10);
              if (!baseCents) return;

              var threshCents, progress, remaining;
              if (cartCurrency !== active) {
                // Cart API still in base currency (JS converter, no server-side Markets)
                threshCents = baseCents;
                progress = Math.min(100, Math.floor(cartTotal * 100 / threshCents));
                remaining = Math.round(Math.max(0, threshCents - cartTotal) * rate);
              } else {
                // Shopify Markets: cart API already in presentment currency
                threshCents = Math.round(baseCents * rate);
                progress = Math.min(100, Math.floor(cartTotal * 100 / threshCents));
                remaining = Math.max(0, threshCents - cartTotal);
              }

              var fill = el.querySelector('[data-free-shipping-bar]');
              if (fill) fill.style.width = progress + '%';
              if (el.classList.contains('tc-freeship') || el.classList.contains('tc-freeship--unlocked')) {
                el.classList.toggle('tc-freeship--unlocked', progress >= 100);
              }

              var msg = el.querySelector('[data-free-shipping-message]');
              if (!msg) return;
              if (progress >= 100) {
                msg.innerHTML = 'Free shipping unlocked';
              } else {
                /* remaining is already in the active display currency here
                   (rate-converted above) - format only, no second conversion. */
                var formatted = window.tcFormatMoney(remaining, { currency: active, maxDigits: 2 });
                var pre = el.dataset.freeShippingPrefix || '';
                var suf = el.dataset.freeShippingSuffix || '';
                msg.innerHTML = (pre ? pre + ' ' : '') + '<strong>' + formatted + '</strong>' + (suf ? ' ' + suf : '');
              }
            });
          })
          .catch(function () {});
      }

      document.addEventListener('CartLinesUpdateEvent', async function (e) {
        try { await (e.detail && e.detail.promise); } catch (_) {}
        setTimeout(run, 100);
      });
      document.addEventListener('localization:changed', run);
      document.addEventListener('currency:changed', run);

    return run;
  }());

  document.addEventListener('DOMContentLoaded', function () { window.tcUpdateFSBars(); });
</script>

{% stylesheet %}
  cart-drawer-component {
    --cart-drawer-padding: var(--theme-drawer-padding);
    --font-paragraph--line-height: 1;
    display: contents;
  }

  cart-drawer-component:not(:defined) {
    display: block;
  }

  .cart-drawer__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
  }

  .cart-drawer__inner > .cart-items-component {
    flex: 1;
    min-height: 0;
    height: auto;
  }

  .cart-drawer__content {
    display: flex;
    flex-direction: column;
    padding: 0;
    background-color: var(--color-background);
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  .cart-drawer__items {
    display: flex;
    flex-direction: column;
    padding-inline: var(--cart-drawer-padding);
    padding-bottom: 14px;
    overflow-y: auto;
  }

  .cart-drawer__items .cart-items__table-row {
    padding-bottom: var(--gap-xl);
    border-bottom: var(--style-border-width) solid rgb(var(--color-foreground-rgb) / var(--opacity-10-25));
    margin-bottom: var(--gap-xl);
  }

  .cart-drawer__items .cart-items__table-row:has(+ .cart-items__nested-line) {
    border-bottom: none;
    margin-bottom: 0;
  }

  .cart-drawer__items .cart-items__table-row:last-child {
    border-bottom: none;
    padding-block-end: 0;
    margin-block-end: 0;
  }

  .cart-drawer__close-button--empty {
    margin-inline-start: auto;
  }

  .cart-drawer__summary {
    --cart-drawer-summary-padding: var(--padding-lg);

    position: sticky;
    bottom: 0;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--gap-xl);
    padding: var(--cart-drawer-summary-padding);
    margin-top: auto;
    background-color: var(--color-background);
    /* stylelint-disable-next-line color-named */
    mask-image: linear-gradient(to bottom, transparent, black var(--cart-drawer-summary-padding));

    @media screen and (min-width: 750px) {
      --cart-drawer-summary-padding: var(--padding-2xl);
    }
  }

  #cart-drawer .theme-drawer__dialog[cart-summary-sticky='false'] .cart-drawer__summary {
    position: static;
    mask-image: none;
  }

  .theme-drawer__dialog[cart-summary-sticky='false'] .cart-drawer__items {
    overflow: unset;
  }

  .cart-actions summary {
    padding-inline: 0;
    padding-block: var(--padding-sm);
    line-height: 1.2;
    min-height: var(--minimum-touch-target);
  }

  .cart-drawer__summary .cart__summary-totals:not(:has(.cart__subtotal-container:empty)) {
    border-block-start: var(--style-border-width) solid rgb(var(--color-foreground-rgb) / var(--opacity-10-25));
    padding-block-start: var(--padding-2xl);
  }

  .cart-drawer__summary .cart-note {
    @media screen and (min-width: 750px) {
      margin-block-start: var(--margin-3xs);
    }
  }

  .cart-drawer--empty .cart-drawer__content {
    text-align: center;
    align-items: center;
    justify-content: center;
    min-height: auto;
  }

  .cart-drawer--empty .cart-drawer__items {
    padding-inline: 0;
  }

  cart-drawer-component:not(:has(.cart-form)) .cart-drawer__content {
    text-align: center;
    align-items: center;
    justify-content: center;
  }

  cart-drawer-component:not(:has(.cart-form)) .cart-drawer__items {
    padding-inline: 0;
  }

  @media screen and (prefers-reduced-motion: no-preference) {
    html:active-view-transition-type(empty-cart-drawer) {
      .theme-drawer__close-button {
        view-transition-name: cart-drawer-close-button;
      }
    }
  }

  :active-view-transition {
    .cart-drawer__header,
    .cart-drawer__content {
      background: transparent;
    }
  }

  /* ─── Tailand brand overrides ──────────────────────────────────── */

  .theme-drawer__dialog.color-custom-drawer {
    background-color: #FFF4D9;
    border-left: 3px solid #2B1B12;
  }

  #cart-drawer .theme-drawer__dialog.color-custom-drawer {
    overflow: hidden;
  }

  .theme-drawer__header {
    background-color: #FFF4D9;
    border-bottom: 2px solid #2B1B12;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .theme-drawer__title {
    flex: 1;
    min-width: 0;
    font-family: 'Fredoka', sans-serif;
    color: #2B1B12;
  }

  /* Break the table formatting context so display:grid works reliably on <tr> across all browsers */
  .cart-drawer__items .cart-items__table,
  .cart-drawer__items .cart-items__table tbody {
    display: block;
  }
  .cart-drawer__items .cart-items__table thead {
    display: none;
  }

  .cart-drawer__items .cart-items__table-row {
    display: grid;
    background: #fff;
    border: 2.5px solid #2B1B12;
    border-radius: 16px;
    box-shadow: 4px 4px 0 #2B1B12;
    padding: 0.9rem;
    margin-bottom: 1rem;
    /* 80px image | flexible title | price auto-sized */
    grid-template-columns: 80px minmax(0, 1fr) auto;
    grid-template-rows: repeat(5, min-content);
    grid-template-areas: 'media details price' 'media variants variants' 'media unit_price unit_price' 'media quantity quantity' 'media error error';
    column-gap: 10px;
  }

  /* Assign grid areas on cells */
  .cart-drawer__items .cart-items__media              { grid-area: media; align-self: start; width: 80px; }
  .cart-drawer__items .cart-items__details            { display: contents; }
  .cart-drawer__items .cart-items__product-info       { grid-area: details; }
  .cart-drawer__items .cart-items__variants-wrapper   { grid-area: variants; }
  .cart-drawer__items .cart-items__unit-price-wrapper { grid-area: unit_price; }
  .cart-drawer__items .cart-items__quantity           { grid-area: quantity; }
  .cart-drawer__items .cart-items__price              { grid-area: price; text-align: end; min-width: 0; }
  .cart-drawer__items .cart-items__error              { grid-area: error; }

  .cart-drawer__items .cart-items__table-row:last-child {
    border: 2.5px solid #2B1B12;
    padding-block-end: 0.9rem;
    margin-block-end: 0;
  }

  /* Spacing between header and first card, and last card and summary */
  .cart-drawer__items {
    padding-top: 1.25rem;
    padding-bottom: 20px;
  }

  /* Hide per-unit price in drawer — line total top-right is sufficient */
  .cart-drawer__items .cart-items__unit-price-wrapper {
    display: none !important;
  }

  .cart-items__media-container {
    border-radius: 10px;
    overflow: hidden;
    border: 2px solid #2B1B12;
    width: 100%;
  }

  .cart-items__title {
    font-family: 'Fredoka', sans-serif;
    color: #2B1B12;
    font-weight: 600;
  }

  .cart-items__variants dt,
  .cart-items__variants dd {
    color: #7A5C45;
    font-size: 0.8rem;
  }

  .cart-items__price text-component,
  .cart-items__price {
    font-family: 'Fredoka', sans-serif;
    color: #2B1B12;
    font-weight: 600;
  }

  /* ── Quantity controls ─────────────────────────────────────────── */
  .cart-drawer__items .cart-items__quantity .quantity-selector {
    background: #FFF4D9;
    border: 2px solid #2B1B12;
    border-radius: 50px;
    box-shadow: 2px 2px 0 #2B1B12;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    height: 2.2rem;
    min-width: 7rem;
    padding: 0;
    gap: 0;
  }

  .cart-drawer__items .cart-items__quantity .quantity-minus,
  .cart-drawer__items .cart-items__quantity .quantity-plus {
    background: transparent;
    border: none;
    border-radius: 0;
    color: #2B1B12;
    width: 2.2rem;
    height: 2.2rem;
    min-width: 2.2rem;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: none;
    padding: 0;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .cart-drawer__items .cart-items__quantity .quantity-minus:hover,
  .cart-drawer__items .cart-items__quantity .quantity-plus:hover {
    background: #F18222;
    color: #fff;
  }

  .cart-drawer__items .cart-items__quantity .quantity-minus svg,
  .cart-drawer__items .cart-items__quantity .quantity-plus svg {
    width: 0.8rem;
    height: 0.8rem;
  }

  .cart-drawer__items .cart-items__quantity .quantity-selector input[type="number"] {
    background: transparent;
    border: none;
    text-align: center;
    color: #2B1B12;
    font-family: 'Fredoka', sans-serif;
    font-weight: 600;
    font-size: 1rem;
    flex: 1;
    min-width: 0;
    width: 2rem;
    padding: 0;
    height: 100%;
    box-shadow: none;
    outline: none;
    -moz-appearance: textfield;
    appearance: textfield;
  }

  .cart-drawer__items .cart-items__quantity .quantity-selector input[type="number"]::-webkit-inner-spin-button,
  .cart-drawer__items .cart-items__quantity .quantity-selector input[type="number"]::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  /* ── Remove button ──────────────────────────────────────────────── */
  .cart-drawer__items .cart-items__remove {
    background: #FFF4D9;
    border: 2px solid #2B1B12;
    border-radius: 50%;
    width: 2rem;
    height: 2rem;
    min-width: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #2B1B12;
    box-shadow: 2px 2px 0 #2B1B12;
    padding: 0;
    transition: background 0.15s ease, color 0.15s ease, transform 0.12s ease, box-shadow 0.12s ease;
  }

  .cart-drawer__items .cart-items__remove:hover {
    background: #F18222;
    color: #fff;
    transform: translate(1px, 1px);
    box-shadow: 1px 1px 0 #2B1B12;
  }

  .cart-drawer__items .cart-items__remove svg {
    width: 0.875rem;
    height: 0.875rem;
    flex-shrink: 0;
  }

  #cart-drawer .cart-drawer__summary {
    background-color: #FFF4D9;
    border-top: 2px solid #2B1B12;
    mask-image: none;
    position: static;
    flex-shrink: 0;
    margin-top: 0;
    padding-bottom: calc(var(--cart-drawer-summary-padding) + env(safe-area-inset-bottom, 0px));
  }

  /* ── Short viewport: compact summary so products get usable height ── */
  @media screen and (max-height: 650px) {
    #cart-drawer .cart-drawer__summary {
      --cart-drawer-summary-padding: 10px;
      gap: 8px;
    }
    /* Discount code entry is accessible at checkout — hide it on short screens */
    #cart-drawer .cart-drawer__summary .cart-actions {
      display: none;
    }
  }

  @media screen and (max-height: 520px) {
    #cart-drawer .cart-drawer__summary {
      --cart-drawer-summary-padding: 8px;
      gap: 6px;
    }
    /* Hide shipping/duties note — visible at checkout anyway */
    #cart-drawer .cart-drawer__summary .cart-totals__tax-note {
      display: none;
    }
  }

  .cart-totals__total-label,
  .cart-totals__total-value {
    font-family: 'Fredoka', sans-serif;
    color: #2B1B12;
    font-weight: 600;
    font-size: 1.1rem;
  }

  /* Space between discount section and totals/shipping */
  #cart-drawer .totals {
    margin-top: 14px;
  }

  .cart__ctas .cart__checkout-button {
    background-color: #5BB870;
    color: #fff;
    border: 2.5px solid #2B1B12;
    border-radius: 50px;
    box-shadow: 4px 4px 0 #2B1B12;
    font-family: 'Fredoka', sans-serif;
    font-weight: 600;
    font-size: 1.05rem;
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }

  .cart__ctas .cart__checkout-button:hover {
    background-color: #4da362;
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 #2B1B12;
  }

  /* Empty cart state */
  .tp-cart-empty__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    padding: 2.5rem 1.5rem;
    text-align: center;
  }

  .tp-cart-empty__msg {
    font-family: 'Fredoka', sans-serif;
    font-size: 1.15rem;
    color: #2B1B12;
    margin: 0;
    line-height: 1.4;
    max-width: 240px;
  }

  .tp-cart-empty__btn {
    display: inline-block;
    background: #5BB870;
    color: #fff;
    border: 2.5px solid #2B1B12;
    border-radius: 50px;
    box-shadow: 4px 4px 0 #2B1B12;
    font-family: 'Fredoka', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    padding: 0.6rem 1.5rem;
    text-decoration: none;
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }

  .tp-cart-empty__btn:hover {
    background: #4da362;
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 #2B1B12;
  }

  /* ── Cart drawer header count badge ────────────────────────────── */
  #cart-drawer .theme-drawer__badge {
    background-color: #F18222;
    color: #fff;
    border: 1.5px solid #2B1B12;
    box-shadow: 2px 2px 0 #2B1B12;
    font-family: 'Fredoka', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    min-width: 22px;
    height: 22px;
    border-radius: 50px;
    padding-inline: 0.4em;
  }

  /* ── Cart count badge ───────────────────────────────────────────── */
  .header-actions__cart-icon {
    --cart-bubble-background: #F18222;
    --cart-bubble-text: #fff;
  }

  .header-actions__cart-icon .cart-bubble {
    border: 1.5px solid #2B1B12;
    box-shadow: 2px 2px 0 #2B1B12;
  }

  .header-actions__cart-icon .cart-bubble__text {
    font-family: 'Fredoka', sans-serif;
    font-weight: 700;
    font-size: 0.6rem;
    line-height: 1;
  }

  /* ── Desktop: cart drawer as true overlay (no page squeeze) ─────────── */
  @media screen and (min-width: 990px) {
    /* Neutralize base.css margin-right squeeze; page stays full-width */
    body.tc-cart-drawer-open .page-wrapper {
      margin-right: 0 !important;
      transition: none !important;
      overflow-y: hidden !important;
    }

    /* Lower every stacking context in the header below the cart dialog.
       Primary fix is the JS inline style in syncDrawerClass(); this is the CSS backup.
       .header-section is position:sticky z-index:18; #header-component and .header also
       create stacking contexts via contain:layout. Target all three. */
    body.tc-cart-drawer-open .header-section,
    body.tc-cart-drawer-open #header-component,
    body.tc-cart-drawer-open .header {
      z-index: 1 !important;
    }

    /* Scrim covers only the page-content area (left side of viewport).
       Stops at the drawer's left edge so it never dims the cart itself.
       z-index 7: above lowered header (1), below cart dialog (theme z-index 8). */
    .tc-cart-scrim {
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      right: var(--theme-drawer-width, var(--sidebar-width));
      z-index: 7;
      background: rgba(0, 0, 0, 0.35);
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    body.tc-cart-drawer-open .tc-cart-scrim {
      pointer-events: auto;
      opacity: 1;
    }

  }

  /* Desktop: dialog is now in the top layer via showModal() — no z-index fight needed.
     Suppress the native ::backdrop; .tc-cart-scrim handles the dim overlay instead. */
  @media screen and (min-width: 990px) {
    #cart-drawer .theme-drawer__dialog::backdrop {
      background: transparent;
    }
  }

  /* Mobile/tablet: keep the native showModal() backdrop as the dim overlay */
  @media screen and (max-width: 989px) {
    .tc-cart-scrim {
      display: none;
    }

    #cart-drawer .theme-drawer__dialog::backdrop {
      background: rgba(0, 0, 0, 0.35);
    }
  }

  /* ── Free shipping bar ─────────────────────────────────────── */
  .tc-freeship {
    margin: 0 0 12px;
    padding: 10px 14px 12px;
    background: #FFF4D9;
    border: 2.5px solid #2d2d2d;
    border-radius: 16px;
    box-shadow: 3px 3px 0 #2d2d2d;
  }
  .tc-freeship__text {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 8px;
    font-family: 'Nunito Sans', sans-serif;
    font-size: 0.88rem;
    font-weight: 700;
    color: #2B1B12;
    line-height: 1.3;
  }
  .tc-freeship__text svg {
    width: 18px;
    height: 18px;
    color: #2eaa5f;
    flex-shrink: 0;
  }
  .tc-freeship--unlocked .tc-freeship__text {
    color: #2eaa5f;
  }
  .tc-freeship--unlocked .tc-freeship__text svg {
    color: #2eaa5f;
  }
  .tc-freeship__text strong {
    font-weight: 800;
  }
  .tc-freeship__track {
    height: 8px;
    background: #E4DDD5;
    border-radius: 999px;
    overflow: hidden;
  }
  .tc-freeship__fill {
    height: 100%;
    background: #2eaa5f;
    border-radius: 999px;
    transition: width 0.4s ease;
    min-width: 2px;
  }

  /* ── Delete all button ──────────────────────────────────────── */
  .tc-cart-clear-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
    padding: 8px 16px;
    background: #FFF4D9;
    color: #2B1B12;
    border: 2.5px solid #2B1B12;
    border-radius: 999px;
    box-shadow: 2px 2px 0 #2B1B12;
    font-family: 'Nunito Sans', sans-serif;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.12s ease, color 0.12s ease, transform 0.1s ease, box-shadow 0.1s ease;
    min-height: 38px;
  }
  .tc-cart-clear-btn svg {
    flex-shrink: 0;
    width: 13px;
    height: 13px;
  }
  .tc-cart-clear-btn:hover:not(:disabled):not([data-state="confirm"]) {
    background: #EE7B28;
    color: #fff;
    transform: translate(1px, 1px);
    box-shadow: 1px 1px 0 #2B1B12;
  }
  .tc-cart-clear-btn[data-state="confirm"] {
    background: #EE7B28;
    color: #fff;
    transform: translate(1px, 1px);
    box-shadow: 1px 1px 0 #2B1B12;
  }
  .tc-cart-clear-btn:disabled,
  .tc-cart-clear-btn[data-state="loading"] {
    opacity: 0.6;
    cursor: not-allowed;
    pointer-events: none;
  }
  @media screen and (max-width: 479px) {
    .tc-cart-clear-btn__text {
      display: none;
    }
    .tc-cart-clear-btn {
      padding: 8px 10px;
    }
  }
{% endstylesheet %}
