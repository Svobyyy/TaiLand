{% doc %}
  Renders reusable cart drawer markup for both initial page loads and Section Rendering API responses.

  @param {boolean} [render_wrapper] - When true, wraps the drawer in the section wrapper that the Section Rendering API adds automatically.
{% enddoc %}

{%- liquid
  assign render_wrapper = render_wrapper | default: true, allow_false: true
-%}

{%- if settings.cart_type == 'drawer' and template.name != 'cart' -%}
  {% if render_wrapper %}
    <div
      id="shopify-section-cart-drawer-section"
      class="shopify-section"
    >
  {% endif %}

  <script
    type="module"
    src="{{ 'cart-drawer.js' | asset_url }}"
    fetchpriority="low"
  ></script>
  <script
    type="module"
    src="{{ 'component-cart-items.js' | asset_url }}"
    fetchpriority="low"
  ></script>

  {% capture empty_cart_drawer_content %}
    <div
      class="cart-drawer__content"
      aria-label="{{ 'accessibility.cart' | t }}"
    >
      <h2
        class="theme-drawer__title h4"
        id="cart-drawer-heading"
      >
        {{ 'content.your_cart_is_empty' | t }}
      </h2>

      <div class="cart-drawer__items">
        <div class="tp-cart-empty__inner">
          <p class="tp-cart-empty__msg">Your cart is waiting for some pawsome picks.</p>
          <a href="/collections/best-sellers" class="tp-cart-empty__btn">Shop Best Sellers</a>
        </div>
      </div>
    </div>
    {% endcapture %}

  <theme-drawer
    id="cart-drawer"
    data-skip-node-update
  >
    <dialog
      ref="panel"
      class="theme-drawer__dialog color-custom-drawer"
      aria-labelledby="cart-drawer-heading"
      cart-summary-sticky="true"
    >
      <cart-drawer-component
        {% if settings.auto_open_cart_drawer and template.name != 'cart' %}
          auto-open
        {% endif %}
      >
        <template id="empty-cart-template">
          {{ empty_cart_drawer_content }}
        </template>

        <div
          class="cart-drawer__inner{% if cart.empty? %} cart-drawer--empty{% endif %}"
          data-hydration-key="cart-drawer-inner"
        >
          {%- if cart.empty? -%}
            <div class="theme-drawer__header">
              <button
                on:click="#cart-drawer/close"
                class="theme-drawer__close-button cart-drawer__close-button--empty"
                type="button"
                aria-label="{{ 'actions.close' | t }}"
              >
                <span class="svg-wrapper">
                  {{- 'icon-close.svg' | inline_asset_content -}}
                </span>
              </button>
            </div>
          {%- else -%}
            {% capture cart_badge_html %}
              <span
                class="theme-drawer__badge{% if cart.item_count == 0 %} visually-hidden{% endif %}"
                aria-hidden="true"
                {% if cart.item_count <= 99 %}
                  data-maintain-ratio
                {% endif %}
              >
                {{- cart.item_count -}}
              </span>
              {% if cart.item_count > 0 %}
                <span class="visually-hidden">
                  {{ 'accessibility.cart_count' | t }}: {{ cart.item_count }}
                </span>
              {% endif %}
            {% endcapture %}
            {% assign cart_drawer_title = 'content.cart_title' | t %}
            {% render 'theme-drawer-header',
              title: cart_drawer_title,
              drawer_id: 'cart-drawer',
              heading_id: 'cart-drawer-heading',
              title_append: cart_badge_html
            %}
          {%- endif -%}

          {% capture cart_items_children %}
            {%- if cart.empty? -%}
              {{ empty_cart_drawer_content }}
            {%- else -%}
              <scroll-hint
                class="cart-drawer__content"
                aria-label="{{ 'accessibility.cart' | t }}"
                style="--header-height: 60px;"
              >
                <scroll-hint class="cart-drawer__items">
                  {% render 'cart-products', context: 'drawer' %}
                </scroll-hint>

                <div class="cart-drawer__summary">
                  {% render 'cart-summary', section_id: 'cart-drawer-section' %}
                </div>
              </scroll-hint>
            {%- endif -%}
          {% endcapture %}
          {% render 'cart-items-component',
            children: cart_items_children,
            is_drawer: true,
            section_id: 'cart-drawer-section'
          %}
        </div>
      </cart-drawer-component>
    </dialog>
  </theme-drawer>

  {% if render_wrapper %}
    </div>
  {% endif %}

  <script>
    (function () {
      var cartDrawer = document.getElementById('cart-drawer');
      if (!cartDrawer) return;

      // Scrim — desktop-only backdrop; clicking it closes the drawer
      var scrim = document.createElement('div');
      scrim.className = 'tc-cart-scrim';
      document.body.appendChild(scrim);
      scrim.addEventListener('click', function () {
        if (typeof cartDrawer.close === 'function') cartDrawer.close();
      });

      var desktopQuery = window.matchMedia('(min-width: 990px)');

      // On desktop, theme-drawer.js calls dialog.show() (non-modal — loses to the sticky header).
      // Session restore calls dialog.setAttribute('open','') directly, also bypassing showModal().
      // Both paths are intercepted to use showModal() (browser top layer), matching mobile.
      if (desktopQuery.matches) {
        var desktopDialog = cartDrawer.querySelector('dialog');
        if (desktopDialog) {
          desktopDialog.show = function () {
            if (!this.open) HTMLDialogElement.prototype.showModal.call(this);
          };
          new MutationObserver(function () {
            if (desktopDialog.hasAttribute('open') && !desktopDialog.matches(':modal')) {
              desktopDialog.close();
              HTMLDialogElement.prototype.showModal.call(desktopDialog);
            }
          }).observe(desktopDialog, { attributes: true, attributeFilter: ['open'] });
        }
      }

      // Body class drives the scrim fade and header z-index via CSS
      function syncDrawerClass() {
        document.body.classList.toggle('tc-cart-drawer-open', cartDrawer.hasAttribute('open'));
      }

      desktopQuery.addEventListener('change', syncDrawerClass);
      new MutationObserver(syncDrawerClass).observe(cartDrawer, {
        attributes: true,
        attributeFilter: ['open'],
      });
      syncDrawerClass();
    })();
  </script>
{%- endif -%}

{% stylesheet %}
  cart-drawer-component {
    --cart-drawer-padding: var(--theme-drawer-padding);
    --font-paragraph--line-height: 1;
    display: contents;
  }

  .cart-drawer__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
  }

  .cart-drawer__inner > .cart-items-component {
    flex: 1;
    min-height: 0;
    height: auto;
  }

  .cart-drawer__content {
    height: calc(100% - var(--header-height));
    display: flex;
    flex-direction: column;
    padding: 0;
    background-color: var(--color-background);
    flex-grow: 1;
    overflow-y: auto;
  }

  .cart-drawer__items {
    display: flex;
    flex-direction: column;
    padding-inline: var(--cart-drawer-padding);
    overflow-y: auto;
  }

  .cart-drawer__items .cart-items__table-row {
    padding-bottom: var(--gap-xl);
    border-bottom: var(--style-border-width) solid rgb(var(--color-foreground-rgb) / var(--opacity-10-25));
    margin-bottom: var(--gap-xl);
  }

  .cart-drawer__items .cart-items__table-row:has(+ .cart-items__nested-line) {
    border-bottom: none;
    margin-bottom: 0;
  }

  .cart-drawer__items .cart-items__table-row:last-child {
    border-bottom: none;
    padding-block-end: 0;
    margin-block-end: 0;
  }

  .cart-drawer__close-button--empty {
    margin-inline-start: auto;
  }

  .cart-drawer__summary {
    --cart-drawer-summary-padding: var(--padding-lg);

    position: sticky;
    bottom: 0;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--gap-xl);
    padding: var(--cart-drawer-summary-padding);
    margin-top: auto;
    background-color: var(--color-background);
    /* stylelint-disable-next-line color-named */
    mask-image: linear-gradient(to bottom, transparent, black var(--cart-drawer-summary-padding));

    @media screen and (min-width: 750px) {
      --cart-drawer-summary-padding: var(--padding-2xl);
    }
  }

  .theme-drawer__dialog[cart-summary-sticky='false'] .cart-drawer__summary {
    position: static;
    mask-image: none;
  }

  .theme-drawer__dialog[cart-summary-sticky='false'] .cart-drawer__items {
    overflow: unset;
  }

  .cart-actions summary {
    padding-inline: 0;
    padding-block: var(--padding-sm);
    line-height: 1.2;
    min-height: var(--minimum-touch-target);
  }

  .cart-drawer__summary .cart__summary-totals:not(:has(.cart__subtotal-container:empty)) {
    border-block-start: var(--style-border-width) solid rgb(var(--color-foreground-rgb) / var(--opacity-10-25));
    padding-block-start: var(--padding-2xl);
  }

  .cart-drawer__summary .cart-note {
    @media screen and (min-width: 750px) {
      margin-block-start: var(--margin-3xs);
    }
  }

  .cart-drawer--empty .cart-drawer__content {
    text-align: center;
    align-items: center;
    justify-content: center;
    min-height: auto;
  }

  .cart-drawer--empty .cart-drawer__items {
    padding-inline: 0;
  }

  cart-drawer-component:not(:has(.cart-form)) .cart-drawer__content {
    text-align: center;
    align-items: center;
    justify-content: center;
  }

  cart-drawer-component:not(:has(.cart-form)) .cart-drawer__items {
    padding-inline: 0;
  }

  @media screen and (prefers-reduced-motion: no-preference) {
    html:active-view-transition-type(empty-cart-drawer) {
      .theme-drawer__close-button {
        view-transition-name: cart-drawer-close-button;
      }
    }
  }

  :active-view-transition {
    .cart-drawer__header,
    .cart-drawer__content {
      background: transparent;
    }
  }

  /* ─── Tailand brand overrides ──────────────────────────────────── */

  .theme-drawer__dialog.color-custom-drawer {
    background-color: #FFF4D9;
    border-left: 3px solid #2B1B12;
  }

  .theme-drawer__header {
    background-color: #FFF4D9;
    border-bottom: 2px solid #2B1B12;
  }

  .theme-drawer__title {
    font-family: 'Fredoka', sans-serif;
    color: #2B1B12;
  }

  .cart-drawer__items .cart-items__table-row {
    background: #fff;
    border: 2.5px solid #2B1B12;
    border-radius: 16px;
    box-shadow: 4px 4px 0 #2B1B12;
    padding: 0.9rem;
    margin-bottom: 1rem;
  }

  .cart-drawer__items .cart-items__table-row:last-child {
    border: 2.5px solid #2B1B12;
    padding-block-end: 0.9rem;
    margin-block-end: 0;
  }

  /* Spacing between header and first card, and last card and summary */
  .cart-drawer__items {
    padding-top: 1.25rem;
    padding-bottom: 1.5rem;
  }

  /* Hide per-unit price in drawer — line total top-right is sufficient */
  .cart-drawer__items .cart-items__unit-price-wrapper {
    display: none;
  }

  .cart-items__media-container {
    border-radius: 10px;
    overflow: hidden;
    border: 2px solid #2B1B12;
  }

  .cart-items__title {
    font-family: 'Fredoka', sans-serif;
    color: #2B1B12;
    font-weight: 600;
  }

  .cart-items__variants dt,
  .cart-items__variants dd {
    color: #7A5C45;
    font-size: 0.8rem;
  }

  .cart-items__price text-component,
  .cart-items__price {
    font-family: 'Fredoka', sans-serif;
    color: #2B1B12;
    font-weight: 600;
  }

  /* ── Quantity controls ─────────────────────────────────────────── */
  .cart-drawer__items .cart-items__quantity .quantity-selector {
    background: #FFF4D9;
    border: 2px solid #2B1B12;
    border-radius: 50px;
    box-shadow: 2px 2px 0 #2B1B12;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    height: 2.2rem;
    min-width: 7rem;
    padding: 0;
    gap: 0;
  }

  .cart-drawer__items .cart-items__quantity .quantity-minus,
  .cart-drawer__items .cart-items__quantity .quantity-plus {
    background: transparent;
    border: none;
    border-radius: 0;
    color: #2B1B12;
    width: 2.2rem;
    height: 2.2rem;
    min-width: 2.2rem;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: none;
    padding: 0;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .cart-drawer__items .cart-items__quantity .quantity-minus:hover,
  .cart-drawer__items .cart-items__quantity .quantity-plus:hover {
    background: #F18222;
    color: #fff;
  }

  .cart-drawer__items .cart-items__quantity .quantity-minus svg,
  .cart-drawer__items .cart-items__quantity .quantity-plus svg {
    width: 0.8rem;
    height: 0.8rem;
  }

  .cart-drawer__items .cart-items__quantity .quantity-selector input[type="number"] {
    background: transparent;
    border: none;
    text-align: center;
    color: #2B1B12;
    font-family: 'Fredoka', sans-serif;
    font-weight: 600;
    font-size: 1rem;
    flex: 1;
    min-width: 0;
    width: 2rem;
    padding: 0;
    height: 100%;
    box-shadow: none;
    outline: none;
    -moz-appearance: textfield;
    appearance: textfield;
  }

  .cart-drawer__items .cart-items__quantity .quantity-selector input[type="number"]::-webkit-inner-spin-button,
  .cart-drawer__items .cart-items__quantity .quantity-selector input[type="number"]::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  /* ── Remove button ──────────────────────────────────────────────── */
  .cart-drawer__items .cart-items__remove {
    background: #FFF4D9;
    border: 2px solid #2B1B12;
    border-radius: 50%;
    width: 2rem;
    height: 2rem;
    min-width: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #2B1B12;
    box-shadow: 2px 2px 0 #2B1B12;
    padding: 0;
    transition: background 0.15s ease, color 0.15s ease, transform 0.12s ease, box-shadow 0.12s ease;
  }

  .cart-drawer__items .cart-items__remove:hover {
    background: #F18222;
    color: #fff;
    transform: translate(1px, 1px);
    box-shadow: 1px 1px 0 #2B1B12;
  }

  .cart-drawer__items .cart-items__remove svg {
    width: 0.875rem;
    height: 0.875rem;
    flex-shrink: 0;
  }

  .cart-drawer__summary {
    background-color: #FFF4D9;
    border-top: 2px solid #2B1B12;
    mask-image: none;
  }

  .cart-totals__total-label,
  .cart-totals__total-value {
    font-family: 'Fredoka', sans-serif;
    color: #2B1B12;
    font-weight: 600;
    font-size: 1.1rem;
  }

  .cart__ctas .cart__checkout-button {
    background-color: #5BB870;
    color: #fff;
    border: 2.5px solid #2B1B12;
    border-radius: 50px;
    box-shadow: 4px 4px 0 #2B1B12;
    font-family: 'Fredoka', sans-serif;
    font-weight: 600;
    font-size: 1.05rem;
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }

  .cart__ctas .cart__checkout-button:hover {
    background-color: #4da362;
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 #2B1B12;
  }

  /* Empty cart state */
  .tp-cart-empty__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    padding: 2.5rem 1.5rem;
    text-align: center;
  }

  .tp-cart-empty__msg {
    font-family: 'Fredoka', sans-serif;
    font-size: 1.15rem;
    color: #2B1B12;
    margin: 0;
    line-height: 1.4;
    max-width: 240px;
  }

  .tp-cart-empty__btn {
    display: inline-block;
    background: #5BB870;
    color: #fff;
    border: 2.5px solid #2B1B12;
    border-radius: 50px;
    box-shadow: 4px 4px 0 #2B1B12;
    font-family: 'Fredoka', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    padding: 0.6rem 1.5rem;
    text-decoration: none;
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }

  .tp-cart-empty__btn:hover {
    background: #4da362;
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 #2B1B12;
  }

  /* ── Cart drawer header count badge ────────────────────────────── */
  #cart-drawer .theme-drawer__badge {
    background-color: #F18222;
    color: #fff;
    border: 1.5px solid #2B1B12;
    box-shadow: 2px 2px 0 #2B1B12;
    font-family: 'Fredoka', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    min-width: 22px;
    height: 22px;
    border-radius: 50px;
    padding-inline: 0.4em;
  }

  /* ── Cart count badge ───────────────────────────────────────────── */
  .header-actions__cart-icon {
    --cart-bubble-background: #F18222;
    --cart-bubble-text: #fff;
  }

  .header-actions__cart-icon .cart-bubble {
    border: 1.5px solid #2B1B12;
    box-shadow: 2px 2px 0 #2B1B12;
  }

  .header-actions__cart-icon .cart-bubble__text {
    font-family: 'Fredoka', sans-serif;
    font-weight: 700;
    font-size: 0.6rem;
    line-height: 1;
  }

  /* ── Desktop: cart drawer as true overlay (no page squeeze) ─────────── */
  @media screen and (min-width: 990px) {
    /* Neutralize base.css margin-right squeeze; page stays full-width */
    body.tc-cart-drawer-open .page-wrapper {
      margin-right: 0 !important;
      transition: none !important;
      overflow-y: hidden !important;
    }

    /* Lower every stacking context in the header below the cart dialog.
       Primary fix is the JS inline style in syncDrawerClass(); this is the CSS backup.
       .header-section is position:sticky z-index:18; #header-component and .header also
       create stacking contexts via contain:layout. Target all three. */
    body.tc-cart-drawer-open .header-section,
    body.tc-cart-drawer-open #header-component,
    body.tc-cart-drawer-open .header {
      z-index: 1 !important;
    }

    /* Scrim covers only the page-content area (left side of viewport).
       Stops at the drawer's left edge so it never dims the cart itself.
       z-index 7: above lowered header (1), below cart dialog (theme z-index 8). */
    .tc-cart-scrim {
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      right: var(--theme-drawer-width, var(--sidebar-width));
      z-index: 7;
      background: rgba(0, 0, 0, 0.35);
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    body.tc-cart-drawer-open .tc-cart-scrim {
      pointer-events: auto;
      opacity: 1;
    }

  }

  /* Desktop: dialog is now in the top layer via showModal() — no z-index fight needed.
     Suppress the native ::backdrop; .tc-cart-scrim handles the dim overlay instead. */
  @media screen and (min-width: 990px) {
    #cart-drawer .theme-drawer__dialog::backdrop {
      background: transparent;
    }
  }

  /* Mobile/tablet: keep the native showModal() backdrop as the dim overlay */
  @media screen and (max-width: 989px) {
    .tc-cart-scrim {
      display: none;
    }

    #cart-drawer .theme-drawer__dialog::backdrop {
      background: rgba(0, 0, 0, 0.35);
    }
  }
{% endstylesheet %}
