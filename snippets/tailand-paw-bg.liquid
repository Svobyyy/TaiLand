      );
      mask-image: linear-gradient(
        to right,
        black                   0%,
        rgba(0, 0, 0, 0.80)     8%,
        rgba(0, 0, 0, 0.40)    20%,
        rgba(0, 0, 0, 0.10)    32%,
        rgba(0, 0, 0, 0.05)    38%,
        rgba(0, 0, 0, 0.05)    62%,
