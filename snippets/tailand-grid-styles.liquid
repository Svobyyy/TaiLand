{% stylesheet %}
/* =========================================================
   Tailand product grid — shared tc-* classes
   Rendered by both sections/tailand-collection.liquid and
   sections/tailand-search.liquid ({% render 'tailand-grid-styles' %}).
   Card markup itself is shared via snippets/tailand-product-card.liquid.
   Each section's own {% stylesheet %} block only holds rules truly
   exclusive to that page (collection's AJAX-loading state, search's
   search-form styling) — everything else belongs HERE, not duplicated.
   ========================================================= */

.tc-container {
  max-width: 1300px;
  margin: 0 auto;
  padding-inline: var(--page-margin, 20px);
}

/* ── Hero ── */
.tc-hero {
  text-align: center;
  margin-bottom: 44px;
}

.tc-hero__heading {
  font-family: 'Fredoka', sans-serif;
  font-size: clamp(2rem, 5vw, 3rem);
  font-weight: 600;
  color: var(--pc-text, #2B1B12);
  line-height: 1.2;
  margin: 0 0 14px;
}

.tc-hero__plain {
  font-weight: 400;
}

.tc-hero__highlight {
  display: inline-block;
  position: relative;
  font-weight: 700;
  white-space: nowrap;
  padding-bottom: 8px;
}

.tc-hero__underline {
  position: absolute;
  left: -3%;
  bottom: -2px;
  width: 106%;
  height: 12px;
  color: var(--pc-green, #4F8A2F);
  pointer-events: none;
  display: block;
}

.tc-hero__desc {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 1.05rem;
  font-weight: 600;
  color: var(--pc-text, #2B1B12);
  opacity: 0.7;
  max-width: 580px;
  margin: 0 auto;
  line-height: 1.65;
}

/* ── Search query badge ── */
.tc-query-badge {
  display: inline-flex;
  align-items: center;
  background: var(--pc-orange, #EE7B28);
  color: #fff;
  border: 2px solid var(--pc-text, #2B1B12);
  border-radius: 50px;
  box-shadow: 3px 3px 0 var(--pc-text, #2B1B12);
  padding: 0.12em 0.65em 0.18em;
  font-weight: 700;
  font-size: 0.78em;
  vertical-align: middle;
  white-space: nowrap;
  max-width: 300px;
  overflow: hidden;
  text-overflow: ellipsis;
  font-family: 'Nunito Sans', sans-serif;
  letter-spacing: 0.01em;
  line-height: 1.4;
}

.tc-search-meta {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 1rem;
  color: var(--pc-text, #2B1B12);
  opacity: 0.6;
  margin: 8px auto 0;
  font-weight: 600;
}

/* ── Category tabs ── */
.tc-tabs {
  display: flex;
  gap: 10px;
  margin-bottom: 32px;
  overflow-x: auto;
  scrollbar-width: none;
  -webkit-overflow-scrolling: touch;
  padding-bottom: 6px;
  justify-content: center;
  flex-wrap: wrap;
}

.tc-tabs::-webkit-scrollbar { display: none; }

.tc-tab {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 10px 22px;
  background: var(--pc-white, #fff);
  color: var(--pc-text, #2B1B12);
  border: 2.5px solid var(--pc-text, #2B1B12);
  border-radius: 999px;
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.95rem;
  font-weight: 800;
  text-decoration: none;
  white-space: nowrap;
  box-shadow: 3px 3px 0 var(--pc-text, #2B1B12);
  transition: transform 0.12s ease, box-shadow 0.12s ease;
  flex-shrink: 0;
}

.tc-tab:hover {
  transform: translate(-1px, -1px);
  box-shadow: 4px 4px 0 var(--pc-text, #2B1B12);
  color: var(--pc-text, #2B1B12);
}

.tc-tab--active {
  background: var(--pc-orange, #EE7B28);
  color: var(--pc-white, #fff);
}

.tc-tab--active:hover { color: var(--pc-white, #fff); }

.tc-tab__icon {
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
  line-height: 0;
}

.tc-tab__icon svg {
  width: 17px;
  height: 17px;
}

/* ── Sort toolbar ── */
.tc-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 28px;
  padding: 12px 20px;
  background: #FFF4D9;
  border: 1.5px solid rgba(43, 27, 18, 0.1);
  border-radius: 14px;
}

.tc-toolbar__count {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--pc-text, #2B1B12);
  opacity: 0.6;
  white-space: nowrap;
}

.tc-toolbar__count-paw {
  width: 15px;
  height: 15px;
  flex-shrink: 0;
  opacity: 0.75;
}

.tc-sort-form {
  display: flex;
  align-items: center;
  gap: 8px;
}

.tc-sort__label {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--pc-text, #2B1B12);
  opacity: 0.65;
  white-space: nowrap;
}

.tc-sort__wrap {
  position: relative;
  display: inline-flex;
  align-items: center;
}

.tc-sort__select {
  -webkit-appearance: none;
  appearance: none;
  padding: 9px 42px 9px 16px;
  background: #FFF4D9;
  border: 2.5px solid var(--pc-text, #2B1B12);
  border-radius: 12px;
  box-shadow: 3px 3px 0 var(--pc-text, #2B1B12);
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.9rem;
  font-weight: 800;
  color: var(--pc-text, #2B1B12);
  cursor: pointer;
  min-width: 200px;
  transition: box-shadow 0.12s ease, transform 0.12s ease;
}

.tc-sort__select:hover {
  transform: translate(-1px, -1px);
  box-shadow: 4px 4px 0 var(--pc-text, #2B1B12);
}

.tc-sort__select:focus {
  outline: 2.5px solid var(--pc-orange, #EE7B28);
  outline-offset: 2px;
  box-shadow: 3px 3px 0 var(--pc-text, #2B1B12);
  transform: none;
}

.tc-sort__arrow {
  position: absolute;
  right: 13px;
  top: 50%;
  transform: translateY(-50%);
  width: 16px;
  height: 16px;
  color: var(--pc-text, #2B1B12);
  pointer-events: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tc-sort__arrow svg { width: 16px; height: 16px; display: block; }

/* ── Product grid ── */
.tc-grid {
  list-style: none;
  padding: 0;
  margin: 0;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}

/* ── Product card ── */
.tc-card {
  background: #FFF4D9;
  border: 2.5px solid var(--pc-text, #2B1B12);
  border-radius: 18px;
  box-shadow: 5px 5px 0 var(--pc-text, #2B1B12);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.tc-card:hover {
  transform: translate(-2px, -2px);
  box-shadow: 7px 7px 0 var(--pc-text, #2B1B12);
}

.tc-card__media-wrap {
  position: relative;
  flex-shrink: 0;
  overflow: visible;
  container-type: inline-size;
  container-name: tc-card-media;
}

.tc-card__media-link {
  display: block;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background: var(--pc-white, #fff);
}

.tc-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.3s ease;
}

.tc-card:hover .tc-card__img { transform: scale(1.04); }

.tc-card__img--placeholder {
  width: 100%;
  aspect-ratio: 1 / 1;
  background: #FFF4D9;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(43, 27, 18, 0.18);
}

.tc-card__img--placeholder svg { width: 52px; height: 52px; }

/* Badges */
.tc-badge-group {
  position: absolute;
  inset: 0;
  z-index: 2;
  pointer-events: none;
}

.tc-badge-group--dual {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: space-between;
  align-content: flex-start;
  padding: 10px;
  gap: 6px;
}

.tc-badge-group--dual .tc-sale-badge,
.tc-badge-group--dual .tc-best-badge { position: static; }

.tc-sale-badge,
.tc-best-badge,
.tc-soldout-badge {
  position: absolute;
  top: 10px;
  z-index: 2;
  padding: 8px 16px;
  color: var(--pc-white, #fff);
  font-family: 'Nunito Sans', sans-serif;
  font-size: 1rem;
  font-weight: 800;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  border-radius: 10px;
  border: 2.5px solid var(--pc-text, #2B1B12);
  box-shadow: 3px 3px 0 var(--pc-text, #2B1B12);
  line-height: 1.3;
  pointer-events: none;
  white-space: nowrap;
}

.tc-sale-badge,
.tc-soldout-badge {
  left: 10px;
}

.tc-best-badge {
  right: 10px;
}

.tc-sale-badge {
  background: var(--pc-sale-red, #D63C3C);
}

.tc-best-badge {
  background: var(--pc-orange, #EE7B28);
}

.tc-soldout-badge {
  background: var(--pc-text, #2B1B12);
}

.tc-card--soldout .tc-card__img {
  opacity: 0.55;
}

/* Card body */
.tc-card__body {
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  flex: 1;
}

.tc-card__title-link { text-decoration: none; color: inherit; }

.tc-card__title {
  font-family: 'Fredoka', sans-serif;
  font-size: 1.15rem;
  font-weight: 600;
  color: var(--pc-text, #2B1B12);
  margin: 0;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.tc-card__title-link:hover .tc-card__title { color: var(--pc-orange, #EE7B28); }

.tc-card__price {
  display: flex;
  align-items: baseline;
  gap: 8px;
  flex-wrap: wrap;
}

.tc-card__price-reg {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 1.15rem;
  font-weight: 800;
  color: var(--pc-text, #2B1B12);
}

.tc-card__price-sale {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 1.15rem;
  font-weight: 800;
  color: var(--pc-sale-red, #D63C3C);
}

.tc-card__price-compare {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.88rem;
  font-weight: 600;
  color: var(--pc-text, #2B1B12);
  opacity: 0.4;
  text-decoration: line-through;
}

.tc-card__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 10px 20px;
  background: var(--pc-green, #4F8A2F);
  color: var(--pc-white, #fff);
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.95rem;
  font-weight: 800;
  text-decoration: none;
  border-radius: 999px;
  border: 2.5px solid var(--pc-text, #2B1B12);
  box-shadow: 3px 3px 0 var(--pc-text, #2B1B12);
  transition: background 0.15s ease, transform 0.1s ease, box-shadow 0.1s ease;
  margin-top: auto;
}

.tc-card__btn svg { width: 14px; height: 14px; flex-shrink: 0; }

.tc-card__btn:hover {
  background: var(--pc-green-dark, #3E6F25);
  color: var(--pc-white, #fff);
  transform: translate(1px, 1px);
  box-shadow: 2px 2px 0 var(--pc-text, #2B1B12);
}

/* ── Empty state ── */
.tc-empty {
  text-align: center;
  padding: 80px 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20px;
}

.tc-empty__paw { color: rgba(43, 27, 18, 0.1); }
.tc-empty__paw svg { width: 80px; height: 80px; }

.tc-empty__heading {
  font-family: 'Fredoka', sans-serif;
  font-size: 1.75rem;
  font-weight: 600;
  color: var(--pc-text, #2B1B12);
  margin: 0;
  line-height: 1.4;
}

.tc-empty__heading .tc-query-badge {
  font-size: 0.65em;
  vertical-align: middle;
}

.tc-empty__text {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 1.05rem;
  color: var(--pc-text, #2B1B12);
  opacity: 0.6;
  margin: 0;
  max-width: 380px;
  line-height: 1.5;
}

.tc-empty__actions {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  justify-content: center;
  margin-top: 4px;
}

.tc-empty__btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 12px 28px;
  background: var(--pc-orange, #EE7B28);
  color: var(--pc-white, #fff);
  font-family: 'Nunito Sans', sans-serif;
  font-size: 1rem;
  font-weight: 800;
  text-decoration: none;
  border-radius: 999px;
  border: 2.5px solid var(--pc-text, #2B1B12);
  box-shadow: 3px 3px 0 var(--pc-text, #2B1B12);
  transition: background 0.15s ease, transform 0.1s ease, box-shadow 0.1s ease;
}

.tc-empty__btn--secondary {
  background: var(--pc-white, #fff);
  color: var(--pc-text, #2B1B12);
}

.tc-empty__btn:hover,
.tc-empty__btn--secondary:hover {
  transform: translate(1px, 1px);
  box-shadow: 2px 2px 0 var(--pc-text, #2B1B12);
  color: var(--pc-white, #fff);
  background: var(--pc-orange-dark, #E58901);
}

.tc-empty__btn--secondary:hover {
  background: var(--pc-text, #2B1B12);
}

/* ── Pagination ── */
.tc-pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  margin-top: 52px;
  flex-wrap: wrap;
}

.tc-pagination__btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 11px 26px;
  background: var(--pc-white, #fff);
  color: var(--pc-text, #2B1B12);
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.95rem;
  font-weight: 800;
  text-decoration: none;
  border-radius: 999px;
  border: 2.5px solid var(--pc-text, #2B1B12);
  box-shadow: 3px 3px 0 var(--pc-text, #2B1B12);
  transition: transform 0.1s ease, box-shadow 0.1s ease;
}

.tc-pagination__btn:hover {
  color: var(--pc-text, #2B1B12);
  transform: translate(-1px, -1px);
  box-shadow: 4px 4px 0 var(--pc-text, #2B1B12);
}

.tc-pagination__info {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.88rem;
  font-weight: 700;
  color: var(--pc-text, #2B1B12);
  opacity: 0.5;
}

/* ── Responsive ── */
@media screen and (min-width: 750px) and (max-width: 1000px) {
  .tc-sale-badge, .tc-soldout-badge { font-size: 0.82rem; padding: 5px 11px; top: 8px; left: 8px; }
  .tc-best-badge { font-size: 0.82rem; padding: 5px 11px; top: 8px; right: 8px; }
  .tc-badge-group--dual { padding: 8px; gap: 5px; }
}

@media screen and (max-width: 1199px) {
  .tc-grid { grid-template-columns: repeat(3, 1fr); gap: 16px; }
}

/* Tablets — scroll tabs horizontally, stack sort bar */
@media screen and (max-width: 960px) {
  .tc-tabs {
    justify-content: flex-start;
    flex-wrap: nowrap;
    margin-bottom: 24px;
    padding-bottom: 8px;
  }

  .tc-toolbar {
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
    padding: 12px 16px;
  }

  .tc-sort-form { width: 100%; }
  .tc-sort__wrap { width: 100%; }
  .tc-sort__select { width: 100%; min-width: 0; }
}

@media screen and (max-width: 749px) {
  .tc-hero { margin-bottom: 28px; }
  .tc-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
  .tc-card__body { padding: 12px; gap: 8px; }
  .tc-card__title { font-size: 1rem; }
  .tc-card__btn { font-size: 0.88rem; padding: 9px 16px; }
  .tc-sale-badge, .tc-soldout-badge { font-size: 0.82rem; padding: 6px 12px; top: 8px; left: 8px; }
  .tc-best-badge { font-size: 0.82rem; padding: 6px 12px; top: 8px; right: 8px; }
  .tc-empty__heading { font-size: 1.35rem; }
  .tc-query-badge { max-width: 200px; }
}

@media screen and (max-width: 480px) {
  .tc-grid { gap: 10px; }
  .tc-card__body { padding: 10px; }
  .tc-card__title { font-size: 0.95rem; }
  .tc-card__btn { font-size: 0.82rem; padding: 8px 12px; }
  .tc-sale-badge, .tc-soldout-badge { font-size: 0.72rem; padding: 4px 9px; top: 7px; left: 7px; }
  .tc-best-badge { font-size: 0.72rem; padding: 4px 9px; top: 7px; right: 7px; }
  .tc-badge-group--dual { padding: 7px; gap: 4px; }
}

@container tc-card-media (max-width: 170px) {
  .tc-badge-group--dual { padding: 8px; gap: 4px; }
  .tc-badge-group--dual .tc-sale-badge,
  .tc-badge-group--dual .tc-best-badge {
    font-size: 0.7rem;
    padding: 3px 7px;
    border-width: 2px;
    box-shadow: 2px 2px 0 var(--pc-text, #2B1B12);
    letter-spacing: 0.02em;
  }
}
{% endstylesheet %}
