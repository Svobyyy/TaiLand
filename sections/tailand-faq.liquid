{%- liquid
  assign tfq_plain     = section.settings.heading_plain | default: "Questions? We've"
  assign tfq_highlight = section.settings.heading_highlighted | default: 'Got Answers'
  assign tfq_sub       = section.settings.subheading
-%}

{% style %}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg_color }};
  }
{% endstyle %}

<section class="tfq-section">
  <div class="tfq-container">

    {%- if tfq_plain != blank or tfq_highlight != blank -%}
      <div class="tfq-header">
        <h2 class="tfq-heading">
          {%- if tfq_plain != blank -%}
            <span class="tfq-heading__plain">{{ tfq_plain | escape }}&nbsp;</span>
          {%- endif -%}
          {%- if tfq_highlight != blank -%}
            <span class="tfq-heading__highlight">
              {{- tfq_highlight | escape -}}
              <svg class="tfq-heading__underline" viewBox="0 0 300 14" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                <path d="M4 10 C40 5 80 12 140 7 C200 2 240 11 296 8" stroke="currentColor" stroke-width="6" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          {%- endif -%}
        </h2>
        {%- if tfq_sub != blank -%}
          <p class="tfq-subheading">{{ tfq_sub | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="tfq-list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'faq_item' -%}
            <details class="tfq-item" {{ block.shopify_attributes }}>
              <summary class="tfq-summary">
                <span class="tfq-question">{{ block.settings.question | escape }}</span>
                <span class="tfq-icon" aria-hidden="true">
                  <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                    <polyline points="4,7 10,13 16,7"/>
                  </svg>
                </span>
              </summary>
              <div class="tfq-body">
                <div class="tfq-body-inner">
                  <p class="tfq-answer">{{ block.settings.answer | escape }}</p>
                </div>
              </div>
            </details>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% stylesheet %}
/* ---- Tailand FAQ ---- */

.tfq-section {
  overflow: visible;
}

.tfq-container {
  max-width: 760px;
  margin: 0 auto;
  padding-inline: var(--page-margin, 16px);
}

/* Heading */
.tfq-header {
  text-align: center;
  margin-bottom: 44px;
}

.tfq-heading {
  font-family: 'Fredoka', sans-serif;
  font-size: clamp(2rem, 4.5vw, 3rem);
  font-weight: 600;
  color: var(--pc-text, #2B1B12);
  line-height: 1.3;
  margin: 0;
}

.tfq-heading__plain {
  font-weight: 400;
}

.tfq-heading__highlight {
  display: inline-block;
  position: relative;
  font-weight: 700;
  white-space: nowrap;
  padding-bottom: 8px;
}

.tfq-heading__underline {
  position: absolute;
  left: -3%;
  bottom: -2px;
  width: 106%;
  height: 12px;
  color: var(--pc-green, #4F8A2F);
  pointer-events: none;
  display: block;
}

.tfq-subheading {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 1.05rem;
  font-weight: 600;
  color: var(--pc-text, #2B1B12);
  opacity: 0.65;
  margin: 18px 0 0;
  line-height: 1.5;
}

/* FAQ list */
.tfq-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

/* FAQ item */
.tfq-item {
  background: var(--pc-cream, #fffbf0);
  border: 2.5px solid var(--pc-text, #2B1B12);
  border-radius: 16px;
  overflow: hidden;
  transition: box-shadow 0.2s ease;
}

.tfq-item[open] {
  box-shadow: 5px 5px 0 var(--pc-text, #2B1B12);
}

/* Summary row */
.tfq-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 20px 24px;
  cursor: pointer;
  list-style: none;
  user-select: none;
}

.tfq-summary::-webkit-details-marker { display: none; }
.tfq-summary::marker { display: none; }

.tfq-summary:focus-visible {
  outline: 2px solid var(--pc-orange, #EE7B28);
  outline-offset: -2px;
  border-radius: 14px;
}

/* Question text */
.tfq-question {
  font-family: 'Fredoka', sans-serif;
  font-size: 1.15rem;
  font-weight: 700;
  color: var(--pc-text, #2B1B12);
  line-height: 1.3;
  flex: 1;
  min-width: 0;
  transition: color 0.15s ease;
}

.tfq-summary:hover .tfq-question {
  color: var(--pc-orange, #EE7B28);
}

/* Chevron — bare orange SVG, no box, matching product page style */
.tfq-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 20px;
  height: 20px;
  color: var(--pc-orange, #EE7B28);
}

.tfq-icon svg {
  width: 20px;
  height: 20px;
  display: block;
  transition: transform 0.25s ease;
}

.tfq-item[open] .tfq-icon svg {
  transform: rotate(180deg);
}

/* CSS grid height animation — 0fr → 1fr, no JS needed */
.tfq-body {
  display: grid;
  grid-template-rows: 0fr;
  transition: grid-template-rows 0.28s ease;
}

.tfq-item[open] > .tfq-body {
  grid-template-rows: 1fr;
}

.tfq-body-inner {
  overflow: hidden;
}

.tfq-answer {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 1.02rem;
  font-weight: 600;
  color: var(--pc-text, #2B1B12);
  opacity: 0.85;
  line-height: 1.75;
  margin: 0;
  padding: 4px 24px 22px;
  border-top: 1.5px solid rgba(43, 27, 18, 0.12);
}

/* Mobile */
@media screen and (max-width: 749px) {
  .tfq-header {
    margin-bottom: 32px;
  }
  .tfq-summary {
    padding: 18px 20px;
    gap: 12px;
  }
  .tfq-question {
    font-size: 1.05rem;
  }
  .tfq-answer {
    font-size: 0.95rem;
    padding: 4px 20px 20px;
  }
}

@media screen and (max-width: 479px) {
  .tfq-question {
    font-size: 1rem;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "FAQ",
  "settings": [
    {
      "type": "text",
      "id": "heading_plain",
      "label": "Heading — plain text",
      "default": "Questions? We've"
    },
    {
      "type": "text",
      "id": "heading_highlighted",
      "label": "Heading — highlighted text",
      "default": "Got Answers"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading (optional)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How long does shipping take?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Most orders are processed within 1–3 business days and you will receive tracking details as soon as your order ships."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
