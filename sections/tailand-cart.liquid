<script src="{{ 'component-cart-items.js' | asset_url }}" type="module" fetchpriority="low"></script>
<script src="{{ 'component-cart-quantity-selector.js' | asset_url }}" type="module" fetchpriority="low"></script>

{%- capture tc_empty_html -%}
<div class="tc-page tc-page--empty">
  <div class="tc-empty">
    <div class="tc-empty__inner">
      <div class="tc-empty__icon" aria-hidden="true">
        <svg width="72" height="72" viewBox="0 0 24 24" fill="none" stroke="#5BB870" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
      </div>
      <h1 class="tc-empty__heading">Your cart is <span class="tc-hi">empty</span></h1>
      <p class="tc-empty__text">Your cart is waiting for some pawsome picks.</p>
      <a href="/collections/best-sellers" class="tc-btn tc-btn--green">Shop Best Sellers</a>
      <div class="tc-empty__links">
        <a href="/collections/dogs" class="tc-empty__link">Dogs</a>
        <span class="tc-empty__sep" aria-hidden="true">·</span>
        <a href="/collections/cats" class="tc-empty__link">Cats</a>
      </div>
    </div>
  </div>
</div>
{%- endcapture -%}

{%- capture tc_children -%}

<template id="empty-cart-template">
  {{ tc_empty_html }}
</template>

{%- if cart.empty? -%}
  {{ tc_empty_html }}
{%- else -%}

<div class="tc-page">
  <div class="tc-layout">

    <h1 class="tc-heading">
      Your&nbsp;<span class="tc-heading__hi">
        Cart
        <svg class="tc-heading__underline" viewBox="0 0 200 12" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
          <path d="M2 8 C30 3 70 10 100 6 C130 2 165 9 198 6" stroke="currentColor" stroke-width="5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
      <span class="tc-heading__count">({{ cart.item_count }})</span>
    </h1>

    <div class="tc-layout__body">

      <!-- ── Items ─────────────────────────────────────────── -->
      <div class="tc-items">
        <form
          action="{{ routes.cart_url }}"
          class="cart-form"
          id="cart-form"
          method="post"
        >
          <input type="hidden" name="utf8" value="✓">
          <span class="visually-hidden" ref="cartItemCount" aria-hidden="true">{{ cart.item_count }}</span>

          {%- for item in cart.items -%}
            <div
              class="tc-card"
              id="CartItem-{{ item.key }}"
              ref="cartItemRows[]"
              data-parent-key="{{ item.parent_relationship.parent.key }}"
              data-key="{{ item.key }}"
            >
              <!-- image -->
              {%- if item.image -%}
                <a href="{{ item.url }}" class="tc-card__img-wrap" tabindex="-1" aria-hidden="true">
                  {{ item.image | image_url: width: 320 | image_tag: class: 'tc-card__img', loading: 'lazy', alt: item.title }}
                </a>
              {%- else -%}
                <div class="tc-card__img-wrap tc-card__img-wrap--placeholder"></div>
              {%- endif -%}

              <!-- body -->
              <div class="tc-card__body">
                <div class="tc-card__top">
                  <a href="{{ item.url }}" class="tc-card__title">{{ item.product.title }}</a>
                  <span class="tc-card__price">
                    <text-component value="{{ item.final_line_price | money | strip_html }}">
                      {{- item.final_line_price | money -}}
                    </text-component>
                  </span>
                </div>

                {%- unless item.product.has_only_default_variant -%}
                  <p class="tc-card__variant">
                    {%- for opt in item.options_with_values -%}
                      {{- opt.value -}}{%- unless forloop.last -%}&nbsp;·&nbsp;{%- endunless -%}
                    {%- endfor -%}
                  </p>
                {%- endunless -%}

                {%- if item.selling_plan_allocation -%}
                  <p class="tc-card__variant">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                {%- endif -%}

                <!-- controls -->
                <div class="tc-card__foot">
                  {%- assign can_update_quantity = item.instructions.can_update_quantity | default: true, allow_false: true -%}
                  {% render 'quantity-selector',
                    product: item.product,
                    variant: item.variant,
                    in_cart_quantity: item.quantity,
                    line_index: item.index,
                    can_update_quantity: can_update_quantity
                  %}

                  {%- assign can_remove = item.instructions.can_remove | default: true, allow_false: true -%}
                  {%- unless can_remove == false -%}
                    <button
                      class="button tc-card__remove"
                      type="button"
                      aria-label="{{ 'accessibility.remove_item' | t: title: item.title | escape }}"
                      on:click="/onLineItemRemove/{{ item.index | plus: 1 }}"
                    >
                      {{- 'icon-delete.svg' | inline_asset_content -}}
                      <span class="visually-hidden">{{ 'accessibility.remove' | t }}</span>
                    </button>
                  {%- endunless -%}
                </div>

                <div class="tc-card__error hidden" ref="cartItemErrorContainer-{{ item.index | plus: 1 }}">
                  <small class="cart-item__error-text" ref="cartItemError-{{ item.index | plus: 1 }}"></small>
                </div>
              </div>
            </div>
          {%- endfor -%}
        </form>
        {%- render 'cart-fbt', fbt_limit: 4, fbt_mode: 'page' -%}
      </div>

      <!-- ── Summary ────────────────────────────────────────── -->
      <aside class="tc-summary">
        <div class="tc-summary__card">
          <h2 class="tc-summary__title">Order Summary</h2>

          {%- if cart.cart_level_discount_applications.size > 0 -%}
            <div class="tc-summary__discounts">
              {%- for d in cart.cart_level_discount_applications -%}
                <div class="tc-summary__disc-row">
                  <span>{{ d.title }}</span>
                  <span>-{{ d.total_allocated_amount | money }}</span>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}

          <div class="tc-summary__subtotal">
            <span class="tc-summary__subtotal-label">Subtotal</span>
            <span class="tc-summary__subtotal-val">
              <text-component ref="cartTotal" data-cart-subtotal value="{{ cart.total_price | money | strip_html }}">
                {%- if settings.currency_code_enabled_cart_total -%}
                  {{ cart.total_price | money_with_currency }}
                {%- else -%}
                  {{ cart.total_price | money }}
                {%- endif -%}
              </text-component>
            </span>
          </div>

          <p class="tc-summary__ship">Shipping &amp; taxes calculated at checkout</p>

          <button
            class="tc-btn tc-btn--green"
            type="submit"
            name="checkout"
            form="cart-form"
          >
            Checkout
          </button>

          <a href="{{ routes.all_products_collection_url }}" class="tc-summary__continue">
            Continue Shopping
          </a>

          <div class="tc-trust">
            <div class="tc-trust__item">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <span>Secure Checkout</span>
            </div>
            <div class="tc-trust__item">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
              <span>Easy Returns</span>
            </div>
            <div class="tc-trust__item">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              <span>Track Your Order</span>
            </div>
            <div class="tc-trust__item">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              <span>Pet-Friendly Picks</span>
            </div>
          </div>
        </div>
      </aside>

    </div>
  </div>
</div>

{%- endif -%}

{%- endcapture -%}
{% render 'cart-items-component', children: tc_children, section_id: section.id %}

{% stylesheet %}

/* ── Page ──────────────────────────────────────────────────────── */
.tc-section-outer {
  background: var(--pc-cream, #F7DFB8);
}

.tc-page { min-height: 60vh; }

.tc-layout {
  max-width: 1200px;
  margin: 0 auto;
  padding: 2.5rem 1.25rem 4rem;
}

/* ── Heading ──────────────────────────────────────────────────── */
.tc-heading {
  font-family: 'Fredoka', sans-serif;
  font-size: clamp(2rem, 5vw, 2.75rem);
  font-weight: 700;
  color: var(--pc-text, #2B1B12);
  margin: 0 0 2rem;
  line-height: 1.2;
}

.tc-heading__hi {
  display: inline-block;
  position: relative;
  color: var(--pc-green, #4F8A2F);
  padding-bottom: 6px;
}

.tc-heading__underline {
  position: absolute;
  left: -3%;
  bottom: -2px;
  width: 106%;
  height: 10px;
  color: var(--pc-green, #4F8A2F);
  pointer-events: none;
  display: block;
}

.tc-heading__count {
  font-size: 0.6em;
  color: #7A5C45;
  font-weight: 400;
  vertical-align: middle;
  margin-left: 4px;
}

/* ── Layout ───────────────────────────────────────────────────── */
.tc-layout__body {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.75rem;
  align-items: start;
}

@media screen and (min-width: 900px) {
  .tc-layout__body { grid-template-columns: 1fr 380px; gap: 2.5rem; }
  .tc-summary { position: sticky; top: 1.5rem; }
}

/* ── Item cards ───────────────────────────────────────────────── */
.tc-card {
  display: flex;
  gap: 1.25rem;
  background: #FFF4D9;
  border: 3px solid var(--pc-text, #2B1B12);
  border-radius: 20px;
  box-shadow: 6px 8px 0 rgba(43, 27, 18, 0.82);
  padding: 1rem 1.25rem 1rem 1rem;
  margin-bottom: 1.25rem;
  transition: transform 0.12s ease, box-shadow 0.12s ease;
}

.tc-card:hover {
  transform: translate(2px, 3px);
  box-shadow: 4px 5px 0 rgba(43, 27, 18, 0.82);
}

.tc-card.removing {
  animation: tc-remove var(--animation-speed, 300ms) ease forwards;
  pointer-events: none;
  opacity: 0.5;
  overflow: hidden;
}

@keyframes tc-remove {
  to { opacity: 0; transform: translateX(24px); }
}

.tc-card__img-wrap {
  flex-shrink: 0;
  width: clamp(100px, 26vw, 140px);
  height: clamp(100px, 26vw, 140px);
  border: 2px solid var(--pc-text, #2B1B12);
  border-radius: 14px;
  overflow: hidden;
  background: #fff;
  display: block;
}

.tc-card__img-wrap--placeholder { background: #f0e8d0; }

.tc-card__img { width: 100%; height: 100%; object-fit: cover; display: block; }

.tc-card__body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}

.tc-card__top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 0.75rem;
}

.tc-card__title {
  font-family: 'Fredoka', sans-serif;
  font-size: 1.15rem;
  font-weight: 700;
  color: var(--pc-text, #2B1B12);
  text-decoration: none;
  line-height: 1.25;
  flex: 1;
  min-width: 0;
  overflow-wrap: break-word;
  transition: color 0.15s ease;
}

.tc-card__title:hover { color: var(--pc-orange, #EE7B28); }

.tc-card__price {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 1.2rem;
  font-weight: 800;
  color: var(--pc-text, #2B1B12);
  white-space: nowrap;
  flex-shrink: 0;
}

.tc-card__variant {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.82rem;
  color: #7A5C45;
  margin: 0;
  line-height: 1.4;
}

.tc-card__foot {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-top: auto;
  padding-top: 0.625rem;
  flex-wrap: wrap;
}

.tc-card__error { font-size: 0.8rem; color: #c0392b; margin-top: 0.25rem; }
.tc-card__error.hidden { display: none; }

/* ── Quantity selector ────────────────────────────────────────── */
.tc-items .quantity-selector {
  background: #fff;
  border: 2.5px solid var(--pc-text, #2B1B12);
  border-radius: 999px;
  box-shadow: 3px 3px 0 var(--pc-text, #2B1B12);
  overflow: hidden;
  display: inline-flex;
  align-items: center;
  height: 2.4rem;
  min-width: 7.5rem;
  padding: 0;
  gap: 0;
}

.tc-items .quantity-minus,
.tc-items .quantity-plus {
  background: transparent;
  border: none;
  color: var(--pc-text, #2B1B12);
  width: 2.4rem;
  height: 2.4rem;
  min-width: 2.4rem;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  box-shadow: none;
  padding: 0;
  transition: background 0.15s ease, color 0.15s ease;
}

.tc-items .quantity-minus:hover,
.tc-items .quantity-plus:hover {
  background: var(--pc-orange, #EE7B28);
  color: #fff;
}

.tc-items .quantity-minus svg,
.tc-items .quantity-plus svg { width: 0.85rem; height: 0.85rem; }

.tc-items .quantity-selector input[type="number"] {
  background: transparent;
  border: none;
  text-align: center;
  color: var(--pc-text, #2B1B12);
  font-family: 'Fredoka', sans-serif;
  font-weight: 600;
  font-size: 1.05rem;
  flex: 1;
  min-width: 0;
  width: 2rem;
  padding: 0;
  height: 100%;
  box-shadow: none;
  outline: none;
  -moz-appearance: textfield;
  appearance: textfield;
}

.tc-items .quantity-selector input[type="number"]::-webkit-inner-spin-button,
.tc-items .quantity-selector input[type="number"]::-webkit-outer-spin-button {
  -webkit-appearance: none;
  margin: 0;
}

/* ── Remove button ────────────────────────────────────────────── */
.tc-card__remove {
  background: #fff;
  border: 2.5px solid var(--pc-text, #2B1B12);
  border-radius: 50%;
  width: 2.4rem;
  height: 2.4rem;
  min-width: 2.4rem;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--pc-text, #2B1B12);
  box-shadow: 3px 3px 0 var(--pc-text, #2B1B12);
  padding: 0;
  cursor: pointer;
  transition: background 0.15s ease, color 0.15s ease, transform 0.12s ease, box-shadow 0.12s ease;
}

.tc-card__remove:hover {
  background: var(--pc-orange, #EE7B28);
  color: #fff;
  transform: translate(1px, 1px);
  box-shadow: 2px 2px 0 var(--pc-text, #2B1B12);
}

.tc-card__remove svg { width: 0.9rem; height: 0.9rem; flex-shrink: 0; }

/* ── Summary card ─────────────────────────────────────────────── */
.tc-summary__card {
  background: #FFF4D9;
  border: 3px solid var(--pc-text, #2B1B12);
  border-radius: 20px;
  box-shadow: 6px 8px 0 rgba(43, 27, 18, 0.82);
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.tc-summary__title {
  font-family: 'Fredoka', sans-serif;
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--pc-text, #2B1B12);
  margin: 0;
}

.tc-summary__discounts {
  border-top: 1.5px solid rgba(43,27,18,0.15);
  padding-top: 0.75rem;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.tc-summary__disc-row {
  display: flex;
  justify-content: space-between;
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.9rem;
  color: var(--pc-green, #4F8A2F);
  font-weight: 700;
}

.tc-summary__subtotal {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 2.5px solid var(--pc-text, #2B1B12);
  padding-top: 1rem;
}

.tc-summary__subtotal-label {
  font-family: 'Fredoka', sans-serif;
  font-size: 1.15rem;
  font-weight: 600;
  color: var(--pc-text, #2B1B12);
}

.tc-summary__subtotal-val {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 1.35rem;
  font-weight: 800;
  color: var(--pc-text, #2B1B12);
}

.tc-summary__ship {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.82rem;
  color: #7A5C45;
  margin: 0;
  text-align: center;
  line-height: 1.4;
}

/* ── Checkout button ──────────────────────────────────────────── */
.tc-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  border-radius: 999px;
  font-family: 'Nunito Sans', sans-serif;
  font-size: 1.05rem;
  font-weight: 800;
  padding: 0.875rem 1.5rem;
  text-decoration: none;
  cursor: pointer;
  transition: background 0.15s ease, transform 0.1s ease, box-shadow 0.1s ease;
}

.tc-btn--green {
  background: var(--pc-green, #4F8A2F);
  color: #fff;
  border: 2.5px solid var(--pc-text, #2B1B12);
  box-shadow: 4px 4px 0 var(--pc-text, #2B1B12);
}

.tc-btn--green:hover {
  background: var(--pc-green-dark, #3E6F25);
  transform: translate(2px, 2px);
  box-shadow: 2px 2px 0 var(--pc-text, #2B1B12);
  color: #fff;
}

.tc-summary__continue {
  display: block;
  text-align: center;
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.9rem;
  font-weight: 600;
  color: #7A5C45;
  text-decoration: underline;
  text-underline-offset: 3px;
  transition: color 0.15s ease;
}

.tc-summary__continue:hover { color: var(--pc-text, #2B1B12); }

/* ── Trust badges ─────────────────────────────────────────────── */
.tc-trust {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.6rem;
  border-top: 1.5px solid rgba(43,27,18,0.15);
  padding-top: 1rem;
}

.tc-trust__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 0.35rem;
  background: #fff;
  border: 2px solid var(--pc-text, #2B1B12);
  border-radius: 14px;
  box-shadow: 3px 3px 0 rgba(43, 27, 18, 0.55);
  padding: 0.625rem 0.5rem;
  font-family: 'Fredoka', sans-serif;
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--pc-text, #2B1B12);
  line-height: 1.2;
}

.tc-trust__item svg { color: var(--pc-orange, #EE7B28); }

/* ── Empty state ──────────────────────────────────────────────── */
.tc-page--empty {
  min-height: 70vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tc-empty {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 3rem 1.25rem;
}

.tc-empty__inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 1.25rem;
  max-width: 440px;
}

.tc-empty__icon svg { display: block; }

.tc-empty__heading {
  font-family: 'Fredoka', sans-serif;
  font-size: clamp(2rem, 5vw, 2.75rem);
  font-weight: 700;
  color: var(--pc-text, #2B1B12);
  margin: 0;
  line-height: 1.15;
}

.tc-hi {
  color: var(--pc-green, #4F8A2F);
  text-decoration: underline;
  text-decoration-color: var(--pc-green, #4F8A2F);
  text-underline-offset: 5px;
  text-decoration-thickness: 3px;
}

.tc-empty__text {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 1.05rem;
  color: #7A5C45;
  margin: 0;
  line-height: 1.5;
}

.tc-empty__links {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-wrap: wrap;
  justify-content: center;
}

.tc-empty__link {
  font-family: 'Fredoka', sans-serif;
  font-size: 1rem;
  color: var(--pc-text, #2B1B12);
  text-decoration: underline;
  text-underline-offset: 3px;
  transition: color 0.15s ease;
}

.tc-empty__link:hover { color: var(--pc-orange, #EE7B28); }
.tc-empty__sep { color: #7A5C45; }

{% endstylesheet %}

{% schema %}
{
  "name": "Tailand Cart",
  "tag": "div",
  "class": "tc-section-outer",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    { "type": "header", "content": "Frequently Bought Together" },
    { "type": "checkbox", "id": "show_fbt", "label": "Enable Frequently Bought Together", "default": true },
    { "type": "header", "content": "Default Products (shown when no category matches)" },
    { "type": "product", "id": "fbt_default_1", "label": "Default product 1" },
    { "type": "product", "id": "fbt_default_2", "label": "Default product 2" },
    { "type": "product", "id": "fbt_default_3", "label": "Default product 3" },
    { "type": "header", "content": "Grooming Products (grooming_upsell tag)" },
    { "type": "product", "id": "fbt_grooming_1", "label": "Grooming product 1" },
