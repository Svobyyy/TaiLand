{%- liquid
  assign tc_heading_plain    = section.settings.heading_plain
  assign tc_heading_hi       = section.settings.heading_highlighted
  assign tc_show_desc        = section.settings.show_description
  assign tc_show_tabs        = section.settings.show_tabs
  assign tc_show_sort        = section.settings.show_sort
  assign tc_show_badges      = section.settings.show_badges
  assign tc_show_best        = section.settings.show_best_seller_badge
  assign tc_best_text        = section.settings.best_seller_badge_text | default: 'Best Seller'
  assign tc_btn              = section.settings.card_btn_text | default: 'Shop Now'
  assign tc_per_page         = section.settings.products_per_page | default: 16
  assign tc_highlight        = tc_heading_hi | default: collection.title
  assign tc_menu_handle      = section.settings.nav_menu | default: 'main-menu'
  assign tc_linklist         = linklists[tc_menu_handle]
-%}

{% style %}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: var(--pc-white, #fff);
  }
{% endstyle %}

<div class="tc-section">
  <div class="tc-container" id="tc-page-region" data-tc-section="{{ section.id }}">

    <!-- ── Hero header ── -->
    <div class="tc-hero">
      <h1 class="tc-hero__heading">
        {%- if tc_heading_plain != blank -%}
          <span class="tc-hero__plain">{{ tc_heading_plain | escape }}&nbsp;</span>
        {%- endif -%}
        {%- if tc_highlight != blank -%}
          <span class="tc-hero__highlight">
            {{- tc_highlight | escape -}}
            <svg class="tc-hero__underline" viewBox="0 0 300 14" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
              <path d="M4 10 C40 5 80 12 140 7 C200 2 240 11 296 8" stroke="currentColor" stroke-width="6" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        {%- endif -%}
      </h1>
      {%- if tc_show_desc and collection.description != blank -%}
        <div class="tc-hero__desc">{{ collection.description }}</div>
      {%- endif -%}
    </div>

    <!-- ── Category tabs — All Products hardcoded first, then nav menu ── -->
    {%- if tc_show_tabs -%}
      {%- assign tc_all_active = false -%}
      {%- if collection.handle == 'all' -%}{%- assign tc_all_active = true -%}{%- endif -%}
      <nav class="tc-tabs" aria-label="Browse by category">
        <a
          href="/collections/all"
          class="tc-tab{%- if tc_all_active %} tc-tab--active{%- endif %}"
          {%- if tc_all_active %} aria-current="page"{%- endif %}
        >
          <span class="tc-tab__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
          </span>
          <span class="tc-tab__label">All Products</span>
        </a>
        {%- for link in tc_linklist.links -%}
          {%- comment %} Category tabs are collections only — skip pages, blogs, external links etc. {%- endcomment -%}
          {%- unless link.type == 'collection_link' -%}{%- continue -%}{%- endunless -%}
          {%- comment %} Extract collection handle from /collections/{handle} URL {%- endcomment -%}
          {%- assign tc_lh = link.url | split: '/collections/' | last | split: '?' | first | split: '/' | first -%}
          {%- assign tc_active = false -%}
          {%- if collection.handle == tc_lh -%}{%- assign tc_active = true -%}{%- endif -%}
          <a
            href="{{ link.url }}"
            class="tc-tab{%- if tc_active %} tc-tab--active{%- endif %}"
            {%- if tc_active %} aria-current="page"{%- endif %}
          >
            <span class="tc-tab__icon" aria-hidden="true">
              {%- case tc_lh -%}
                {%- when 'best-sellers', 'best_sellers' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {%- when 'dogs' -%}
                  {% render 'icon-dog', width: 20, height: 20 %}
                {%- when 'cats' -%}
                  {% render 'icon-cat', width: 20, height: 20 %}
                {%- when 'sale' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2H2v10l10 10 10-10L12 2z"/><circle cx="7" cy="7" r="1.5" fill="currentColor" stroke="none"/></svg>
                {%- when 'summer' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
                {%- else -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><ellipse cx="6.5" cy="9" rx="2" ry="2.5"/><ellipse cx="10" cy="6.5" rx="2" ry="2.5"/><ellipse cx="14" cy="6.5" rx="2" ry="2.5"/><ellipse cx="17.5" cy="9" rx="2" ry="2.5"/><path d="M12 22.5C8.5 22.5 5.5 20.5 5.5 17.5C5.5 14.5 7.5 12.5 12 12.5C16.5 12.5 18.5 14.5 18.5 17.5C18.5 20.5 15.5 22.5 12 22.5Z"/></svg>
              {%- endcase -%}
            </span>
            <span class="tc-tab__label">{{ link.title | escape }}</span>
          </a>
        {%- endfor -%}
      </nav>
    {%- endif -%}
    {%- comment -%}Show tabs even when menu has no links (All Products always shows){%- endcomment -%}

    <!-- ── Sort + count toolbar ── -->
    {%- if tc_show_sort -%}
      <div class="tc-toolbar">
        <span class="tc-toolbar__count">
          <svg class="tc-toolbar__count-paw" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><ellipse cx="12" cy="17" rx="5.5" ry="5"/><ellipse cx="5.5" cy="11.5" rx="2.2" ry="3"/><ellipse cx="18.5" cy="11.5" rx="2.2" ry="3"/><ellipse cx="9" cy="7.5" rx="2" ry="2.8"/><ellipse cx="15" cy="7.5" rx="2" ry="2.8"/></svg>
          {{ collection.products_count }}
          {%- if collection.products_count == 1 %} product{%- else %} products{%- endif %}
        </span>
        <form method="get" action="{{ collection.url }}" class="tc-sort-form">
          <label for="tc-sort-{{ section.id }}" class="tc-sort__label">Sort by</label>
          <div class="tc-sort__wrap">
            <select id="tc-sort-{{ section.id }}" name="sort_by" class="tc-sort__select">
              <option value="manual"{%- if collection.sort_by == 'manual' %} selected{%- endif %}>Featured</option>
              <option value="best-selling"{%- if collection.sort_by == 'best-selling' %} selected{%- endif %}>Best Selling</option>
              <option value="title-ascending"{%- if collection.sort_by == 'title-ascending' %} selected{%- endif %}>A–Z</option>
              <option value="title-descending"{%- if collection.sort_by == 'title-descending' %} selected{%- endif %}>Z–A</option>
              <option value="price-ascending"{%- if collection.sort_by == 'price-ascending' %} selected{%- endif %}>Price: Low → High</option>
              <option value="price-descending"{%- if collection.sort_by == 'price-descending' %} selected{%- endif %}>Price: High → Low</option>
              <option value="created-descending"{%- if collection.sort_by == 'created-descending' %} selected{%- endif %}>Newest First</option>
            </select>
            <span class="tc-sort__arrow" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </span>
          </div>
          <noscript><button type="submit" class="tc-sort__go">Go</button></noscript>
        </form>
      </div>
    {%- endif -%}

    <!-- ── Product grid ── -->
    {%- paginate collection.products by tc_per_page -%}

      {%- if collection.products_count == 0 -%}

        <!-- Empty state -->
        <div class="tc-empty">
          <div class="tc-empty__paw" aria-hidden="true">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="currentColor">
              <ellipse cx="12" cy="17" rx="5.5" ry="5"/>
              <ellipse cx="5.5" cy="11.5" rx="2.2" ry="3"/>
              <ellipse cx="18.5" cy="11.5" rx="2.2" ry="3"/>
              <ellipse cx="9" cy="7.5" rx="2" ry="2.8"/>
              <ellipse cx="15" cy="7.5" rx="2" ry="2.8"/>
            </svg>
          </div>
          <h2 class="tc-empty__heading">No products found here yet.</h2>
          <a href="/collections/all" class="tc-empty__btn">Browse All Products</a>
        </div>

      {%- else -%}

        <ul class="tc-grid" role="list">
          {%- for product in collection.products -%}
            {% render 'tailand-product-card', product: product, tc_show_badges: tc_show_badges, tc_show_best: tc_show_best, tc_best_text: tc_best_text, tc_btn: tc_btn, eager: forloop.first %}
          {%- endfor -%}
        </ul>

        <!-- Pagination -->
        {%- if paginate.pages > 1 -%}
          <nav class="tc-pagination" aria-label="Pagination">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="tc-pagination__btn">&#8592; Previous</a>
            {%- endif -%}
            <span class="tc-pagination__info">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="tc-pagination__btn">Next &#8594;</a>
            {%- endif -%}
          </nav>
        {%- endif -%}

      {%- endif -%}
    {%- endpaginate -%}

  </div>
</div>

{% render 'tailand-grid-styles' %}

{% stylesheet %}
/* =========================================================
   Tailand Collection Page — tc-* (collection-exclusive rules only;
   shared card/hero/tabs/grid/empty-state CSS lives in
   snippets/tailand-grid-styles.liquid, rendered above)
   ========================================================= */

/* AJAX loading state — tied to this section's own script, not shared with search */
#tc-page-region { transition: opacity 0.2s ease; }
#tc-page-region.tc-loading { opacity: 0.5; pointer-events: none; }
{% endstylesheet %}

<script>
(function () {
  var pageRegion = document.getElementById('tc-page-region');
  if (!pageRegion) return;

  var sectionId = pageRegion.dataset.tcSection;
  if (!sectionId) return;

  // Prevent duplicate listeners if the section script runs more than once
  // (Theme Editor re-renders, section hydration).
  if (pageRegion.dataset.tcListening === '1') return;
  pageRegion.dataset.tcListening = '1';

  var currentCtrl = null;

  // Close mobile header drawer using the component's public API
  function closeMenu() {
    var headerDrawer = document.querySelector('header-drawer');
    if (headerDrawer && typeof headerDrawer.close === 'function') headerDrawer.close();
  }

  function fetchPage(url, opts) {
    var scrollY = (opts && opts.scrollY) || 0;
    var push    = !opts || opts.push !== false;

    if (currentCtrl) currentCtrl.abort();
    var ctrl = new AbortController();
    currentCtrl = ctrl;
    pageRegion.classList.add('tc-loading');

    var tid = setTimeout(function () { ctrl.abort(); }, 12000);

    fetch(url + (url.includes('?') ? '&' : '?') + 'sections=' + sectionId, { signal: ctrl.signal })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        clearTimeout(tid);
        if (ctrl !== currentCtrl) return;
        currentCtrl = null;

        var html = data[sectionId];
        if (!html) return restore();

        var doc = new DOMParser().parseFromString(html, 'text/html');
        var newRegion = doc.getElementById('tc-page-region');
        if (!newRegion) return restore();

        pageRegion.innerHTML = newRegion.innerHTML;

        if (push) history.pushState({ tcAjax: true, url: url }, '', url);
        pageRegion.classList.remove('tc-loading');
        window.scrollTo({ top: scrollY, behavior: scrollY ? 'instant' : 'smooth' });
      })
      .catch(function (err) {
        clearTimeout(tid);
        if (err.name === 'AbortError' && ctrl !== currentCtrl) return;
        currentCtrl = null;
        restore();
      });
  }

  function restore() {
    pageRegion.classList.remove('tc-loading');
  }

  function saveScrollY() {
    history.replaceState(
      Object.assign({ tcAjax: true, url: location.pathname + location.search }, history.state || {}, { scrollY: window.scrollY }),
      ''
    );
  }

  // Document-level delegation handles tabs, drawer links, and pagination
  // even after innerHTML is replaced (no rebinding needed)
  document.addEventListener('click', function (e) {
    if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;

    var tab = e.target.closest('.tc-tab');
    if (tab && tab.href) {
      e.preventDefault();
      saveScrollY();
      var sort = new URLSearchParams(location.search).get('sort_by');
      fetchPage(tab.href + (sort ? '?sort_by=' + sort : ''), { scrollY: 0, push: true });
      return;
    }

    // Header links (mobile drawer, desktop nav, mobile nav bar) — only on collection pages
    var headerLink = e.target.closest('.pc-drawer-item, .menu-list__link, .menu-list__item');
    if (headerLink && headerLink.href && headerLink.href.includes('/collections/')) {
      if (!document.getElementById('tc-page-region')) return;
      e.preventDefault();
      if (headerLink.classList.contains('pc-drawer-item')) closeMenu();
      saveScrollY();
      fetchPage(headerLink.href, { scrollY: 0, push: true });
      return;
    }

    var pageBtn = e.target.closest('.tc-pagination__btn');
    if (pageBtn && pageBtn.href) {
      e.preventDefault();
      saveScrollY();
      fetchPage(pageBtn.href, { scrollY: 0, push: true });
    }
  });

  document.addEventListener('change', function (e) {
    if (!e.target.matches('.tc-sort__select')) return;
    saveScrollY();
    fetchPage(location.pathname + '?sort_by=' + e.target.value, { scrollY: 0, push: true });
  });

  window.addEventListener('popstate', function (e) {
    if (!e.state || !e.state.tcAjax) return;
    fetchPage(location.pathname + location.search, { scrollY: e.state.scrollY || 0, push: false });
  });
})();
</script>

{% schema %}
{
  "name": "Tailand Collection",
  "tag": "section",
  "class": "tailand-collection-section",
  "settings": [
    {
      "type": "header",
      "content": "Hero heading"
    },
    {
      "type": "text",
      "id": "heading_plain",
      "label": "Heading — plain text",
      "default": "Shop"
    },
    {
      "type": "text",
      "id": "heading_highlighted",
      "label": "Heading — highlighted text (leave blank to use collection title)",
      "info": "Shown with the green underline. Leave empty to use the collection's own title."
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show collection description",
      "default": true
    },
    {
      "type": "header",
      "content": "Category tabs"
    },
    {
      "type": "checkbox",
      "id": "show_tabs",
      "label": "Show category tabs",
      "default": true
    },
    {
      "type": "link_list",
      "id": "nav_menu",
      "label": "Navigation menu",
      "default": "main-menu",
      "info": "Tabs are built automatically from this Shopify menu. Edit the menu in Online Store → Navigation to change tabs and order. Icons are matched by collection handle."
    },
    {
      "type": "header",
      "content": "Sort bar"
    },
    {
      "type": "checkbox",
      "id": "show_sort",
      "label": "Show sort + product count bar",
      "default": true
    },
    {
      "type": "header",
      "content": "Product cards"
    },
    {
      "type": "text",
      "id": "card_btn_text",
      "label": "Card button text",
      "default": "Shop Now"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 48,
      "step": 4,
      "label": "Products per page",
      "default": 16
    },
    {
      "type": "header",
      "content": "Badges"
    },
    {
      "type": "checkbox",
      "id": "show_badges",
      "label": "Show sale badge (ENDS SOON)",
      "default": true,
      "info": "Shown automatically on products with a compare-at price."
    },
    {
      "type": "checkbox",
      "id": "show_best_seller_badge",
      "label": "Show Best Seller badge on all products",
      "default": false,
      "info": "Turns on the orange badge for every product in this collection."
    },
    {
      "type": "text",
      "id": "best_seller_badge_text",
      "label": "Best Seller badge text",
      "default": "Best Seller"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Tailand Collection"
    }
  ]
}
{% endschema %}
