    { "type": "product", "id": "fbt_water_2", "label": "Water product 2" },
    { "type": "product", "id": "fbt_water_3", "label": "Water product 3" },
    { "type": "header", "content": "Toy Products (toy_upsell tag)" },
    { "type": "product", "id": "fbt_toy_1", "label": "Toy product 1" },
    { "type": "product", "id": "fbt_toy_2", "label": "Toy product 2" },
    { "type": "product", "id": "fbt_toy_3", "label": "Toy product 3" },
    { "type": "header", "content": "Cat Products (cat_upsell tag)" },
    { "type": "product", "id": "fbt_cat_1", "label": "Cat product 1" },
    { "type": "product", "id": "fbt_cat_2", "label": "Cat product 2" },
    { "type": "product", "id": "fbt_cat_3", "label": "Cat product 3" },
    { "type": "header", "content": "Dog Products (dog_upsell tag)" },
    { "type": "product", "id": "fbt_dog_1", "label": "Dog product 1" },
    { "type": "product", "id": "fbt_dog_2", "label": "Dog product 2" },
    { "type": "product", "id": "fbt_dog_3", "label": "Dog product 3" }
  ]
