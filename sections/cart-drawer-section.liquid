{% # SRA target for /cart endpoints. The Section Rendering API provides the section wrapper. %}
{% render 'cart-drawer', render_wrapper: false %}

{% schema %}
{
  "name": "t:names.cart_drawer",
  "settings": [
    { "type": "header", "content": "Frequently Bought Together" },
    { "type": "checkbox", "id": "show_fbt", "label": "Enable Frequently Bought Together", "default": true },
    { "type": "header", "content": "Default Products (shown when no category matches)" },
    { "type": "product", "id": "fbt_default_1", "label": "Default product 1" },
    { "type": "product", "id": "fbt_default_2", "label": "Default product 2" },
    { "type": "product", "id": "fbt_default_3", "label": "Default product 3" },
    { "type": "header", "content": "Grooming Products (grooming_upsell tag)" },
    { "type": "product", "id": "fbt_grooming_1", "label": "Grooming product 1" },
    { "type": "product", "id": "fbt_grooming_2", "label": "Grooming product 2" },
    { "type": "product", "id": "fbt_grooming_3", "label": "Grooming product 3" },
    { "type": "header", "content": "Feeder Products (feeder_upsell tag)" },
    { "type": "product", "id": "fbt_feeder_1", "label": "Feeder product 1" },
    { "type": "product", "id": "fbt_feeder_2", "label": "Feeder product 2" },
    { "type": "product", "id": "fbt_feeder_3", "label": "Feeder product 3" },
