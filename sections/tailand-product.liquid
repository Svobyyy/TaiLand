{% stylesheet %}
/* ============================================================
   TAILAND PRODUCT PAGE — tp-* prefix
   ============================================================ */

/* ---- Layout ---- */
.tp-wrap {
  max-width: 1280px;
  margin: 0 auto;
  padding: var(--tp-pt, 48px) 1.5rem 0;
}

.tp-main {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: start;
}

@media screen and (max-width: 899px) {
  .tp-main { grid-template-columns: 1fr; gap: 2rem; }
}

/* ============================================================
   GALLERY
   ============================================================ */

/* Sticky only on desktop.
   align-self: start is mandatory — without it the grid item stretches
   to the full column height and sticky never activates.
   top is set to 20px here as a safe fallback; JS overrides it at
   runtime with the actual rendered header height. */
@media screen and (min-width: 900px) {
  .tp-gallery {
    position: sticky;
    top: 20px;
    align-self: start;
    overflow: visible; /* never clip box-shadow of child elements */
  }
}

.tp-gallery__main {
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 20px;
  border: 2.5px solid var(--pc-text, #2d2d2d);
  box-shadow: 6px 6px 0 var(--pc-text, #2d2d2d);
  /* Do NOT use overflow:hidden or overflow:clip here —
     either can create an implicit scroll container that breaks
     position:sticky on the parent in certain Shopify theme wrappers.
     The image is kept away from corners via padding + object-fit:contain,
     so no clipping is needed for the border-radius to look correct. */
  overflow: visible;
  background: #FFF4D9;
  position: relative;
  padding: 1.25rem;
}

.tp-gallery__main-img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
  border-radius: 14px;
  transition: opacity 0.2s ease;
}
.tp-gallery__main-img.tp-fade { opacity: 0; }

.tp-gallery__badge {
  position: absolute;
  top: 14px;
  left: 14px;
  z-index: 2;
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: var(--pc-sale-red, #e8372b);
  color: #fff;
  font-family: 'Fredoka', sans-serif;
  font-size: 0.9rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  padding: 5px 14px;
  border-radius: 999px;
  border: 2px solid var(--pc-text, #2d2d2d);
  box-shadow: 2px 2px 0 var(--pc-text, #2d2d2d);
  text-transform: uppercase;
}

.tp-gallery__thumbs {
  display: flex;
  gap: 10px;
  margin-top: 14px;
  flex-wrap: wrap;
}

.tp-gallery__thumb {
  width: 72px;
  height: 72px;
  border-radius: 12px;
  border: 2.5px solid var(--pc-text, #2d2d2d);
  box-shadow: 3px 3px 0 var(--pc-text, #2d2d2d);
  overflow: hidden;
  background: #FFF4D9;
  cursor: pointer;
  padding: 0;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
  flex-shrink: 0;
}

.tp-gallery__thumb:hover,
.tp-gallery__thumb.tp-active {
  transform: translate(-2px, -2px);
  box-shadow: 5px 5px 0 var(--pc-text, #2d2d2d);
}

.tp-gallery__thumb.tp-active { border-color: var(--pc-orange, #f59f2b); }

.tp-gallery__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }

/* ============================================================
   INFO PANEL
   ============================================================ */
.tp-info { display: flex; flex-direction: column; gap: 1.125rem; }

/* Breadcrumb */
.tp-breadcrumb {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.875rem;
  color: var(--pc-text, #2d2d2d);
  opacity: 0.6;
  flex-wrap: wrap;
}
.tp-breadcrumb a { color: inherit; text-decoration: none; }
.tp-breadcrumb a:hover { opacity: 1; text-decoration: underline; }

/* Paw rating */
.tp-paw-row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }

.tp-paws { display: flex; gap: 3px; }

.tp-paw { width: 22px; height: 22px; }
.tp-paw--on  { color: var(--pc-orange, #f59f2b); }
.tp-paw--off { color: var(--pc-text, #2d2d2d); opacity: 0.2; }

.tp-paw-text {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--pc-text, #2d2d2d);
  opacity: 0.75;
}

/* Title */
.tp-title {
  font-family: 'Fredoka', sans-serif;
  font-size: clamp(1.75rem, 3.5vw, 2.4rem);
  font-weight: 600;
  line-height: 1.15;
  color: var(--pc-text, #2d2d2d);
  margin: 0;
}

/* Subtitle */
.tp-subtitle {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 1.05rem;
  color: var(--pc-text, #2d2d2d);
  opacity: 0.7;
  margin: 0;
  line-height: 1.5;
}

/* Price */
.tp-price-row { display: flex; align-items: baseline; gap: 0.75rem; flex-wrap: wrap; }

.tp-price {
  font-family: 'Fredoka', sans-serif;
  font-size: 2.1rem;
  font-weight: 600;
  color: var(--pc-text, #2d2d2d);
}
.tp-price--sale { color: var(--pc-sale-red, #e8372b); }

.tp-compare {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 1.1rem;
  color: var(--pc-text, #2d2d2d);
  opacity: 0.4;
  text-decoration: line-through;
}

.tp-savings {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.82rem;
  font-weight: 800;
  color: var(--pc-sale-red, #e8372b);
  background: #ffeeed;
  border: 1.5px solid var(--pc-sale-red, #e8372b);
  border-radius: 999px;
  padding: 3px 10px;
}

/* Description — text only, strip embedded media */
.tp-description {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 1.02rem;
  line-height: 1.65;
  color: var(--pc-text, #2d2d2d);
  opacity: 0.85;
}

/* Hide any images / video / embeds inside product description.
   Product images belong in the gallery only. */
.tp-description img,
.tp-description video,
.tp-description iframe,
.tp-description figure,
.tp-description .shopify-block--image,
.tp-description [data-mce-fragment] img {
  display: none !important;
}

/* Also collapse empty paragraphs Shopify wraps around removed images */
.tp-description p:empty { display: none; }

/* Variants */
.tp-variants { display: flex; flex-direction: column; gap: 1rem; }

.tp-option-group { display: flex; flex-direction: column; gap: 0.5rem; }

.tp-option-label {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.82rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--pc-text, #2d2d2d);
}
.tp-option-label em {
  font-style: normal;
  font-weight: 500;
  text-transform: none;
  letter-spacing: 0;
  opacity: 0.65;
  margin-left: 6px;
}

.tp-pills { display: flex; flex-wrap: wrap; gap: 8px; }

.tp-pill {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.9rem;
  font-weight: 700;
  padding: 7px 18px;
  border-radius: 999px;
  border: 2.5px solid var(--pc-text, #2d2d2d);
  box-shadow: 3px 3px 0 var(--pc-text, #2d2d2d);
  background: #FFF4D9;
  color: var(--pc-text, #2d2d2d);
  cursor: pointer;
  transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
}
.tp-pill:hover { transform: translate(-2px, -2px); box-shadow: 5px 5px 0 var(--pc-text, #2d2d2d); }
.tp-pill.tp-selected {
  background: var(--pc-orange, #f59f2b);
  transform: translate(-2px, -2px);
  box-shadow: 5px 5px 0 var(--pc-text, #2d2d2d);
}
.tp-pill.tp-unavailable { opacity: 0.3; cursor: not-allowed; pointer-events: none; box-shadow: none; }
.tp-variant-msg { font-family: 'Nunito Sans', sans-serif; font-size: 0.875rem; font-weight: 700; color: var(--pc-sale-red, #e8372b); padding: 8px 12px; background: rgba(232,55,43,0.08); border-radius: 8px; border-left: 3px solid var(--pc-sale-red, #e8372b); margin-top: 4px; }

.tp-variant-select-native { position: absolute; opacity: 0; pointer-events: none; width: 0; height: 0; }

/* Quantity */
.tp-qty-row { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }

.tp-qty-label {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.82rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--pc-text, #2d2d2d);
}

.tp-qty {
  display: flex;
  align-items: center;
  border: 2.5px solid var(--pc-text, #2d2d2d);
  border-radius: 999px;
  box-shadow: 3px 3px 0 var(--pc-text, #2d2d2d);
  background: #FFF4D9;
  overflow: hidden;
}

.tp-qty__btn {
  width: 42px; height: 42px;
  background: none; border: none;
  font-family: 'Fredoka', sans-serif;
  font-size: 1.4rem; font-weight: 600;
  color: var(--pc-text, #2d2d2d);
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  line-height: 1;
  transition: background 0.12s;
}
.tp-qty__btn:hover { background: #E8CFA0; }

.tp-qty__input {
  width: 44px; text-align: center;
  border: none;
  border-left: 2px solid var(--pc-text, #2d2d2d);
  border-right: 2px solid var(--pc-text, #2d2d2d);
  background: none;
  font-family: 'Fredoka', sans-serif;
  font-size: 1.1rem; font-weight: 600;
  color: var(--pc-text, #2d2d2d);
  height: 42px; padding: 0;
  -moz-appearance: textfield;
}
.tp-qty__input::-webkit-inner-spin-button,
.tp-qty__input::-webkit-outer-spin-button { -webkit-appearance: none; }

/* Promo box */
.tp-promo {
  background: #FFF4D9;
  border: 2.5px solid var(--pc-text, #2d2d2d);
  border-radius: 16px;
  box-shadow: 5px 5px 0 var(--pc-text, #2d2d2d);
  padding: 16px 18px;
}

.tp-promo__head { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
.tp-promo__emoji { font-size: 1.3rem; line-height: 1; }
.tp-promo__title { font-family: 'Fredoka', sans-serif; font-size: 1.15rem; font-weight: 600; color: var(--pc-text, #2d2d2d); }
.tp-promo__text { font-family: 'Nunito Sans', sans-serif; font-size: 0.9rem; color: var(--pc-text, #2d2d2d); opacity: 0.75; margin-bottom: 10px; }

/* Countdown */
.tp-countdown { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }

.tp-countdown__label {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.78rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.06em;
  color: var(--pc-text, #2d2d2d); opacity: 0.6;
}

.tp-countdown__units { display: flex; gap: 6px; align-items: center; }

.tp-countdown__unit {
  display: flex; flex-direction: column; align-items: center;
  background: var(--pc-orange, #f59f2b);
  border: 2px solid var(--pc-text, #2d2d2d);
  border-radius: 8px;
  box-shadow: 2px 2px 0 var(--pc-text, #2d2d2d);
  min-width: 38px; padding: 4px 6px 3px;
}

.tp-countdown__num { font-family: 'Fredoka', sans-serif; font-size: 1.15rem; font-weight: 600; color: #fff; line-height: 1; }
.tp-countdown__sub { font-family: 'Nunito Sans', sans-serif; font-size: 0.6rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; color: #fff; opacity: 0.85; line-height: 1; margin-top: 1px; }
.tp-countdown__sep { font-family: 'Fredoka', sans-serif; font-size: 1.2rem; font-weight: 700; color: var(--pc-text, #2d2d2d); opacity: 0.5; }
.tp-countdown__expired { font-family: 'Nunito Sans', sans-serif; font-size: 0.88rem; font-weight: 700; color: var(--pc-sale-red, #e8372b); }

/* Free shipping bar */
.tp-ship-bar {
  background: #FFF4D9;
  border: 2.5px solid var(--pc-text, #2d2d2d);
  border-radius: 14px;
  box-shadow: 4px 4px 0 var(--pc-text, #2d2d2d);
  padding: 12px 16px;
}

.tp-ship-bar__text {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.88rem; font-weight: 700;
  color: var(--pc-text, #2d2d2d);
  margin-bottom: 8px;
  display: flex; align-items: center; gap: 6px;
}
.tp-ship-bar__text svg { width: 18px; height: 18px; color: var(--pc-green, #2eaa5f); flex-shrink: 0; }

.tp-ship-bar__track { height: 8px; background: #E4DDD5; border-radius: 999px; overflow: hidden; }
.tp-ship-bar__fill { height: 100%; background: var(--pc-green, #2eaa5f); border-radius: 999px; }

/* Multibuy */
.tp-multibuy {
  background: linear-gradient(135deg, #fff8e7 0%, #fff3d5 100%);
  border: 2px dashed var(--pc-orange, #f59f2b);
  border-radius: 14px;
  padding: 12px 16px;
  display: flex; align-items: center; gap: 10px;
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.88rem; font-weight: 700;
  color: var(--pc-text, #2d2d2d);
}
.tp-multibuy__emoji { font-size: 1.3rem; flex-shrink: 0; }

/* Bundle upsell */
.tp-upsell {
  background: #FFF4D9;
  border: 2.5px solid var(--pc-orange, #f59f2b);
  border-radius: 16px;
  box-shadow: 5px 5px 0 var(--pc-text, #2d2d2d);
  padding: 14px 16px;
  display: flex; align-items: center; gap: 12px;
}
.tp-upsell__icon { font-size: 2rem; flex-shrink: 0; line-height: 1; }
.tp-upsell__body { flex: 1; }
.tp-upsell__title { font-family: 'Fredoka', sans-serif; font-size: 1rem; font-weight: 600; color: var(--pc-text, #2d2d2d); margin-bottom: 2px; }
.tp-upsell__text { font-family: 'Nunito Sans', sans-serif; font-size: 0.82rem; color: var(--pc-text, #2d2d2d); opacity: 0.7; }

.tp-upsell__btn {
  font-family: 'Fredoka', sans-serif; font-size: 0.9rem; font-weight: 600;
  color: var(--pc-white, #ffffff);
  background: var(--pc-orange, #f59f2b);
  border: 2px solid var(--pc-text, #2d2d2d);
  border-radius: 999px;
  box-shadow: 2px 2px 0 var(--pc-text, #2d2d2d);
  padding: 6px 14px;
  text-decoration: none; white-space: nowrap; flex-shrink: 0;
  transition: transform 0.14s ease, box-shadow 0.14s ease;
  display: inline-flex; align-items: center;
}
.tp-upsell__btn:hover { transform: translate(-2px,-2px); box-shadow: 4px 4px 0 var(--pc-text, #2d2d2d); }

/* CTA */
.tp-cta { display: flex; flex-direction: column; gap: 10px; }

.tp-btn-cart {
  display: flex; align-items: center; justify-content: center; gap: 8px;
  width: 100%; padding: 16px 24px;
  font-family: 'Fredoka', sans-serif; font-size: 1.2rem; font-weight: 600;
  color: var(--pc-white, #ffffff);
  background: var(--pc-green, #2eaa5f);
  border: 2.5px solid var(--pc-text, #2d2d2d);
  border-radius: 999px;
  box-shadow: 5px 5px 0 var(--pc-text, #2d2d2d);
  cursor: pointer;
  transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
}
.tp-btn-cart:hover:not(:disabled) { transform: translate(-2px,-2px); box-shadow: 7px 7px 0 var(--pc-text, #2d2d2d); background: var(--pc-green-dark, #228a4a); }
.tp-btn-cart:disabled { opacity: 0.5; cursor: not-allowed; }

/* Trust badges */
.tp-trust {
  display: grid; grid-template-columns: 1fr 1fr; gap: 8px;
  padding: 14px;
  background: #FFF4D9;
  border: 2.5px solid var(--pc-text, #2d2d2d);
  border-radius: 14px;
  box-shadow: 4px 4px 0 var(--pc-text, #2d2d2d);
}
.tp-trust__item { display: flex; align-items: center; gap: 7px; font-family: 'Nunito Sans', sans-serif; font-size: 0.8rem; font-weight: 700; color: var(--pc-text, #2d2d2d); }
.tp-trust__icon { width: 24px; height: 24px; flex-shrink: 0; color: var(--pc-green, #2eaa5f); }

/* ============================================================
   PRODUCT DESCRIPTION (below two-column section)
   ============================================================ */
.tp-desc-section {
  max-width: 860px;
  margin: 2.5rem auto 0;
  padding: 0 1.5rem;
}

/* Description text — brand-styled, no images */
.tp-desc-section .tp-description {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 1.05rem;
  line-height: 1.75;
  color: var(--pc-text, #2d2d2d);
  opacity: 0.85;
}

/* Hide all media inside product description — images belong in gallery only */
.tp-description img,
.tp-description video,
.tp-description iframe,
.tp-description figure,
.tp-description .shopify-block--image {
  display: none !important;
}
.tp-description p:empty { display: none; }

/* Nice formatting for description content */
.tp-description p { margin: 0 0 0.85rem; }
.tp-description p:last-child { margin-bottom: 0; }
.tp-description ul, .tp-description ol {
  padding-left: 1.4rem;
  margin: 0 0 0.85rem;
}
.tp-description li { margin-bottom: 0.3rem; }
.tp-description strong { font-weight: 800; }
.tp-description h2, .tp-description h3, .tp-description h4 {
  font-family: 'Fredoka', sans-serif;
  font-weight: 600;
  color: var(--pc-text, #2d2d2d);
  margin: 1.25rem 0 0.5rem;
}

/* ============================================================
   LOWER CONTENT
   ============================================================ */
.tp-lower { max-width: 1280px; margin: 0 auto; padding: 3rem 1.5rem 0; }

/* Accordions */
.tp-accordions { display: flex; flex-direction: column; gap: 10px; max-width: 820px; margin: 0 auto; }

.tp-acc {
  border: 2.5px solid var(--pc-text, #2d2d2d);
  border-radius: 14px; overflow: hidden;
  box-shadow: 3px 3px 0 var(--pc-text, #2d2d2d);
  background: #FFF4D9;
}
.tp-acc[open] { box-shadow: 5px 5px 0 var(--pc-text, #2d2d2d); }

.tp-acc summary {
  display: flex; align-items: center; justify-content: space-between;
  padding: 14px 20px; cursor: pointer; list-style: none;
  font-family: 'Fredoka', sans-serif; font-size: 1.1rem; font-weight: 600;
  color: var(--pc-text, #2d2d2d);
  gap: 1rem; user-select: none;
}
.tp-acc summary::-webkit-details-marker { display: none; }
.tp-acc__label { display: flex; align-items: center; gap: 10px; }

.tp-acc__chev {
  width: 20px; height: 20px; flex-shrink: 0;
  color: var(--pc-orange, #f59f2b);
  transition: transform 0.2s ease;
}
.tp-acc[open] .tp-acc__chev { transform: rotate(180deg); }

.tp-acc__body {
  padding: 14px 20px 16px;
  border-top: 1.5px solid rgba(45,45,45,0.12);
  font-family: 'Nunito Sans', sans-serif; font-size: 1rem; line-height: 1.65;
  color: var(--pc-text, #2d2d2d); opacity: 0.85;
}
.tp-acc__body p { margin: 0 0 0.75rem; }
.tp-acc__body p:last-child { margin-bottom: 0; }

/* ---- Product Story ---- */
.tp-story { max-width: 1280px; margin: 3.5rem auto 0; padding: 0 1.5rem; }

.tp-story__heading {
  font-family: 'Fredoka', sans-serif;
  font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 600;
  color: var(--pc-text, #2d2d2d);
  text-align: center; margin-bottom: 2rem;
}

.tp-story__grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem;
}
@media screen and (max-width: 899px) { .tp-story__grid { grid-template-columns: 1fr 1fr; } }
@media screen and (max-width: 599px) { .tp-story__grid { grid-template-columns: 1fr; } }

.tp-story__card {
  background: #FFF4D9;
  border: 2.5px solid var(--pc-text, #2d2d2d);
  border-radius: 18px; box-shadow: 5px 5px 0 var(--pc-text, #2d2d2d);
  overflow: hidden; display: flex; flex-direction: column;
}

.tp-story__img { width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block; }

.tp-story__card-body { padding: 16px 18px 18px; }
.tp-story__emoji { font-size: 1.6rem; margin-bottom: 8px; display: block; }
.tp-story__card-title { font-family: 'Fredoka', sans-serif; font-size: 1.15rem; font-weight: 600; color: var(--pc-text, #2d2d2d); margin-bottom: 6px; }
.tp-story__card-text { font-family: 'Nunito Sans', sans-serif; font-size: 0.92rem; line-height: 1.6; color: var(--pc-text, #2d2d2d); opacity: 0.75; }

/* ---- Specs table ---- */
.tp-specs { max-width: 820px; margin: 3rem auto 0; padding: 0 1.5rem; }

.tp-specs__heading {
  font-family: 'Fredoka', sans-serif; font-size: 1.4rem; font-weight: 600;
  color: var(--pc-text, #2d2d2d); text-align: center; margin-bottom: 1rem;
}

.tp-specs__table {
  border: 2.5px solid var(--pc-text, #2d2d2d);
  border-radius: 14px; overflow: hidden;
  box-shadow: 4px 4px 0 var(--pc-text, #2d2d2d);
}

.tp-specs__row {
  display: grid; grid-template-columns: 1fr 2fr;
  border-bottom: 1.5px solid rgba(45,45,45,0.12);
}
.tp-specs__row:last-child { border-bottom: none; }
.tp-specs__row:nth-child(even) { background: #FFF8EE; }

.tp-specs__key {
  padding: 12px 16px;
  font-family: 'Nunito Sans', sans-serif; font-size: 0.78rem; font-weight: 800;
  text-transform: uppercase; letter-spacing: 0.04em;
  color: var(--pc-text, #2d2d2d); opacity: 0.6;
}
.tp-specs__val {
  padding: 12px 16px;
  font-family: 'Nunito Sans', sans-serif; font-size: 0.92rem;
  color: var(--pc-text, #2d2d2d);
}

/* ---- Related products ---- */
.tp-related { max-width: 1280px; margin: 3rem auto 0; padding: 0 1.5rem; }

.tp-related__heading {
  font-family: 'Fredoka', sans-serif;
  font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 600;
  color: var(--pc-text, #2d2d2d); text-align: center; margin-bottom: 1.5rem;
}

.tp-related__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
@media screen and (max-width: 1024px) { .tp-related__grid { grid-template-columns: repeat(3, 1fr); } }
@media screen and (max-width: 749px) { .tp-related__grid { grid-template-columns: repeat(2, 1fr); gap: 0.875rem; } }

.tp-rel-card {
  background: #FFF4D9;
  border: 2.5px solid var(--pc-text, #2d2d2d);
  border-radius: 18px; box-shadow: 5px 5px 0 var(--pc-text, #2d2d2d);
  overflow: hidden; display: flex; flex-direction: column;
  text-decoration: none;
  transition: transform 0.18s ease, box-shadow 0.18s ease;
}
.tp-rel-card:hover { transform: translate(-2px,-2px); box-shadow: 7px 7px 0 var(--pc-text, #2d2d2d); }

.tp-rel-card__img-wrap { width: 100%; aspect-ratio: 1/1; overflow: hidden; background: #FFF4D9; }
.tp-rel-card__img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.3s ease; }
.tp-rel-card:hover .tp-rel-card__img { transform: scale(1.04); }

.tp-rel-card__body { padding: 14px 16px 16px; display: flex; flex-direction: column; gap: 8px; flex: 1; }
.tp-rel-card__title { font-family: 'Fredoka', sans-serif; font-size: 1.05rem; font-weight: 600; color: var(--pc-text, #2d2d2d); line-height: 1.25; }

.tp-rel-card__price { font-family: 'Nunito Sans', sans-serif; font-size: 0.95rem; font-weight: 700; color: var(--pc-text, #2d2d2d); }
.tp-rel-card__price--sale { color: var(--pc-sale-red, #e8372b); }
.tp-rel-card__compare { font-size: 0.82rem; text-decoration: line-through; opacity: 0.4; margin-left: 5px; }

.tp-rel-card__btn {
  display: flex; align-items: center; justify-content: center;
  width: 100%; padding: 9px 16px; margin-top: auto;
  font-family: 'Fredoka', sans-serif; font-size: 1rem; font-weight: 600;
  color: var(--pc-white, #ffffff); background: var(--pc-green, #2eaa5f);
  border: 2.5px solid var(--pc-text, #2d2d2d);
  border-radius: 999px; box-shadow: 3px 3px 0 var(--pc-text, #2d2d2d);
  transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
}
.tp-rel-card:hover .tp-rel-card__btn { transform: translate(-2px,-2px); box-shadow: 5px 5px 0 var(--pc-text, #2d2d2d); background: var(--pc-green-dark, #228a4a); }

/* ---- FAQ ---- */
.tp-faq {
  max-width: 820px;
  margin: 4rem auto 0;
  padding: 0 1.5rem;
  text-align: center;
}

.tp-faq__heading {
  font-family: 'Fredoka', sans-serif;
  font-size: clamp(2rem, 4vw, 2.8rem);
  font-weight: 600;
  color: var(--pc-text, #2d2d2d);
  margin: 0 0 0.5rem;
  line-height: 1.1;
}

/* SVG wave underline matching landing page hero sections */
.tp-faq__wave {
  display: block;
  width: 180px;
  margin: 0 auto 2.25rem;
  overflow: visible;
}

.tp-faq__items { display: flex; flex-direction: column; gap: 10px; text-align: left; }

/* FAQ accordions are slightly taller than product accordions for readability */
.tp-faq .tp-acc summary {
  padding: 16px 22px;
  font-size: 1.15rem;
}

.tp-faq .tp-acc__body {
  padding: 14px 22px 18px;
  font-size: 1.02rem;
}

/* ---- Sticky mobile bar ---- */
.tp-sticky-bar {
  display: none;
  position: fixed; bottom: 0; left: 0; right: 0; z-index: 200;
  background: #FFF4D9;
  border-top: 2.5px solid var(--pc-text, #2d2d2d);
  box-shadow: 0 -4px 16px rgba(0,0,0,0.12);
  padding: 10px 16px;
  align-items: center; gap: 12px;
}
@media screen and (max-width: 899px) {
  .tp-sticky-bar { display: flex; }
  .tp-sticky-bar.tp-hidden { display: none; }
}

.tp-sticky-bar__info { flex: 1; min-width: 0; }
.tp-sticky-bar__title { font-family: 'Fredoka', sans-serif; font-size: 0.95rem; font-weight: 600; color: var(--pc-text, #2d2d2d); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.tp-sticky-bar__price { font-family: 'Nunito Sans', sans-serif; font-size: 0.88rem; font-weight: 700; color: var(--pc-text, #2d2d2d); }
.tp-sticky-bar__price--sale { color: var(--pc-sale-red, #e8372b); }

.tp-sticky-bar__btn {
  flex-shrink: 0; padding: 11px 22px;
  font-family: 'Fredoka', sans-serif; font-size: 1rem; font-weight: 600;
  color: var(--pc-white, #ffffff); background: var(--pc-green, #2eaa5f);
  border: 2px solid var(--pc-text, #2d2d2d);
  border-radius: 999px; box-shadow: 3px 3px 0 var(--pc-text, #2d2d2d);
  cursor: pointer; white-space: nowrap;
}
.tp-sticky-bar__btn:disabled { opacity: 0.5; cursor: not-allowed; box-shadow: none; }

/* ---- Bottom spacing ---- */
.tp-section-end { padding-bottom: var(--tp-pb, 64px); }

/* ---- Mobile tightening ---- */
@media screen and (max-width: 749px) {
  .tp-wrap, .tp-desc-section, .tp-lower, .tp-story, .tp-specs, .tp-related, .tp-faq, .tp-feat {
    padding-left: 1rem; padding-right: 1rem;
  }
}

/* ============================================================
   FEATURE ROWS  (tp-feat-*)
   ============================================================ */
.tp-feat {
  max-width: 1280px;
  margin: 3.5rem auto 0;
  padding: 0 1.5rem;
}

.tp-feat__row {
  display: flex;
  gap: 3.5rem;
  align-items: center;
  margin-bottom: 3.5rem;
}

.tp-feat__row:last-child { margin-bottom: 0; }

.tp-feat__row--reverse { flex-direction: row-reverse; }

/* Image side */
.tp-feat__img-wrap {
  flex: 1 1 45%;
  min-width: 0;
  border: 3px solid var(--pc-text, #2B1B12);
  border-radius: 20px;
  box-shadow: 6px 8px 0 rgba(43, 27, 18, 0.82);
  overflow: hidden;
  background: #FFF4D9;
  flex-shrink: 0;
}

.tp-feat__img {
  width: 100%;
  aspect-ratio: 4 / 3;
  object-fit: cover;
  display: block;
  transition: transform 0.35s ease;
}

.tp-feat__row:hover .tp-feat__img { transform: scale(1.03); }

/* Text side */
.tp-feat__content {
  flex: 1 1 50%;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.tp-feat__eyebrow {
  display: inline-block;
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.78rem;
  font-weight: 800;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--pc-orange, #EE7B28);
  background: rgba(238, 123, 40, 0.1);
  border: 1.5px solid rgba(238, 123, 40, 0.25);
  border-radius: 999px;
  padding: 4px 14px;
  line-height: 1.4;
  width: fit-content;
}

.tp-feat__title {
  font-family: 'Fredoka', sans-serif;
  font-size: clamp(1.5rem, 2.8vw, 2rem);
  font-weight: 700;
  color: var(--pc-text, #2B1B12);
  margin: 0;
  line-height: 1.2;
}

.tp-feat__body {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 1rem;
  line-height: 1.75;
  color: var(--pc-text, #2B1B12);
  opacity: 0.82;
  max-width: 54ch;
}

.tp-feat__body p { margin: 0 0 0.75rem; }
.tp-feat__body p:last-child { margin-bottom: 0; }

.tp-feat__body h2,
.tp-feat__body h3 {
  font-family: 'Fredoka', sans-serif;
  font-size: clamp(1.4rem, 2.5vw, 1.9rem);
  font-weight: 700;
  color: var(--pc-text, #2B1B12);
  opacity: 1;
  margin: 0 0 0.75rem;
  line-height: 1.2;
}

.tp-feat__body ul,
.tp-feat__body ol {
  list-style: none;
  padding: 0;
  margin: 0.25rem 0 0;
  display: flex;
  flex-direction: column;
  gap: 0.55rem;
}

.tp-feat__body li {
  display: flex;
  align-items: flex-start;
  gap: 0.55rem;
  font-size: 0.95rem;
  font-weight: 600;
  opacity: 1;
  color: var(--pc-text, #2B1B12);
  line-height: 1.4;
}

.tp-feat__body li::before {
  content: '';
  flex-shrink: 0;
  display: inline-block;
  width: 18px;
  height: 18px;
  margin-top: 1px;
  background-color: var(--pc-green, #4F8A2F);
  border-radius: 50%;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 20 20' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpolyline points='5 10 8.5 13.5 15 6.5' stroke='white' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
  background-size: 14px 14px;
  background-repeat: no-repeat;
  background-position: center;
}

.tp-feat__bullets {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.625rem;
}

.tp-feat__bullet {
  display: flex;
  align-items: flex-start;
  gap: 0.6rem;
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--pc-text, #2B1B12);
  line-height: 1.4;
}

.tp-feat__check {
  flex-shrink: 0;
  width: 18px;
  height: 18px;
  margin-top: 1px;
  color: var(--pc-green, #4F8A2F);
}

@media screen and (max-width: 749px) {
  .tp-feat__row,
  .tp-feat__row--reverse {
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }
  .tp-feat__img-wrap { flex-basis: auto; width: 100%; }
  .tp-feat__content { flex-basis: auto; }
  .tp-feat { margin-top: 2.5rem; }
}
{% endstylesheet %}

{%- liquid
  assign tp_product       = product
  assign tp_variant       = tp_product.selected_or_first_available_variant
  assign tp_on_sale       = false
  if tp_variant.compare_at_price > tp_variant.price
    assign tp_on_sale = true
  endif
  assign tp_pt = section.settings.padding_top  | append: 'px'
  assign tp_pb = section.settings.padding_bottom | append: 'px'

  assign tp_active_currency = localization.country.currency.iso_code
  assign tp_is_usd          = false
  if tp_active_currency == 'USD'
    assign tp_is_usd = true
  endif
  assign tp_threshold_cents = section.settings.free_shipping_threshold_usd | times: 100
  assign tp_cart_cents      = cart.total_price
  assign tp_progress        = 0
  if tp_is_usd and tp_threshold_cents > 0
    if tp_cart_cents >= tp_threshold_cents
      assign tp_progress = 100
    else
      assign tp_progress = tp_cart_cents | times: 100 | divided_by: tp_threshold_cents
    endif
  endif
  assign tp_remaining = tp_threshold_cents | minus: tp_cart_cents | money
-%}

<style>
  #tp-{{ section.id }} { --tp-pt: {{ tp_pt }}; --tp-pb: {{ tp_pb }}; }
  #shopify-section-{{ section.id }} { background: #FFFFFF; }
</style>

<section id="tp-{{ section.id }}">
  {%- form 'product', tp_product, id: 'tp-form' -%}
    {{- '' -}}
    <input type="hidden" name="id" id="tp-variant-id" value="{{ product.selected_or_first_available_variant.id }}">

    <div class="tp-wrap">
      <div class="tp-main">

        <!-- ======== GALLERY ======== -->
        <div class="tp-gallery">
          <div class="tp-gallery__main">

            {%- if section.settings.show_sale_badge and tp_on_sale -%}
              <div class="tp-gallery__badge">{{ section.settings.sale_badge_text }}</div>
            {%- endif -%}

            {%- assign tp_main_media = tp_variant.featured_media | default: tp_product.featured_media -%}
            {%- if tp_main_media != blank -%}
              {%- assign tp_main_alt = tp_main_media.alt | default: tp_product.title | escape -%}
              {%- assign tp_main_src = tp_main_media.preview_image -%}
            {%- else -%}
              {%- assign tp_main_alt = tp_product.title | escape -%}
              {%- assign tp_main_src = tp_product.featured_image -%}
            {%- endif -%}

            {%- if tp_main_src != blank -%}
              {{- tp_main_src | image_url: width: 900 | image_tag: id: 'tp-main-img', class: 'tp-gallery__main-img', alt: tp_main_alt, loading: 'eager', fetchpriority: 'high', width: 900, height: 900 -}}
            {%- endif -%}

          </div>

          {%- if tp_product.media.size > 1 -%}
            <div class="tp-gallery__thumbs">
              {%- for media in tp_product.media -%}
                {%- assign tp_th_alt = media.alt | default: tp_product.title | escape -%}
                {%- assign tp_th_full = media.preview_image | image_url: width: 900 -%}
                <button type="button"
                  class="tp-gallery__thumb{% if forloop.first %} tp-active{% endif %}"
                  data-src="{{ tp_th_full }}"
                  aria-label="{{ tp_th_alt }}">
                  {{- media.preview_image | image_url: width: 144 | image_tag: alt: tp_th_alt, loading: 'lazy', width: 72, height: 72 -}}
                </button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
        <!-- /gallery -->

        <!-- ======== INFO PANEL ======== -->
        <div class="tp-info">

          <!-- Breadcrumb -->
          <nav class="tp-breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span aria-hidden="true">/</span>
            {%- if tp_product.collections.size > 0 -%}
              <a href="{{ tp_product.collections.first.url }}">{{ tp_product.collections.first.title }}</a>
              <span aria-hidden="true">/</span>
            {%- endif -%}
            <span>{{ tp_product.title }}</span>
          </nav>

          <!-- Paw rating -->
          {%- if section.settings.show_paw_rating -%}
            {%- assign tp_paw_n = section.settings.paw_rating_score -%}
            <div class="tp-paw-row">
              <div class="tp-paws" role="img" aria-label="{{ tp_paw_n }} out of 5">
                {%- for i in (1..5) -%}
                  {%- if i <= tp_paw_n -%}
                    <svg class="tp-paw tp-paw--on" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <ellipse cx="6.5" cy="9" rx="2" ry="2.5"/>
                      <ellipse cx="10" cy="6.5" rx="2" ry="2.5"/>
                      <ellipse cx="14" cy="6.5" rx="2" ry="2.5"/>
                      <ellipse cx="17.5" cy="9" rx="2" ry="2.5"/>
                      <path d="M12 22.5C8.5 22.5 5.5 20.5 5.5 17.5C5.5 14.5 7.5 12.5 12 12.5C16.5 12.5 18.5 14.5 18.5 17.5C18.5 20.5 15.5 22.5 12 22.5Z"/>
                    </svg>
                  {%- else -%}
                    <svg class="tp-paw tp-paw--off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <ellipse cx="6.5" cy="9" rx="2" ry="2.5"/>
                      <ellipse cx="10" cy="6.5" rx="2" ry="2.5"/>
                      <ellipse cx="14" cy="6.5" rx="2" ry="2.5"/>
                      <ellipse cx="17.5" cy="9" rx="2" ry="2.5"/>
                      <path d="M12 22.5C8.5 22.5 5.5 20.5 5.5 17.5C5.5 14.5 7.5 12.5 12 12.5C16.5 12.5 18.5 14.5 18.5 17.5C18.5 20.5 15.5 22.5 12 22.5Z"/>
                    </svg>
                  {%- endif -%}
                {%- endfor -%}
              </div>
              <span class="tp-paw-text">{{ section.settings.paw_rating_text }}</span>
            </div>
          {%- endif -%}

          <!-- Title -->
          <h1 class="tp-title">{{ tp_product.title }}</h1>

          <!-- Subtitle -->
          {%- if section.settings.subtitle != blank -%}
            <p class="tp-subtitle">{{ section.settings.subtitle }}</p>
          {%- endif -%}

          <!-- Price -->
          <div class="tp-price-row" id="tp-price-row">
            {%- if tp_on_sale -%}
              <span class="tp-price tp-price--sale" id="tp-price">{{ tp_variant.price | money }}</span>
              <span class="tp-compare" id="tp-compare">{{ tp_variant.compare_at_price | money }}</span>
              {%- assign tp_save_amt = tp_variant.compare_at_price | minus: tp_variant.price -%}
              <span class="tp-savings" id="tp-savings">Save {{ tp_save_amt | money }}</span>
            {%- else -%}
              <span class="tp-price" id="tp-price">{{ tp_variant.price | money }}</span>
              <span class="tp-compare" id="tp-compare" style="display:none"></span>
              <span class="tp-savings" id="tp-savings" style="display:none"></span>
            {%- endif -%}
          </div>

          <!-- Variant pills -->
          {%- unless tp_product.has_only_default_variant -%}
            <div class="tp-variants">
              {%- for option in tp_product.options_with_values -%}
                {%- assign tp_oi = forloop.index0 -%}
                <div class="tp-option-group" data-option-index="{{ tp_oi }}">
                  <div class="tp-option-label">
                    {{ option.name }}<em id="tp-sel-{{ tp_oi }}" aria-live="polite" aria-atomic="true">{{ option.selected_value }}</em>
                  </div>
                  <div class="tp-pills" role="group" aria-label="{{ option.name }}">
                    {%- for value in option.values -%}
                      {%- if option.selected_value == value -%}
                        {%- assign tp_pill_on = true -%}
                      {%- else -%}
                        {%- assign tp_pill_on = false -%}
                      {%- endif -%}
                      <button type="button"
                        class="tp-pill{% if tp_pill_on %} tp-selected{% endif %}"
                        data-option-index="{{ tp_oi }}"
                        data-value="{{ value | escape }}"
                        aria-pressed="{{ tp_pill_on }}"
                      >{{ value }}</button>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- endunless -%}

          <!-- Variant availability message -->
          <div id="tp-variant-msg" class="tp-variant-msg" aria-live="polite" style="display:none"></div>

          <!-- Variant data store (no name= so it does not submit a duplicate id) -->
          <select id="tp-variant-select" class="tp-variant-select-native" aria-hidden="true">
            {%- for variant in tp_product.variants -%}
              {%- assign tp_var_alt = variant.featured_media.alt | default: tp_product.title | escape -%}
              {%- if variant.featured_media != blank -%}
                {%- assign tp_var_img = variant.featured_media.preview_image | image_url: width: 900 -%}
              {%- else -%}
                {%- assign tp_var_img = '' -%}
              {%- endif -%}
              <option
                value="{{ variant.id }}"
                {% if variant == tp_variant %}selected{% endif %}
                {% unless variant.available %}disabled{% endunless %}
                data-price="{{ variant.price }}"
                data-compare="{{ variant.compare_at_price | default: 0 }}"
                data-img="{{ tp_var_img }}"
                data-alt="{{ tp_var_alt }}"
              >{{ variant.title }}</option>
            {%- endfor -%}
          </select>

          <!-- Quantity -->
          <div class="tp-qty-row">
            <span class="tp-qty-label">Qty</span>
            <div class="tp-qty">
              <button type="button" class="tp-qty__btn" id="tp-minus" aria-label="Decrease">&#8722;</button>
              <input type="number" name="quantity" id="tp-qty" class="tp-qty__input" value="1" min="1" aria-label="Quantity">
              <button type="button" class="tp-qty__btn" id="tp-plus" aria-label="Increase">&#43;</button>
            </div>
          </div>

          <!-- Promo box -->
          {%- if section.settings.promo_title != blank -%}
            <div class="tp-promo">
              <div class="tp-promo__head">
                {%- if section.settings.promo_emoji != blank -%}
                  <span class="tp-promo__emoji">{{ section.settings.promo_emoji }}</span>
                {%- endif -%}
                <span class="tp-promo__title">{{ section.settings.promo_title }}</span>
              </div>
              {%- if section.settings.promo_text != blank -%}
                <p class="tp-promo__text">{{ section.settings.promo_text }}</p>
              {%- endif -%}
              {%- if section.settings.show_countdown -%}
                <div class="tp-countdown" data-tailand-countdown>
                  <span class="tp-countdown__label">{{ section.settings.countdown_label | default: "Today's deal ends in" }}</span>
                  <div class="tp-countdown__units">
                    <div class="tp-countdown__unit"><span class="tp-countdown__num" data-cd-h>--</span><span class="tp-countdown__sub">Hrs</span></div>
                    <span class="tp-countdown__sep">:</span>
                    <div class="tp-countdown__unit"><span class="tp-countdown__num" data-cd-m>--</span><span class="tp-countdown__sub">Min</span></div>
                    <span class="tp-countdown__sep">:</span>
                    <div class="tp-countdown__unit"><span class="tp-countdown__num" data-cd-s>--</span><span class="tp-countdown__sub">Sec</span></div>
                  </div>
                  <noscript><span class="tp-countdown__label">Today's deal is available now.</span></noscript>
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}

          <!-- Free shipping bar -->
          {%- if section.settings.show_free_shipping -%}
            {%- if tp_is_usd and tp_threshold_cents > 0 -%}
              <div class="tp-ship-bar"
                   data-free-shipping-progress
                   data-free-shipping-threshold="{{ tp_threshold_cents }}"
                   data-free-shipping-prefix="{{ section.settings.free_shipping_prefix | escape }}"
                   data-free-shipping-suffix="{{ section.settings.free_shipping_suffix | escape }}">
                <div class="tp-ship-bar__text">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                  {%- if tp_progress >= 100 -%}
                    <span data-free-shipping-message>You unlocked <strong>free shipping!</strong> &#127881;</span>
                  {%- else -%}
                    <span data-free-shipping-message>{{ section.settings.free_shipping_prefix }} <strong>{{ tp_remaining }}</strong> {{ section.settings.free_shipping_suffix }}</span>
                  {%- endif -%}
                </div>
                <div class="tp-ship-bar__track">
                  <div class="tp-ship-bar__fill" data-free-shipping-bar style="width:{{ tp_progress }}%"></div>
                </div>
              </div>
            {%- else -%}
              <div class="tp-ship-bar tp-ship-bar--static">
                <div class="tp-ship-bar__text">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                  <span>Free shipping on qualifying orders over <strong>$60 USD</strong></span>
                </div>
              </div>
            {%- endif -%}
          {%- endif -%}

          <!-- Multi-buy -->
          {%- if section.settings.multibuy_text != blank -%}
            <div class="tp-multibuy">
              <span class="tp-multibuy__emoji">🐾</span>
              <span>{{ section.settings.multibuy_text }}</span>
            </div>
          {%- endif -%}

          <!-- Bundle upsell -->
          {%- if section.settings.upsell_title != blank -%}
            <div class="tp-upsell">
              <span class="tp-upsell__icon">🎁</span>
              <div class="tp-upsell__body">
                <div class="tp-upsell__title">{{ section.settings.upsell_title }}</div>
                {%- if section.settings.upsell_text != blank -%}
                  <div class="tp-upsell__text">{{ section.settings.upsell_text }}</div>
                {%- endif -%}
              </div>
              {%- if section.settings.upsell_link_url != blank -%}
                <a href="{{ section.settings.upsell_link_url }}" class="tp-upsell__btn">{{ section.settings.upsell_link_text | default: 'Add' }}</a>
              {%- endif -%}
            </div>
          {%- endif -%}

          <!-- Add to Cart -->
          <div class="tp-cta">
            <button type="submit" name="add" id="tp-add-btn" class="tp-btn-cart"
              {% unless tp_variant.available %}disabled{% endunless %}>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
              <span id="tp-btn-text">
                {%- if tp_variant.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
              </span>
            </button>
          </div>

          <!-- Trust badges -->
          {%- if section.settings.show_trust_badges -%}
            <div class="tp-trust">
              <div class="tp-trust__item">
                <svg class="tp-trust__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                <span>{{ section.settings.trust_1 | default: 'Secure Checkout' }}</span>
              </div>
              <div class="tp-trust__item">
                <svg class="tp-trust__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 15L3 9l6-6"/><path d="M3 9h12a6 6 0 0 1 0 12H9"/></svg>
                <span>{{ section.settings.trust_2 | default: 'Easy Returns' }}</span>
              </div>
              <div class="tp-trust__item">
                <svg class="tp-trust__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                <span>{{ section.settings.trust_3 | default: 'Track Your Order' }}</span>
              </div>
              <div class="tp-trust__item">
                <svg class="tp-trust__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                <span>{{ section.settings.trust_4 | default: 'Pet-Friendly Pick' }}</span>
              </div>
            </div>
          {%- endif -%}

        </div>
        <!-- /info panel -->

      </div>
    </div>

  {%- endform -%}

  <!-- ======== FEATURE ROWS / DESCRIPTION ======== -->
  {%- assign tp_has_feat = false -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'feature_row' -%}{%- assign tp_has_feat = true -%}{%- break -%}{%- endif -%}
  {%- endfor -%}

  {%- assign tp_desc_norm   = tp_product.description | replace: '<hr/>', '<hr>' | replace: '<hr />', '<hr>' -%}
  {%- assign tp_desc_parts  = tp_desc_norm | split: '<hr>' -%}
  {%- assign tp_desc_rows   = false -%}
  {%- if tp_desc_parts.size > 1 -%}{%- assign tp_desc_rows = true -%}{%- endif -%}

  {%- if tp_has_feat -%}
    <div class="tp-feat">
      {%- for block in section.blocks -%}
        {%- if block.type != 'feature_row' -%}{%- continue -%}{%- endif -%}
        {%- assign tp_fr_cls = 'tp-feat__row' -%}
        {%- if block.settings.layout == 'image_right' -%}
          {%- assign tp_fr_cls = 'tp-feat__row tp-feat__row--reverse' -%}
        {%- endif -%}
        <div class="{{ tp_fr_cls }}" {{ block.shopify_attributes }}>

          {%- if block.settings.image != blank -%}
            <div class="tp-feat__img-wrap">
              {{- block.settings.image | image_url: width: 900 | image_tag:
                    class: 'tp-feat__img',
                    alt: block.settings.title,
                    loading: 'lazy',
                    widths: '450, 600, 900',
                    sizes: '(max-width: 749px) 100vw, 45vw'
              -}}
            </div>
          {%- endif -%}

          <div class="tp-feat__content">
            {%- if block.settings.eyebrow != blank -%}
              <span class="tp-feat__eyebrow">{{ block.settings.eyebrow | escape }}</span>
            {%- endif -%}
            {%- if block.settings.title != blank -%}
              <h3 class="tp-feat__title">{{ block.settings.title | escape }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <div class="tp-feat__body">{{ block.settings.text }}</div>
            {%- endif -%}
            {%- assign tp_fr_bullets = block.settings.bullet_1 | append: '|||' | append: block.settings.bullet_2 | append: '|||' | append: block.settings.bullet_3 | append: '|||' | append: block.settings.bullet_4 -%}
            {%- assign tp_fr_bullet_arr = tp_fr_bullets | split: '|||' -%}
            {%- assign tp_fr_has_bullets = false -%}
            {%- for b in tp_fr_bullet_arr -%}
              {%- unless b == blank -%}{%- assign tp_fr_has_bullets = true -%}{%- break -%}{%- endunless -%}
            {%- endfor -%}
            {%- if tp_fr_has_bullets -%}
              <ul class="tp-feat__bullets">
                {%- for b in tp_fr_bullet_arr -%}
                  {%- if b == blank -%}{%- continue -%}{%- endif -%}
                  <li class="tp-feat__bullet">
                    <svg class="tp-feat__check" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <circle cx="10" cy="10" r="8.5" stroke="currentColor" stroke-width="2"/>
                      <polyline points="6.5 10 9 12.5 13.5 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span>{{ b | escape }}</span>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>

        </div>
      {%- endfor -%}
    </div>
  {%- elsif tp_desc_rows -%}
    <div class="tp-feat">
      {%- for tp_part in tp_desc_parts -%}
        {%- assign tp_part_clean = tp_part | strip -%}
        {%- if tp_part_clean == blank -%}{%- continue -%}{%- endif -%}
        {%- assign tp_feat_img = tp_product.images[forloop.index] -%}
        {%- assign tp_row_reverse = false -%}
        {%- assign tp_mod = forloop.index0 | modulo: 2 -%}
        {%- if tp_mod == 1 -%}{%- assign tp_row_reverse = true -%}{%- endif -%}
        <div class="tp-feat__row{% if tp_row_reverse %} tp-feat__row--reverse{% endif %}">
          {%- if tp_feat_img != blank -%}
            <div class="tp-feat__img-wrap">
              {{- tp_feat_img | image_url: width: 900 | image_tag:
                    class: 'tp-feat__img',
                    alt: tp_product.title,
                    loading: 'lazy',
                    widths: '450, 600, 900',
                    sizes: '(max-width: 749px) 100vw, 45vw'
              -}}
            </div>
          {%- endif -%}
          <div class="tp-feat__content">
            <div class="tp-feat__body">{{ tp_part_clean }}</div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  {%- elsif tp_product.description != blank -%}
    <div class="tp-desc-section">
      <div class="tp-description">{{ tp_product.description }}</div>
    </div>
  {%- endif -%}

  <!-- ======== LOWER CONTENT ======== -->
  <div class="tp-lower">

    {%- if section.settings.show_accordions -%}
      <div class="tp-accordions">
        {%- assign tp_acc_ids   = 'accordion_1,accordion_2,accordion_3,accordion_4,accordion_5' | split: ',' -%}
        {%- assign tp_acc_icons = '📋,🚚,🐾,💡,📦' | split: ',' -%}
        {%- for acc in tp_acc_ids -%}
          {%- assign tp_at = acc | append: '_title' -%}
          {%- assign tp_ab = acc | append: '_content' -%}
          {%- assign tp_ae = tp_acc_icons[forloop.index0] -%}
          {%- assign tp_at_val = section.settings[tp_at] -%}
          {%- assign tp_ab_val = section.settings[tp_ab] -%}
          {%- if tp_at_val != blank and tp_ab_val != blank -%}
            <details class="tp-acc">
              <summary>
                <span class="tp-acc__label">
                  <span aria-hidden="true">{{ tp_ae }}</span>{{ tp_at_val }}
                </span>
                <svg class="tp-acc__chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="tp-acc__body">{{ tp_ab_val }}</div>
            </details>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>

  <!-- ======== PRODUCT STORY ======== -->
  {%- assign tp_has_story = false -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'story_card' -%}{%- assign tp_has_story = true -%}{%- endif -%}
  {%- endfor -%}

  {%- if tp_has_story -%}
    <div class="tp-story">
      {%- if section.settings.story_heading != blank -%}
        <h2 class="tp-story__heading">{{ section.settings.story_heading }}</h2>
      {%- endif -%}
      <div class="tp-story__grid">
        {%- for block in section.blocks -%}
          {%- if block.type != 'story_card' -%}{%- continue -%}{%- endif -%}
          <div class="tp-story__card" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {%- assign tp_sc_alt = block.settings.image.alt | default: block.settings.title | escape -%}
              {{- block.settings.image | image_url: width: 600 | image_tag: class: 'tp-story__img', alt: tp_sc_alt, loading: 'lazy', width: 600, height: 450 -}}
            {%- endif -%}
            <div class="tp-story__card-body">
              {%- if block.settings.emoji != blank -%}
                <span class="tp-story__emoji" aria-hidden="true">{{ block.settings.emoji }}</span>
              {%- endif -%}
              {%- if block.settings.title != blank -%}
                <div class="tp-story__card-title">{{ block.settings.title }}</div>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div class="tp-story__card-text">{{ block.settings.text }}</div>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  <!-- ======== SPECS ======== -->
  {%- assign tp_has_specs = false -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'spec_row' -%}{%- assign tp_has_specs = true -%}{%- endif -%}
  {%- endfor -%}

  {%- if tp_has_specs -%}
    <div class="tp-specs">
      {%- if section.settings.specs_heading != blank -%}
        <h2 class="tp-specs__heading">{{ section.settings.specs_heading }}</h2>
      {%- endif -%}
      <div class="tp-specs__table">
        {%- for block in section.blocks -%}
          {%- if block.type != 'spec_row' -%}{%- continue -%}{%- endif -%}
          <div class="tp-specs__row" {{ block.shopify_attributes }}>
            <div class="tp-specs__key">{{ block.settings.spec_key }}</div>
            <div class="tp-specs__val">{{ block.settings.spec_val }}</div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  <!-- ======== RELATED PRODUCTS ======== -->
  {%- if section.settings.show_related -%}
    {%- assign tp_rel_col = collections[section.settings.related_collection] -%}
    {%- if tp_rel_col == blank and tp_product.collections.size > 0 -%}
      {%- assign tp_rel_col = tp_product.collections.first -%}
    {%- endif -%}
    {%- if tp_rel_col != blank -%}
      {%- assign tp_rel_lim = section.settings.related_count -%}
      {%- assign tp_rel_cnt = 0 -%}
      {%- for rp in tp_rel_col.products -%}
        {%- if rp.handle != tp_product.handle -%}
          {%- assign tp_rel_cnt = tp_rel_cnt | plus: 1 -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if tp_rel_cnt > 0 -%}
        <div class="tp-related">
          <h2 class="tp-related__heading">{{ section.settings.related_heading }}</h2>
          <div class="tp-related__grid">
            {%- assign tp_shown = 0 -%}
            {%- for rp in tp_rel_col.products -%}
              {%- if rp.handle == tp_product.handle -%}{%- continue -%}{%- endif -%}
              {%- if tp_shown >= tp_rel_lim -%}{%- break -%}{%- endif -%}
              {%- assign tp_shown = tp_shown | plus: 1 -%}
              {%- assign tp_rp_sale = false -%}
              {%- if rp.compare_at_price > rp.price -%}{%- assign tp_rp_sale = true -%}{%- endif -%}
              {%- assign tp_rp_alt = rp.featured_image.alt | default: rp.title | escape -%}
              <a href="{{ rp.url }}" class="tp-rel-card">
                <div class="tp-rel-card__img-wrap">
                  {{- rp.featured_image | image_url: width: 500 | image_tag: class: 'tp-rel-card__img', alt: tp_rp_alt, loading: 'lazy', width: 500, height: 500 -}}
                </div>
                <div class="tp-rel-card__body">
                  <div class="tp-rel-card__title">{{ rp.title }}</div>
                  <div class="tp-rel-card__price{% if tp_rp_sale %} tp-rel-card__price--sale{% endif %}">
                    {{ rp.price | money }}
                    {%- if tp_rp_sale -%}<span class="tp-rel-card__compare">{{ rp.compare_at_price | money }}</span>{%- endif -%}
                  </div>
                  <span class="tp-rel-card__btn">View Product</span>
                </div>
              </a>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    {%- endif -%}
  {%- endif -%}

  <!-- ======== FAQ ======== -->
  {%- assign tp_has_faq = false -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'faq_item' -%}{%- assign tp_has_faq = true -%}{%- endif -%}
  {%- endfor -%}

  {%- if tp_has_faq -%}
    <div class="tp-faq">
      <h2 class="tp-faq__heading">{{ section.settings.faq_heading | default: 'Common Questions' }}</h2>
      <svg class="tp-faq__wave" viewBox="0 0 180 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M2 9 C 30 2, 60 16, 90 9 S 150 2, 178 9" stroke="var(--pc-green, #2eaa5f)" stroke-width="5" stroke-linecap="round" fill="none"/>
      </svg>
      <div class="tp-faq__items">
        {%- for block in section.blocks -%}
          {%- if block.type != 'faq_item' -%}{%- continue -%}{%- endif -%}
          <details class="tp-acc" {{ block.shopify_attributes }}>
            <summary>
              <span>{{ block.settings.question }}</span>
              <svg class="tp-acc__chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="tp-acc__body">{{ block.settings.answer }}</div>
          </details>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  <div class="tp-section-end"></div>

</section>

<!-- Sticky mobile bar (outside section, fixed position) -->
<div class="tp-sticky-bar tp-hidden" id="tp-sticky" aria-hidden="true">
  <div class="tp-sticky-bar__info">
    <div class="tp-sticky-bar__title">{{ tp_product.title | truncate: 42 }}</div>
    <div class="tp-sticky-bar__price{% if tp_on_sale %} tp-sticky-bar__price--sale{% endif %}" id="tp-sticky-price">
      {{ tp_variant.price | money }}
    </div>
  </div>
  <button type="button" class="tp-sticky-bar__btn" id="tp-sticky-btn">Add to Cart</button>
</div>

<script>
  /* Variant data injected server-side for accurate availability / price checks */
  window.tpProductData = {
    handle: {{ product.handle | json }},
    variants: [
      {%- for v in product.variants -%}
        {%- assign _vsave = '' -%}
        {%- if v.compare_at_price > v.price -%}
          {%- assign _vsave = v.compare_at_price | minus: v.price | money -%}
        {%- endif -%}
        {"id":{{ v.id }},"title":{{ v.title | json }},"available":{{ v.available }},"price":{{ v.price }},"compare_at_price":{{ v.compare_at_price | default: 0 }},"price_html":{{ v.price | money | json }},"compare_at_price_html":{{ v.compare_at_price | default: 0 | money | json }},"save_html":{{ _vsave | json }},"inventory_quantity":{{ v.inventory_quantity }},"inventory_policy":{{ v.inventory_policy | json }},"inventory_management":{{ v.inventory_management | json }},"option1":{{ v.option1 | json }},"option2":{{ v.option2 | json }},"option3":{{ v.option3 | json }}}
        {%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
  };

(function () {
  /* --- Qty stepper --- */
  var qty = document.getElementById('tp-qty');
  document.getElementById('tp-minus').addEventListener('click', function () { var v = parseInt(qty.value,10); if (v > 1) qty.value = v - 1; });
  document.getElementById('tp-plus').addEventListener('click', function () { qty.value = parseInt(qty.value,10) + 1; });

  /* --- Gallery thumbnails --- */
  var mainImg = document.getElementById('tp-main-img');

  function tpSwapImage(img, src, alt) {
    if (!img || !src) return;
    img.classList.add('tp-fade');
    setTimeout(function () {
      /* Shopify image_tag outputs srcset — browsers prefer srcset over src,
         so we must clear both attributes before assigning the new src,
         otherwise the displayed image never changes. */
      img.removeAttribute('srcset');
      img.removeAttribute('sizes');
      img.src = src;
      if (alt) img.alt = alt;
      img.classList.remove('tp-fade');
    }, 180);
  }

  var allThumbs = Array.from(document.querySelectorAll('.tp-gallery__thumb'));
  allThumbs.forEach(function (thumb) {
    thumb.addEventListener('click', function () {
      allThumbs.forEach(function (t) { t.classList.remove('tp-active'); });
      thumb.classList.add('tp-active');
      var thumbImg = thumb.querySelector('img');
      tpSwapImage(mainImg, thumb.getAttribute('data-src'), thumbImg ? thumbImg.alt : null);
    });
  });

  /* --- Variant pills --- */
  var varSel = document.getElementById('tp-variant-select');
  var selOpts = [];
  if (varSel) {
    var initOpt = varSel.options[varSel.selectedIndex];
    if (initOpt) {
      initOpt.text.split(' / ').forEach(function (v, i) { selOpts[i] = v.trim(); });
    }
  }

  /* Fallback: if the Liquid-rendered hidden input is absent from DOM (CDN cache lag),
     create it dynamically so cart add always has a valid variant id */
  if (!document.getElementById('tp-variant-id')) {
    var fEl = document.getElementById('tp-form');
    if (fEl) {
      var inp = document.createElement('input');
      inp.type  = 'hidden';
      inp.name  = 'id';
      inp.id    = 'tp-variant-id';
      inp.value = varSel ? varSel.value : '';
      fEl.insertBefore(inp, fEl.firstChild);
    }
  }

  /* Count how many option groups exist (1–3) */
  var numOptionGroups = document.querySelectorAll('.tp-option-group').length;

  /* Returns true if ANY real variant can be formed with `value` at `optionIndex`
     combined with the current selections in all other option groups.            */
  function canSelect(optionIndex, value) {
    var tvArr = (window.tpProductData && window.tpProductData.variants) || [];
    return tvArr.some(function (tv) {
      if (!tv.available) return false;
      for (var j = 0; j < numOptionGroups; j++) {
        var tv_val = tv['option' + (j + 1)];
        if (j === optionIndex) {
          if (tv_val !== value) return false;
        } else {
          if (selOpts[j] && tv_val !== selOpts[j]) return false;
        }
      }
      return true;
    });
  }

  /* Exact-match: find the one variant where option1/2/3 all equal selOpts[0/1/2]. */
  function findExactVariant() {
    var tvArr = (window.tpProductData && window.tpProductData.variants) || [];
    for (var i = 0; i < tvArr.length; i++) {
      var tv = tvArr[i];
      var match = true;
      for (var j = 0; j < numOptionGroups; j++) {
        if (tv['option' + (j + 1)] !== selOpts[j]) { match = false; break; }
      }
      if (match) return tv;
    }
    return null;
  }

  /* Mark pills that can't form any real variant as tp-unavailable.
     If a selected pill becomes unavailable, deselects it and auto-picks
     the first still-available value in that group.                      */
  function updatePillAvailability() {
    document.querySelectorAll('.tp-option-group').forEach(function (group) {
      var gIdx = parseInt(group.getAttribute('data-option-index'), 10);
      var pills = group.querySelectorAll('.tp-pill');

      pills.forEach(function (pill) {
        var val = pill.getAttribute('data-value');
        var ok  = canSelect(gIdx, val);
        pill.classList.toggle('tp-unavailable', !ok);
        if (!ok) {
          pill.setAttribute('aria-disabled', 'true');
          if (pill.classList.contains('tp-selected')) {
            pill.classList.remove('tp-selected');
            pill.setAttribute('aria-pressed', 'false');
            selOpts[gIdx] = null;
            var lbl = document.getElementById('tp-sel-' + gIdx);
            if (lbl) lbl.textContent = '';
          }
        } else {
          pill.removeAttribute('aria-disabled');
        }
      });

      /* Auto-select first available pill when group has no selection */
      if (!selOpts[gIdx]) {
        pills.forEach(function (pill) {
          if (!selOpts[gIdx] && !pill.classList.contains('tp-unavailable')) {
            pill.classList.add('tp-selected');
            pill.setAttribute('aria-pressed', 'true');
            selOpts[gIdx] = pill.getAttribute('data-value');
            var lbl = document.getElementById('tp-sel-' + gIdx);
            if (lbl) lbl.textContent = selOpts[gIdx];
          }
        });
      }
    });
  }

  document.querySelectorAll('.tp-option-group').forEach(function (group) {
    var idx = parseInt(group.getAttribute('data-option-index'), 10);
    group.querySelectorAll('.tp-pill').forEach(function (pill) {
      pill.addEventListener('click', function () {
        if (pill.classList.contains('tp-unavailable')) return;
        group.querySelectorAll('.tp-pill').forEach(function (p) {
          p.classList.remove('tp-selected');
          p.setAttribute('aria-pressed', 'false');
        });
        pill.classList.add('tp-selected');
        pill.setAttribute('aria-pressed', 'true');
        selOpts[idx] = pill.getAttribute('data-value');
        var lbl = document.getElementById('tp-sel-' + idx);
        if (lbl) lbl.textContent = selOpts[idx];
        updatePillAvailability();
        updateVariant();
      });
    });
  });

  function updateVariant() {
    var variantInput = document.getElementById('tp-variant-id');
    var addBtn       = document.getElementById('tp-add-btn');
    var btnText      = document.getElementById('tp-btn-text');
    var stickyBtn    = document.getElementById('tp-sticky-btn');
    var msgEl        = document.getElementById('tp-variant-msg');

    var matched = findExactVariant();

    if (!matched) {
      /* No exact variant — clear hidden input so it can never reach cart */
      if (variantInput) variantInput.value = '';
      if (addBtn)    { addBtn.disabled = true; }
      if (btnText)   { btnText.textContent = 'Unavailable'; }
      if (stickyBtn) { stickyBtn.disabled = true; stickyBtn.textContent = 'Unavailable'; }
      if (msgEl)     { msgEl.textContent = 'This combination is not available.'; msgEl.style.display = ''; }
      return;
    }

    /* Sync hidden input with exact variant */
    if (variantInput) {
      variantInput.value = matched.id;
      variantInput.dispatchEvent(new Event('change', { bubbles: true }));
    }

    /* Sync native select for data-img / data-alt lookup */
    if (varSel) {
      for (var si = 0; si < varSel.options.length; si++) {
        if (varSel.options[si].value === String(matched.id)) {
          varSel.selectedIndex = si;
          break;
        }
      }
    }

    var avail   = matched.available;
    var price   = matched.price;
    var compare = matched.compare_at_price || 0;
    var onSale  = compare > price;

    /* Clear any previous message */
    if (msgEl) { msgEl.textContent = ''; msgEl.style.display = 'none'; }

    /* Price display */
    var priceEl   = document.getElementById('tp-price');
    var compareEl = document.getElementById('tp-compare');
    var savingsEl = document.getElementById('tp-savings');
    if (priceEl)   { priceEl.textContent = matched.price_html; priceEl.classList.toggle('tp-price--sale', onSale); }
    if (compareEl) { compareEl.textContent = onSale ? matched.compare_at_price_html : ''; compareEl.style.display = onSale ? '' : 'none'; }
    if (savingsEl) { savingsEl.textContent = onSale ? 'Save ' + matched.save_html : ''; savingsEl.style.display = onSale ? '' : 'none'; }

    /* Sticky price */
    var sp = document.getElementById('tp-sticky-price');
    if (sp) { sp.textContent = matched.price_html; sp.classList.toggle('tp-sticky-bar__price--sale', onSale); }

    /* Button state */
    if (addBtn)    { addBtn.disabled = !avail; }
    if (btnText)   { btnText.textContent = avail ? 'Add to Cart' : 'Sold Out'; }
    if (stickyBtn) { stickyBtn.disabled = !avail; stickyBtn.textContent = avail ? 'Add to Cart' : 'Sold Out'; }
    if (!avail && msgEl) { msgEl.textContent = 'This variant is currently sold out.'; msgEl.style.display = ''; }

    /* Variant image */
    var varSelOpt = varSel && varSel.options[varSel.selectedIndex];
    var imgSrc = varSelOpt ? varSelOpt.getAttribute('data-img') : null;
    var imgAlt = varSelOpt ? varSelOpt.getAttribute('data-alt') : null;
    if (mainImg && imgSrc) {
      tpSwapImage(mainImg, imgSrc, imgAlt);
      document.querySelectorAll('.tp-gallery__thumb').forEach(function (t) {
        t.classList.toggle('tp-active', t.getAttribute('data-src') === imgSrc);
      });
    }
  }

  /* Run on page load to disable impossible pills and sync state */
  updatePillAvailability();
  updateVariant();

  /* Add to cart handled by the ES module below — needs CartLinesUpdateEvent from @shopify/events */

  /* --- Sticky bar visibility --- */
  var stickyBar = document.getElementById('tp-sticky');
  var stickyBtn = document.getElementById('tp-sticky-btn');
  var addBtnEl  = document.getElementById('tp-add-btn');

  if (stickyBar && addBtnEl && 'IntersectionObserver' in window) {
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        stickyBar.classList.toggle('tp-hidden', entry.isIntersecting);
        stickyBar.setAttribute('aria-hidden', entry.isIntersecting ? 'true' : 'false');
      });
    }, { threshold: 0.5 });
    io.observe(addBtnEl);
  }

  if (stickyBtn) {
    stickyBtn.addEventListener('click', function () { if (addBtnEl) addBtnEl.click(); });
  }

  /* --- Sticky gallery: set top = actual header height + 16px gap ---
     CSS top:20px is a safe fallback; JS overrides it on load so the
     gallery never disappears under the header regardless of its height. */
  var tpGallery = document.querySelector('.tp-gallery');
  if (tpGallery && window.matchMedia('(min-width: 900px)').matches) {
    function updateGalleryTop() {
      /* Try common Horizon / Shopify header selectors, widest to narrowest */
      var hdr = document.querySelector('#shopify-section-header .header__wrapper')
             || document.querySelector('.header-wrapper')
             || document.querySelector('header.header')
             || document.querySelector('#shopify-section-header')
             || document.querySelector('header');
      if (hdr) {
        var h = hdr.getBoundingClientRect().height;
        tpGallery.style.top = Math.max(Math.round(h) + 16, 20) + 'px';
      }
    }
    updateGalleryTop();
    var _galResizeTick;
    window.addEventListener('resize', function () {
      clearTimeout(_galResizeTick);
      _galResizeTick = setTimeout(updateGalleryTop, 120);
    });
  }

}());
</script>

<script type="module">
import { CartLinesUpdateEvent } from '@shopify/events';

(function () {
  var form = document.getElementById('tp-form');
  if (!form) return;

  form.addEventListener('submit', async function (e) {
    e.preventDefault();

    var addBtn  = document.getElementById('tp-add-btn');
    var btnText = document.getElementById('tp-btn-text');
    if (addBtn && addBtn.disabled) return;
    if (addBtn) addBtn.disabled = true;
    if (btnText) btnText.textContent = 'Adding…';

    var hiddenIdEl  = document.getElementById('tp-variant-id');
    var qty         = document.getElementById('tp-qty') || { value: '1' };
    var cartVarId   = hiddenIdEl ? hiddenIdEl.value.trim() : '';
    var variantNum  = Number(cartVarId);
    var qtyVal      = parseInt(qty.value, 10) || 1;

    /* Pre-submit: variant ID must be set and valid */
    if (!variantNum) {
      if (btnText) btnText.textContent = 'Select options first';
      setTimeout(function () { if (addBtn) addBtn.disabled = false; if (btnText) btnText.textContent = 'Add to Cart'; }, 2500);
      return;
    }

    /* Pre-submit: variant must exist in tpProductData and be available */
    var tvArr2 = (window.tpProductData && window.tpProductData.variants) || [];
    var foundV = null;
    for (var fi = 0; fi < tvArr2.length; fi++) {
      if (String(tvArr2[fi].id) === String(variantNum)) { foundV = tvArr2[fi]; break; }
    }
    if (!foundV) {
      if (btnText) btnText.textContent = 'Invalid selection';
      setTimeout(function () { if (addBtn) addBtn.disabled = false; if (btnText) btnText.textContent = 'Add to Cart'; }, 2500);
      return;
    }
    if (!foundV.available) {
      if (btnText) btnText.textContent = 'Sold Out';
      setTimeout(function () { if (addBtn) addBtn.disabled = false; if (btnText) btnText.textContent = 'Sold Out'; }, 2500);
      return;
    }

    /* sections_url tells Shopify to render the section in the current page's template context
       (product page), NOT in the cart endpoint context where template.name == 'cart' and
       the cart-drawer snippet would silently render nothing due to its own condition check. */
    var payload = {
      id:           variantNum,
      quantity:     qtyVal,
      sections:     'cart-drawer-section',
      sections_url: window.location.pathname,
    };

    /* Create the deferred promise — cart-drawer, cart-icon, cart-items all await this */
    var deferred = CartLinesUpdateEvent.createPromise();

    /* Dispatch BEFORE the fetch — this is the contract Horizon expects */
    form.dispatchEvent(new CartLinesUpdateEvent({
      action:  'add',
      context: 'product',
      lines:   [{ merchandiseId: String(variantNum), quantity: qtyVal }],
      promise: deferred.promise,
    }));

    try {
      var r    = await fetch('/cart/add.js', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body:    JSON.stringify(payload),
      });
      var data = await r.json();

      if (!r.ok) {
        var errDesc = (data.description || data.message) || ('HTTP ' + r.status);
        if (btnText) btnText.textContent = String(errDesc).slice(0, 50);
        setTimeout(function () { if (addBtn) addBtn.disabled = false; if (btnText) btnText.textContent = 'Add to Cart'; }, 4000);

        /* Resolve with error flag — drawer stays closed, icon count unchanged */
        deferred.resolve({ cart: { totalQuantity: 0, lines: [] }, detail: { didError: true } });
        return;
      }

      /* ── SUCCESS ─────────────────────────────────────────────────────── */

      /* Use sections from the add response when available.
         If missing (e.g. Shopify rendered an empty section), fetch separately
         using the current product-page URL as context so template.name == 'product'. */
      var sectionsHtml = (data.sections && data.sections['cart-drawer-section'])
        ? data.sections
        : await fetch(window.location.pathname + '?sections=cart-drawer-section')
            .then(function (res) { return res.json(); })
            .catch(function () { return {}; });

      var cartResp = await fetch('/cart.js');
      var cart     = await cartResp.json();

      refreshFreeShippingBars();

      deferred.resolve({
        cart: CartLinesUpdateEvent.createCartFromAjaxResponse(cart),
        detail: {
          items:     cart.items,
          source:    'tailand-product',
          itemCount: cart.item_count,
          sections:  sectionsHtml,
          didError:  false,
        },
      });

      if (btnText) btnText.textContent = 'Added!';
      setTimeout(function () { if (addBtn) addBtn.disabled = false; if (btnText) btnText.textContent = 'Add to Cart'; }, 2000);

      /* Fallback open: if auto_open_cart_drawer setting is disabled, open the drawer manually.
         Wait two animation frames so the morph from deferred.resolve can complete first. */
      var drawerComp = document.querySelector('cart-drawer-component');
      if (drawerComp && !drawerComp.hasAttribute('auto-open')) {
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            var drawer = document.querySelector('theme-drawer#cart-drawer');
            if (drawer && typeof drawer.open === 'function') drawer.open();
          });
        });
      }

    } catch (err) {
      if (btnText) btnText.textContent = 'Connection error – retry';
      setTimeout(function () { if (addBtn) addBtn.disabled = false; if (btnText) btnText.textContent = 'Add to Cart'; }, 3000);
      deferred.reject(err);
    }
  });

  // ── Free-shipping bar live update (Section Rendering API) ──────────────
  // Re-renders the bar server-side so Liquid's |money filter applies the
  // correct presentment currency (CZK, EUR, USD …) automatically.
  function refreshFreeShippingBars() {
    var sectionId = '{{ section.id }}';
    fetch(window.location.pathname + '?sections=' + encodeURIComponent(sectionId))
      .then(function (r) { return r.ok ? r.json() : null; })
      .then(function (json) {
        if (!json || !json[sectionId]) return;
        var temp = document.createElement('div');
        temp.innerHTML = json[sectionId];
        var bars    = document.querySelectorAll('[data-free-shipping-progress]');
        var newBars = temp.querySelectorAll('[data-free-shipping-progress]');
        bars.forEach(function (bar, i) {
          var newBar = newBars[i];
          if (!newBar) return;
          var fill    = bar.querySelector('[data-free-shipping-bar]');
          var newFill = newBar.querySelector('[data-free-shipping-bar]');
          if (fill && newFill) fill.style.width = newFill.style.width;
          var msg    = bar.querySelector('[data-free-shipping-message]');
          var newMsg = newBar.querySelector('[data-free-shipping-message]');
          if (msg && newMsg) msg.innerHTML = newMsg.innerHTML;
        });
      })
      .catch(function () {});
  }

  // Also update when the cart drawer changes quantity or removes a line.
  document.addEventListener('CartLinesUpdateEvent', async function (e) {
    try {
      var result = await (e && e.detail && e.detail.promise);
      if (result && result.detail && result.detail.didError) return;
      refreshFreeShippingBars();
    } catch (_) {}
  });
}());
</script>

