  {%- endif -%}

  <!-- ======== RELATED PRODUCTS ======== -->
  {%- if section.settings.show_related -%}
    {%- assign tp_rel_col = collections[section.settings.related_collection] -%}
    {%- if tp_rel_col == blank and tp_product.collections.size > 0 -%}
      {%- assign tp_rel_col = tp_product.collections.first -%}
    {%- endif -%}
    {%- if tp_rel_col != blank -%}
      {%- assign tp_rel_lim = section.settings.related_count -%}
      {%- assign tp_rel_cnt = 0 -%}
      {%- for rp in tp_rel_col.products -%}
        {%- if rp.handle != tp_product.handle -%}
          {%- assign tp_rel_cnt = tp_rel_cnt | plus: 1 -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if tp_rel_cnt > 0 -%}
        <div class="tp-related">
          <h2 class="tp-related__heading">
            {%- if section.settings.related_heading != blank -%}
              <span class="tp-related__heading-plain">{{- section.settings.related_heading | escape }}&nbsp;</span>
            {%- endif -%}
            {%- if section.settings.related_heading_highlight != blank -%}
              <span class="tp-related__heading-hl">
                {{- section.settings.related_heading_highlight | escape -}}
                <svg class="tp-related__heading-line" viewBox="0 0 300 14" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                  <path d="M4 10 C40 5 80 12 140 7 C200 2 240 11 296 8" stroke="currentColor" stroke-width="6" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            {%- endif -%}
          </h2>
          <ul class="plt-grid" role="list">
            {%- assign tp_shown = 0 -%}
            {%- for rp in tp_rel_col.products -%}
              {%- if rp.handle == tp_product.handle -%}{%- continue -%}{%- endif -%}
              {%- if tp_shown >= tp_rel_lim -%}{%- break -%}{%- endif -%}
              {%- assign tp_shown = tp_shown | plus: 1 -%}
              {%- assign tp_rp_sale = false -%}
              {%- if rp.compare_at_price > rp.price -%}{%- assign tp_rp_sale = true -%}{%- endif -%}
              {%- assign tp_rp_alt = rp.featured_image.alt | default: rp.title | escape -%}
              <li class="plt-card">
                <div class="plt-card__media-wrap">
                  <a href="{{ rp.url }}" class="plt-card__media-link" aria-hidden="true" tabindex="-1">
                    {%- if rp.featured_image -%}
                      {{- rp.featured_image
                          | image_url: width: 600
                          | image_tag:
                              class: 'plt-card__img',
                              alt: tp_rp_alt,
                              widths: '300, 450, 600',
                              sizes: '(max-width: 749px) calc(50vw - 20px), (max-width: 1199px) calc(33vw - 24px), 280px',
                              loading: 'lazy'
                      -}}
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'plt-card__img plt-card__img--placeholder' }}
                    {%- endif -%}
                  </a>
                  {%- if tp_rp_sale -%}
                    <div class="plt-badge-group">
                      <span class="plt-sale-badge">SALE</span>
                    </div>
                  {%- endif -%}
                </div>
                <div class="plt-card__body">
                  <a href="{{ rp.url }}" class="plt-card__title-link">
                    <h3 class="plt-card__title">{{ rp.title | escape }}</h3>
                  </a>
                  <div class="plt-card__price">
                    {%- if tp_rp_sale -%}
                      <span class="plt-card__price-sale">{{ rp.price | money }}</span>
                      <span class="plt-card__price-compare">{{ rp.compare_at_price | money }}</span>
                    {%- else -%}
                      <span class="plt-card__price-reg">{{ rp.price | money }}</span>
                    {%- endif -%}
                  </div>
                  <a href="{{ rp.url }}" class="plt-card__btn">
                    Shop Now<svg aria-hidden="true" focusable="false" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                  </a>
                </div>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
    {%- endif -%}
  {%- endif -%}

  <!-- ======== RECENTLY VIEWED ======== -->
  {%- if section.settings.show_recently_viewed -%}
    <div class="tp-related" id="tp-recent" hidden>
      <h2 class="tp-related__heading">
        <span class="tp-related__heading-plain">Recently&nbsp;</span>
        <span class="tp-related__heading-hl">
          Viewed
          <svg class="tp-related__heading-line" viewBox="0 0 300 14" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
            <path d="M4 10 C40 5 80 12 140 7 C200 2 240 11 296 8" stroke="currentColor" stroke-width="6" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </h2>
      <ul class="plt-grid" role="list" id="tp-recent-grid"></ul>
    </div>

    <script type="module">
      import { RecentlyViewed } from '@theme/recently-viewed-products';

      (function () {
        var DATA_KEY = 'tcRecentlyViewedData';
        var SHOW = 4;
        var currentId = '{{ tp_product.id }}';
        var current = {
          handle: {{ tp_product.handle | json }},
          url: {{ tp_product.url | json }},
          title: {{ tp_product.title | json }},
          {%- if tp_product.featured_image -%}
            img: {{ tp_product.featured_image | image_url: width: 600 | json }},
            imgAlt: {{ tp_product.featured_image.alt | default: tp_product.title | json }},
          {%- else -%}
            img: null,
            imgAlt: '',
          {%- endif -%}
          priceCents: {{ tp_product.selected_or_first_available_variant.price | json }},
          compareCents: {{ tp_product.selected_or_first_available_variant.compare_at_price | default: 0 | json }},
          available: {{ tp_product.available | json }}
        };

        function loadData() { try { return JSON.parse(localStorage.getItem(DATA_KEY)) || {}; } catch (e) { return {}; } }
        function saveData(data) { try { localStorage.setItem(DATA_KEY, JSON.stringify(data)); } catch (e) {} }

        // The shared RecentlyViewed class (assets/recently-viewed-products.js)
        // is the single source of truth for which products were viewed and in
        // what order; it's fed on every product page via snippets/scripts.liquid.
        // This cache only stores the extra render fields (title/image/price)
        // keyed by the same product id, pruned to match the shared list.
        var data = loadData();
        // Liquid just rendered this data — it counts as freshly fetched.
        current.fetchedAt = Date.now();
        data[currentId] = current;

        var viewedIds = RecentlyViewed.getProducts();
        var keep = {};
        viewedIds.concat([currentId]).forEach(function (id) {
          if (data[id]) keep[id] = data[id];
        });
        saveData(keep);

        var items = viewedIds
          .filter(function (id) { return id !== currentId; })
          .map(function (id) { return keep[id]; })
          .filter(Boolean)
          .slice(0, SHOW);

        if (!items.length) return;

        function esc(s) { var d = document.createElement('div'); d.textContent = s == null ? '' : s; return d.innerHTML.replace(/"/g, '&quot;'); }

        var chevron = '<svg aria-hidden="true" focusable="false" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>';

        function cardHtml(it) {
          var sale = it.compareCents > it.priceCents;
          // Only false means sold out — entries cached before the availability
          // field existed are undefined and treated as available.
          var soldOut = it.available === false;
          // Cached URLs are the width=600 CDN variant; derive 300w for the
          // srcset so phones (grid cell ~50vw) don't download the 600px file.
          var imgHtml = '';
          if (it.img) {
            var srcsetAttr = '';
            if (it.img.indexOf('width=600') !== -1) {
              srcsetAttr = ' srcset="' + esc(it.img.replace('width=600', 'width=300')) + ' 300w, ' + esc(it.img) + ' 600w"' +
                ' sizes="(max-width: 749px) calc(50vw - 20px), (max-width: 1199px) calc(33vw - 24px), 280px"';
            }
            imgHtml = '<img class="plt-card__img" src="' + esc(it.img) + '"' + srcsetAttr + ' alt="' + esc(it.imgAlt) + '" loading="lazy" width="600" height="600">';
          }
          return '<li class="plt-card' + (soldOut ? ' plt-card--soldout' : '') + '">' +
            '<div class="plt-card__media-wrap">' +
              '<a href="' + esc(it.url) + '" class="plt-card__media-link" aria-hidden="true" tabindex="-1">' +
              imgHtml +
              '</a>' +
              (soldOut
                ? '<div class="plt-badge-group"><span class="plt-soldout-badge" aria-label="Sold out">SOLD OUT</span></div>'
                : (sale ? '<div class="plt-badge-group"><span class="plt-sale-badge">SALE</span></div>' : '')) +
            '</div>' +
            '<div class="plt-card__body">' +
              '<a href="' + esc(it.url) + '" class="plt-card__title-link"><h3 class="plt-card__title">' + esc(it.title) + '</h3></a>' +
              '<div class="plt-card__price">' +
                (sale
                  ? '<span class="plt-card__price-sale">' + window.tcMoney(it.priceCents) + '</span><span class="plt-card__price-compare">' + window.tcMoney(it.compareCents) + '</span>'
                  : '<span class="plt-card__price-reg">' + window.tcMoney(it.priceCents) + '</span>') +
              '</div>' +
              '<a href="' + esc(it.url) + '" class="plt-card__btn">' + (soldOut ? 'Notify me' : 'Shop Now') + chevron + '</a>' +
            '</div>' +
          '</li>';
        }

        var grid = document.getElementById('tp-recent-grid');
        function render() { grid.innerHTML = items.map(cardHtml).join(''); }
        render();
        document.getElementById('tp-recent').hidden = false;

        // The cached snapshot goes stale — prices change with sales, products
        // sell out. Refresh the shown items from the storefront product JSON
        // in the background and re-render only if something actually moved.
        // items[] entries are the same objects as keep[id], so mutating them
        // and saving keep persists the refresh. A 10-minute TTL per entry
        // skips the refetch on rapid back-and-forth browsing (up to 4 requests
        // saved per page view); prices rarely move faster than that, and any
        // change still lands on the next post-TTL view.
        var REFRESH_TTL = 600000;
        var tsNow = Date.now();
        var staleItems = items.filter(function (it) {
          return !it.fetchedAt || tsNow - it.fetchedAt > REFRESH_TTL;
        });
        if (!staleItems.length) return;
        Promise.all(staleItems.map(function (it) {
          return fetch('/products/' + it.handle + '.js')
            .then(function (r) { return r.ok ? r.json() : null; })
            .catch(function () { return null; });
        })).then(function (fresh) {
          var changed = false;
          fresh.forEach(function (p, i) {
            if (!p || !p.variants || !p.variants.length) return;
            var v = null;
            for (var j = 0; j < p.variants.length; j++) {
              if (p.variants[j].available) { v = p.variants[j]; break; }
            }
            v = v || p.variants[0];
            var it = staleItems[i];
            var upd = {
              title: p.title,
              url: '/products/' + p.handle,
              priceCents: v.price,
              compareCents: v.compare_at_price || 0,
              available: p.available
            };
            for (var k in upd) {
              if (it[k] !== upd[k]) { it[k] = upd[k]; changed = true; }
            }
            it.fetchedAt = tsNow;
          });
          if (changed) render();
          // Always persist: fetchedAt must survive so the TTL works across views.
          saveData(keep);
        });
      })();
    </script>
  {%- endif -%}

  <!-- ======== FAQ ======== -->
  {%- assign tp_has_faq = false -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'faq_item' -%}{%- assign tp_has_faq = true -%}{%- endif -%}
  {%- endfor -%}

  {%- if tp_has_faq -%}
    <div class="tp-faq">
      <h2 class="tp-faq__heading">{{ section.settings.faq_heading | default: 'Common Questions' }}</h2>
      <svg class="tp-faq__wave" viewBox="0 0 180 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M2 9 C 30 2, 60 16, 90 9 S 150 2, 178 9" stroke="var(--pc-green, #2eaa5f)" stroke-width="5" stroke-linecap="round" fill="none"/>
      </svg>
      <div class="tp-faq__items">
        {%- for block in section.blocks -%}
          {%- if block.type != 'faq_item' -%}{%- continue -%}{%- endif -%}
          <details class="tp-acc" {{ block.shopify_attributes }}>
            <summary>
              <span>{{ block.settings.question }}</span>
              <svg class="tp-acc__chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="tp-acc__body">{{ block.settings.answer }}</div>
          </details>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  <div class="tp-section-end"></div>

</section>

<!-- Sticky mobile bar (outside section, fixed position) -->
<div class="tp-sticky-bar tp-hidden" id="tp-sticky" aria-hidden="true">
  <div class="tp-sticky-bar__info">
    <div class="tp-sticky-bar__title">{{ tp_product.title | truncate: 42 }}</div>
    <div class="tp-sticky-bar__price{% if tp_on_sale %} tp-sticky-bar__price--sale{% endif %}" id="tp-sticky-price">
      {{ tp_variant.price | money }}
    </div>
  </div>
  <button type="button" class="tp-sticky-bar__btn" id="tp-sticky-btn">Add to Cart</button>
</div>

<script>
  /* Variant data injected server-side for accurate availability / price checks */
  window.tpProductData = {
    handle: {{ product.handle | json }},
    variants: [
      {%- for v in product.variants -%}
        {%- assign _vsave = '' -%}
        {%- if v.compare_at_price > v.price -%}
          {%- assign _vsave = v.compare_at_price | minus: v.price | money -%}
        {%- endif -%}
        {"id":{{ v.id }},"title":{{ v.title | json }},"available":{{ v.available }},"price":{{ v.price }},"compare_at_price":{{ v.compare_at_price | default: 0 }},"price_html":{{ v.price | money | json }},"compare_at_price_html":{{ v.compare_at_price | default: 0 | money | json }},"save_html":{{ _vsave | json }},"inventory_quantity":{{ v.inventory_quantity }},"inventory_policy":{{ v.inventory_policy | json }},"inventory_management":{{ v.inventory_management | json }},"option1":{{ v.option1 | json }},"option2":{{ v.option2 | json }},"option3":{{ v.option3 | json }}}
        {%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
  };

(function () {
  /* --- Qty stepper --- */
  var qty = document.getElementById('tp-qty');
  document.getElementById('tp-minus').addEventListener('click', function () { var v = parseInt(qty.value,10); if (v > 1) qty.value = v - 1; });
  document.getElementById('tp-plus').addEventListener('click', function () { qty.value = parseInt(qty.value,10) + 1; });

  /* --- Gallery thumbnails --- */
  var mainImg = document.getElementById('tp-main-img');

  /* Swap only after the new image is decoded, and only if no newer swap has
     been requested since (rapid thumbnail clicks) — the old image stays fully
     visible the whole time, so there is never a blank frame. */
  var tpSwapSeq = 0;
  function tpSwapImage(img, src, alt) {
    if (!img || !src) return;
    if (img.src === src && !img.hasAttribute('srcset')) return;
    var seq = ++tpSwapSeq;
    var apply = function () {
      if (seq !== tpSwapSeq) return;
      /* Shopify image_tag outputs srcset — browsers prefer srcset over src,
         so we must clear both attributes before assigning the new src,
         otherwise the displayed image never changes. */
      img.removeAttribute('srcset');
      img.removeAttribute('sizes');
      img.src = src;
      if (alt) img.alt = alt;
    };
    var pre = new Image();
    pre.onload = apply;
    /* Failed preload: keep the current image — swapping anyway would replace
       a good image with the broken-image icon. */
    pre.onerror = null;
    pre.src = src;
    /* complete is also true for a cached FAILED load; naturalWidth>0 means
       it actually decoded. */
    if (pre.complete) { pre.onload = null; if (pre.naturalWidth > 0) apply(); }
  }

  var allThumbs = Array.from(document.querySelectorAll('.tp-gallery__thumb'));
  allThumbs.forEach(function (thumb) {
    thumb.addEventListener('click', function () {
      allThumbs.forEach(function (t) { t.classList.remove('tp-active'); });
      thumb.classList.add('tp-active');
      var thumbImg = thumb.querySelector('img');
      tpSwapImage(mainImg, thumb.getAttribute('data-src'), thumbImg ? thumbImg.alt : null);
    });
  });

  /* --- Variant pills --- */
  var varSel = document.getElementById('tp-variant-select');
  var selOpts = [];
  if (varSel) {
    var initOpt = varSel.options[varSel.selectedIndex];
    if (initOpt) {
      initOpt.text.split(' / ').forEach(function (v, i) { selOpts[i] = v.trim(); });
    }
  }

  /* Fallback: if the Liquid-rendered hidden input is absent from DOM (CDN cache lag),
     create it dynamically so cart add always has a valid variant id */
  if (!document.getElementById('tp-variant-id')) {
    var fEl = document.getElementById('tp-form');
    if (fEl) {
      var inp = document.createElement('input');
      inp.type  = 'hidden';
      inp.name  = 'id';
      inp.id    = 'tp-variant-id';
      inp.value = varSel ? varSel.value : '';
      fEl.insertBefore(inp, fEl.firstChild);
    }
  }

  /* Count how many option groups exist (1–3) */
  var numOptionGroups = document.querySelectorAll('.tp-option-group').length;

  /* Returns true if ANY real variant can be formed with `value` at `optionIndex`
     combined with the current selections in all other option groups.            */
  function canSelect(optionIndex, value) {
    var tvArr = (window.tpProductData && window.tpProductData.variants) || [];
    return tvArr.some(function (tv) {
      if (!tv.available) return false;
      for (var j = 0; j < numOptionGroups; j++) {
        var tv_val = tv['option' + (j + 1)];
        if (j === optionIndex) {
          if (tv_val !== value) return false;
        } else {
          if (selOpts[j] && tv_val !== selOpts[j]) return false;
        }
      }
      return true;
    });
  }

  /* Exact-match: find the one variant where option1/2/3 all equal selOpts[0/1/2]. */
  function findExactVariant() {
    var tvArr = (window.tpProductData && window.tpProductData.variants) || [];
    for (var i = 0; i < tvArr.length; i++) {
      var tv = tvArr[i];
      var match = true;
      for (var j = 0; j < numOptionGroups; j++) {
        if (tv['option' + (j + 1)] !== selOpts[j]) { match = false; break; }
      }
      if (match) return tv;
    }
    return null;
  }

  /* Mark pills that can't form any real variant as tp-unavailable.
     If a selected pill becomes unavailable, deselects it and auto-picks
     the first still-available value in that group.                      */
  function updatePillAvailability() {
    document.querySelectorAll('.tp-option-group').forEach(function (group) {
      var gIdx = parseInt(group.getAttribute('data-option-index'), 10);
      var pills = group.querySelectorAll('.tp-pill');

      pills.forEach(function (pill) {
        var val = pill.getAttribute('data-value');
        var ok  = canSelect(gIdx, val);
        pill.classList.toggle('tp-unavailable', !ok);
        // Keep manually selected pills selected even when sold out — the button
        // shows Sold Out and the back-in-stock signup appears instead.
        if (!ok) pill.setAttribute('aria-disabled', 'true');
        else pill.removeAttribute('aria-disabled');
      });

      /* Auto-select first available pill when group has no selection */
      if (!selOpts[gIdx]) {
        pills.forEach(function (pill) {
          if (!selOpts[gIdx] && !pill.classList.contains('tp-unavailable')) {
            pill.classList.add('tp-selected');
            pill.setAttribute('aria-pressed', 'true');
            selOpts[gIdx] = pill.getAttribute('data-value');
            var lbl = document.getElementById('tp-sel-' + gIdx);
            if (lbl) lbl.textContent = selOpts[gIdx];
          }
        });
      }
    });
  }

  document.querySelectorAll('.tp-option-group').forEach(function (group) {
    var idx = parseInt(group.getAttribute('data-option-index'), 10);
    group.querySelectorAll('.tp-pill').forEach(function (pill) {
      pill.addEventListener('click', function () {
        group.querySelectorAll('.tp-pill').forEach(function (p) {
          p.classList.remove('tp-selected');
          p.setAttribute('aria-pressed', 'false');
        });
        pill.classList.add('tp-selected');
        pill.setAttribute('aria-pressed', 'true');
        selOpts[idx] = pill.getAttribute('data-value');
        var lbl = document.getElementById('tp-sel-' + idx);
        if (lbl) lbl.textContent = selOpts[idx];
        updatePillAvailability();
        updateVariant();
      });
    });
  });

  var _tpInitDone = false;
  function updateVariant() {
    var variantInput = document.getElementById('tp-variant-id');
    var addBtn       = document.getElementById('tp-add-btn');
    var btnText      = document.getElementById('tp-btn-text');
    var stickyBtn    = document.getElementById('tp-sticky-btn');
    var msgEl        = document.getElementById('tp-variant-msg');

    var matched = findExactVariant();

    if (!matched) {
      /* No exact variant — clear hidden input so it can never reach cart */
      if (variantInput) variantInput.value = '';
      if (addBtn)    { addBtn.disabled = true; }
      if (btnText)   { btnText.textContent = 'Unavailable'; }
      if (stickyBtn) { stickyBtn.disabled = true; stickyBtn.textContent = 'Unavailable'; }
      if (msgEl)     { msgEl.textContent = 'This combination is not available.'; msgEl.style.display = ''; }
      return;
    }

    /* Sync hidden input with exact variant */
    if (variantInput) {
      variantInput.value = matched.id;
      variantInput.dispatchEvent(new Event('change', { bubbles: true }));
    }

    /* Sync native select for data-img / data-alt lookup */
    if (varSel) {
      for (var si = 0; si < varSel.options.length; si++) {
        if (varSel.options[si].value === String(matched.id)) {
          varSel.selectedIndex = si;
          break;
        }
      }
    }

    var avail   = matched.available;
    var price   = matched.price;
    var compare = matched.compare_at_price || 0;
    var onSale  = compare > price;

    /* Clear any previous message */
    if (msgEl) { msgEl.textContent = ''; msgEl.style.display = 'none'; }

    /* Price display */
    var priceEl   = document.getElementById('tp-price');
    var compareEl = document.getElementById('tp-compare');
    var savingsEl = document.getElementById('tp-savings');
    if (priceEl)   { priceEl.textContent = matched.price_html; priceEl.classList.toggle('tp-price--sale', onSale); }
    if (compareEl) { compareEl.textContent = onSale ? matched.compare_at_price_html : ''; compareEl.style.display = onSale ? '' : 'none'; }
    if (savingsEl) { savingsEl.textContent = onSale ? 'Save ' + matched.save_html : ''; savingsEl.style.display = onSale ? '' : 'none'; }

    /* Sticky price */
    var sp = document.getElementById('tp-sticky-price');
    if (sp) { sp.textContent = matched.price_html; sp.classList.toggle('tp-sticky-bar__price--sale', onSale); }

    /* Button state */
    if (addBtn)    { addBtn.disabled = !avail; }
    if (btnText)   { btnText.textContent = avail ? 'Add to Cart' : 'Sold Out'; }
    if (stickyBtn) { stickyBtn.disabled = !avail; stickyBtn.textContent = avail ? 'Add to Cart' : 'Sold Out'; }
    if (!avail && msgEl) { msgEl.textContent = 'This variant is currently sold out.'; msgEl.style.display = ''; }

    /* Variant image */
    var varSelOpt = varSel && varSel.options[varSel.selectedIndex];
    var imgSrc = varSelOpt ? varSelOpt.getAttribute('data-img') : null;
    var imgAlt = varSelOpt ? varSelOpt.getAttribute('data-alt') : null;
    if (_tpInitDone && mainImg && imgSrc) {
      tpSwapImage(mainImg, imgSrc, imgAlt);
      document.querySelectorAll('.tp-gallery__thumb').forEach(function (t) {
        t.classList.toggle('tp-active', t.getAttribute('data-src') === imgSrc);
      });
    }
  }

  /* Run on page load to disable impossible pills and sync state */
  updatePillAvailability();
  updateVariant();
  _tpInitDone = true;

  /* Add to cart handled by the ES module below — needs CartLinesUpdateEvent from @shopify/events */

  /* --- Sticky bar visibility --- */
  var stickyBar = document.getElementById('tp-sticky');
  var stickyBtn = document.getElementById('tp-sticky-btn');
  var addBtnEl  = document.getElementById('tp-add-btn');

  if (stickyBar && addBtnEl && 'IntersectionObserver' in window) {
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        stickyBar.classList.toggle('tp-hidden', entry.isIntersecting);
        stickyBar.setAttribute('aria-hidden', entry.isIntersecting ? 'true' : 'false');
      });
    }, { threshold: 0.5 });
    io.observe(addBtnEl);
  }

  if (stickyBtn) {
    stickyBtn.addEventListener('click', function () { if (addBtnEl) addBtnEl.click(); });
  }

  /* --- Sticky gallery: set top = actual header height + 16px gap ---
     CSS top:20px is a safe fallback; JS overrides it on load so the
     gallery never disappears under the header regardless of its height. */
  var tpGallery = document.querySelector('.tp-gallery');
  if (tpGallery && window.matchMedia('(min-width: 900px)').matches) {
    function updateGalleryTop() {
      /* Try common Horizon / Shopify header selectors, widest to narrowest */
      var hdr = document.querySelector('#shopify-section-header .header__wrapper')
             || document.querySelector('.header-wrapper')
             || document.querySelector('header.header')
             || document.querySelector('#shopify-section-header')
             || document.querySelector('header');
      if (hdr) {
        var h = hdr.getBoundingClientRect().height;
        tpGallery.style.top = Math.max(Math.round(h) + 16, 20) + 'px';
      }
    }
    updateGalleryTop();
    var _galResizeTick;
    window.addEventListener('resize', function () {
      clearTimeout(_galResizeTick);
      _galResizeTick = setTimeout(updateGalleryTop, 120);
    });
  }

  /* --- Quantity discount locked/unlocked state --- */
  (function () {
    var box = document.querySelector('[data-qty-disc]');
    if (!box) return;

    var minQty  = parseInt(box.getAttribute('data-qty-disc-min') || '2', 10);
    var discPct = parseFloat(box.getAttribute('data-qty-disc-pct') || '25');
    var lockedH = box.getAttribute('data-locked-heading')   || '';
    var lockedT = box.getAttribute('data-locked-text')      || '';
    var openH   = box.getAttribute('data-unlocked-heading') || '';
    var openT   = box.getAttribute('data-unlocked-text')    || '';

    var headEl    = box.querySelector('[data-qty-disc-heading]');
    var subEl     = box.querySelector('[data-qty-disc-sub]');
    var badgeEl   = box.querySelector('[data-qty-disc-badge]');
    var savingsEl = box.querySelector('[data-qty-disc-savings]');
    var trackEl   = box.querySelector('[data-qty-disc-track]');
    var progLabel = box.querySelector('[data-qty-disc-prog-label]');
    var urgencyEl = box.querySelector('[data-qty-disc-urgency]');
    var varIdEl   = document.getElementById('tp-variant-id');
    var qtyInput  = document.getElementById('tp-qty');

    /* last fetched cart count — used only to re-apply savings display on qty/variant change */
    var lastCount = -1;

    function getCurrentPriceCents() {
      if (!varIdEl) return 0;
      var vid   = parseInt(varIdEl.value, 10);
      var tvArr = (window.tpProductData && window.tpProductData.variants) || [];
      for (var i = 0; i < tvArr.length; i++) {
        if (tvArr[i].id === vid) return tvArr[i].price || 0;
      }
      return 0;
    }

    function formatMoney(cents) {
      if (window.Shopify && typeof window.Shopify.formatMoney === 'function') {
        return window.Shopify.formatMoney(cents, window.Shopify.money_format);
      }
      var currency = (window.Shopify && window.Shopify.currency && window.Shopify.currency.active) || '';
      if (currency && typeof Intl !== 'undefined' && Intl.NumberFormat) {
        try { return new Intl.NumberFormat(undefined, { style: 'currency', currency: currency }).format(cents / 100); } catch (e) {}
      }
      return (cents / 100).toFixed(2);
    }

    function applyState(itemCount) {
      lastCount = itemCount;
      var unlocked = itemCount >= minQty;
      var almost   = !unlocked && itemCount === minQty - 1;
      var needed   = unlocked ? 0 : minQty - itemCount;
      var filled   = unlocked ? minQty : Math.min(itemCount, minQty);

      box.setAttribute('data-qty-disc-locked', unlocked ? 'false' : 'true');
      box.setAttribute('data-qty-disc-almost', almost   ? 'true'  : 'false');

      if (headEl) {
        headEl.textContent = unlocked ? openH
          : almost ? ('Add 1 More Item — Get ' + discPct + '% Off Everything')
          : lockedH;
      }
      if (subEl) {
        subEl.textContent = unlocked ? openT
          : almost ? ('You\'re this close — add 1 more and your whole cart is ' + discPct + '% off!')
          : lockedT;
      }
      if (badgeEl) {
        badgeEl.textContent = unlocked ? (discPct + '% CART DISCOUNT UNLOCKED')
          : almost ? ('1 MORE ITEM → ' + discPct + '% OFF')
          : 'UNLOCK CART DEAL';
      }
      if (urgencyEl && !unlocked) {
        urgencyEl.textContent = almost
          ? ('ONE MORE ITEM IN YOUR CART AND YOU GET ' + discPct + '% OFF — NO CODE NEEDED!')
          : ('Add ' + needed + ' more item' + (needed === 1 ? '' : 's') + ' to unlock ' + discPct + '% off your entire order.');
      }
      if (trackEl) {
        trackEl.querySelectorAll('.tp-qty-disc__prog-step').forEach(function (el, idx) {
          el.classList.toggle('tp-prog-active', idx < filled);
        });
      }
      if (progLabel) {
        progLabel.textContent = unlocked ? 'Discount unlocked!'
          : ('Add ' + needed + ' more item' + (needed === 1 ? '' : 's') + ' to unlock');
      }
      if (savingsEl) {
        if (unlocked) {
          var priceCents = getCurrentPriceCents();
          if (priceCents > 0) {
            var cur = parseInt((qtyInput && qtyInput.value) || '1', 10) || 1;
            var savingPerItem = Math.floor(priceCents * discPct / 100);
            savingsEl.textContent = 'You\'re saving ' + formatMoney(savingPerItem * cur) + ' on this order';
            savingsEl.style.display = 'block';
          } else {
            savingsEl.style.display = 'none';
          }
        } else {
          savingsEl.style.display = 'none';
        }
      }
    }

    /* Central async refresh — sole source of truth is /cart.js */
    var _debounceTimer;
    var _hasInit = false;

    function refreshCartDealState() {
      clearTimeout(_debounceTimer);
      _debounceTimer = setTimeout(function () {
        var root = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) || "/";
        fetch(root + "cart.js", {
          cache: "no-store",
          credentials: "same-origin",
          headers: { "Accept": "application/json" }
        })
          .then(function (r) { return r.json(); })
          .then(function (cart) {
            _hasInit = true;
            var count = typeof cart.item_count === "number"
              ? cart.item_count
              : (cart.items || []).reduce(function (s, i) { return s + (i.quantity || 0); }, 0);
            applyState(count);
          })
          .catch(function () { if (!_hasInit) applyState(0); });
      }, 200);
    }

    /* Initial load */
    refreshCartDealState();
    window.addEventListener('pageshow', refreshCartDealState);

    /* Variant/qty changes only update the savings display — no re-fetch needed */
    if (varIdEl) varIdEl.addEventListener('change', function () { if (lastCount >= 0) applyState(lastCount); });
    if (qtyInput) {
      qtyInput.addEventListener('input',  function () { if (lastCount >= 0) applyState(lastCount); });
      qtyInput.addEventListener('change', function () { if (lastCount >= 0) applyState(lastCount); });
    }

    /* Cart change events — fire at request-start so we use a delay to let the
       server finish. One managed chain: a new event resets the pending chain
       instead of stacking another 4 fetches on top (rapid qty clicks fired
       dozens of /cart.js requests before). The last event still gets its full
       350ms→5s coverage. */
    var _chainTimers = [];
    function scheduleRefreshChain() {
      _chainTimers.forEach(clearTimeout);
      _chainTimers = [350, 950, 2500, 5000].map(function (ms) {
        return setTimeout(refreshCartDealState, ms);
      });
    }
    ['shopify:cart:lines-update', 'cart:updated', 'cart:refresh', 'cart:change'].forEach(function (name) {
      document.addEventListener(name, scheduleRefreshChain);
    });

    /* MutationObserver — badge elements get replaced by morphSection so we need
       to re-observe after each morph. Strategy: observe individual badge elements
       (cheap), AND observe the cart-drawer section root for child replacement
       (fires only when morphSection swaps the section, not on every DOM change). */
    var _observed = new WeakSet();
    function connectBadgeObservers() {
      document.querySelectorAll('.theme-drawer__badge, [data-cart-count]').forEach(function (el) {
        if (_observed.has(el)) return;
        _observed.add(el);
        new MutationObserver(refreshCartDealState).observe(el, { childList: true, characterData: true, subtree: true });
      });
    }
    connectBadgeObservers();
    /* Watch the cart-drawer section root — fires when morphSection replaces it */
    var _cartSection = document.getElementById('shopify-section-cart-drawer-section')
                    || document.querySelector('[id*="cart-drawer-section"]');
    if (_cartSection) {
      new MutationObserver(function () {
        connectBadgeObservers();
        refreshCartDealState();
      }).observe(_cartSection, { childList: true, subtree: false });
    }
  }());

}());
</script>

<script type="module">
import { CartLinesUpdateEvent } from '@shopify/events';

(function () {
  var form = document.getElementById('tp-form');
  if (!form) return;

  form.addEventListener('submit', async function (e) {
    e.preventDefault();

    var addBtn  = document.getElementById('tp-add-btn');
    var btnText = document.getElementById('tp-btn-text');
    if (addBtn && addBtn.disabled) return;
    if (addBtn) addBtn.disabled = true;
    if (btnText) btnText.textContent = 'Adding…';

    var hiddenIdEl  = document.getElementById('tp-variant-id');
    var qty         = document.getElementById('tp-qty') || { value: '1' };
    var cartVarId   = hiddenIdEl ? hiddenIdEl.value.trim() : '';
    var variantNum  = Number(cartVarId);
    var qtyVal      = parseInt(qty.value, 10) || 1;

    /* Pre-submit: variant ID must be set and valid */
    if (!variantNum) {
      if (btnText) btnText.textContent = 'Select options first';
      setTimeout(function () { if (addBtn) addBtn.disabled = false; if (btnText) btnText.textContent = 'Add to Cart'; }, 2500);
      return;
    }

    /* sections_url tells Shopify to render the section in the current page's template context
       (product page), NOT in the cart endpoint context where template.name == 'cart' and
       the cart-drawer snippet would silently render nothing due to its own condition check. */
    var payload = {
      id:           variantNum,
      quantity:     qtyVal,
      sections:     'cart-drawer-section',
      sections_url: window.location.pathname,
    };

    /* Create the deferred promise — cart-drawer, cart-icon, cart-items all await this */
    var deferred = CartLinesUpdateEvent.createPromise();

    /* Dispatch BEFORE the fetch — this is the contract Horizon expects */
    form.dispatchEvent(new CartLinesUpdateEvent({
      action:  'add',
      context: 'product',
      lines:   [{ merchandiseId: String(variantNum), quantity: qtyVal }],
      promise: deferred.promise,
    }));

    try {
      var r    = await fetch('/cart/add.js', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body:    JSON.stringify(payload),
      });
      var data = await r.json();

      if (!r.ok) {
        var errDesc = (data.description || data.message) || ('HTTP ' + r.status);
        if (btnText) btnText.textContent = String(errDesc).slice(0, 50);
        setTimeout(function () { if (addBtn) addBtn.disabled = false; if (btnText) btnText.textContent = 'Add to Cart'; }, 4000);

        /* Resolve with error flag — drawer stays closed, icon count unchanged */
        deferred.resolve({ cart: { totalQuantity: 0, lines: [] }, detail: { didError: true } });
        return;
      }

      /* ── SUCCESS ─────────────────────────────────────────────────────── */

      /* Use sections from the add response when available.
         If missing (e.g. Shopify rendered an empty section), fetch separately
         using the current product-page URL as context so template.name == 'product'. */
      var sectionsHtml = (data.sections && data.sections['cart-drawer-section'])
        ? data.sections
        : await fetch(window.location.pathname + '?sections=cart-drawer-section')
            .then(function (res) { return res.json(); })
            .catch(function () { return {}; });

      var cartResp = await fetch('/cart.js');
      var cart     = await cartResp.json();

      refreshFreeShippingBars();

      deferred.resolve({
        cart: CartLinesUpdateEvent.createCartFromAjaxResponse(cart),
        detail: {
          items:     cart.items,
          source:    'tailand-product',
          itemCount: cart.item_count,
          sections:  sectionsHtml,
          didError:  false,
        },
      });

      if (btnText) btnText.textContent = 'Added!';
      setTimeout(function () { if (addBtn) addBtn.disabled = false; if (btnText) btnText.textContent = 'Add to Cart'; }, 2000);

      /* Notify the deal-box IIFE that the cart is now committed so it can
         re-fetch /cart.js with the correct new count. Dispatching AFTER
         deferred.resolve() guarantees the cart is already updated. */
      document.dispatchEvent(new CustomEvent('cart:updated', { bubbles: true }));

      /* Open the drawer — always try after the deferred resolves so the content
         is ready regardless of whether the theme uses auto-open or not. */
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          var drawer = document.querySelector('theme-drawer#cart-drawer');
          if (drawer && typeof drawer.open === 'function') {
            drawer.open();
          }
        });
      });

    } catch (err) {
      if (btnText) btnText.textContent = 'Connection error – retry';
      setTimeout(function () { if (addBtn) addBtn.disabled = false; if (btnText) btnText.textContent = 'Add to Cart'; }, 3000);
      deferred.reject(err);
    }
  });

  // ── Free-shipping bar live update (Section Rendering API) ──────────────
  // Re-renders the bar server-side so Liquid's |money filter applies the
  // correct presentment currency (CZK, EUR, USD …) automatically.
  function refreshFreeShippingBars() {
    var sectionId = '{{ section.id }}';
    fetch(window.location.pathname + '?sections=' + encodeURIComponent(sectionId))
      .then(function (r) { return r.ok ? r.json() : null; })
      .then(function (json) {
        if (!json || !json[sectionId]) return;
        var temp = document.createElement('div');
        temp.innerHTML = json[sectionId];
        var bars    = document.querySelectorAll('[data-free-shipping-progress]');
        var newBars = temp.querySelectorAll('[data-free-shipping-progress]');
        bars.forEach(function (bar, i) {
          var newBar = newBars[i];
          if (!newBar) return;
          var fill    = bar.querySelector('[data-free-shipping-bar]');
          var newFill = newBar.querySelector('[data-free-shipping-bar]');
          if (fill && newFill) fill.style.width = newFill.style.width;
          var msg    = bar.querySelector('[data-free-shipping-message]');
          var newMsg = newBar.querySelector('[data-free-shipping-message]');
          if (msg && newMsg) msg.innerHTML = newMsg.innerHTML;
        });
      })
      .then(function () { if (window.tcUpdateFSBars) window.tcUpdateFSBars(); })
      .catch(function () {});
  }

  // Run JS currency override on initial load
  if (window.tcUpdateFSBars) window.tcUpdateFSBars();
  else document.addEventListener('DOMContentLoaded', function () { if (window.tcUpdateFSBars) window.tcUpdateFSBars(); });

  // Also update when the cart drawer changes quantity or removes a line.
  document.addEventListener('CartLinesUpdateEvent', async function (e) {
    try {
      var result = await (e && e.detail && e.detail.promise);
      if (result && result.detail && result.detail.didError) return;
      refreshFreeShippingBars();
    } catch (_) {}
  });
}());
</script>

{% schema %}
{
  "name": "Tailand Product",
  "tag": "div",
  "class": "tp-section-outer",
  "settings": [
    { "type": "header", "content": "Paw Rating" },
    { "type": "checkbox", "id": "show_paw_rating", "label": "Show paw rating row", "default": true },
    { "type": "range", "id": "paw_rating_score", "label": "Filled paws (1–5)", "min": 1, "max": 5, "step": 1, "default": 5 },
    { "type": "text", "id": "paw_rating_text", "label": "Rating label", "default": "4.8 • 120 happy pets" },

    { "type": "header", "content": "Product Info" },
    { "type": "text", "id": "subtitle", "label": "Subtitle / value proposition", "info": "Short tagline below the title." },

    { "type": "header", "content": "Back in Stock" },
    { "type": "checkbox", "id": "show_back_in_stock", "label": "Show 'notify me' signup on sold-out variants", "default": true },

    { "type": "header", "content": "Sale Badge" },
    { "type": "checkbox", "id": "show_sale_badge", "label": "Show sale badge on image", "default": true },
    { "type": "text", "id": "sale_badge_text", "label": "Sale badge text", "default": "ENDS SOON" },

    { "type": "header", "content": "Benefit Bullets" },
    { "type": "text", "id": "benefit_1", "label": "Benefit 1", "default": "Pet-friendly pick" },
    { "type": "text", "id": "benefit_2", "label": "Benefit 2", "default": "Easy everyday use" },
    { "type": "text", "id": "benefit_3", "label": "Benefit 3", "default": "Great for playful moments" },
    { "type": "text", "id": "benefit_4", "label": "Benefit 4", "default": "Secure checkout" },
    { "type": "text", "id": "benefit_5", "label": "Benefit 5", "default": "Track your order" },

    { "type": "header", "content": "Promo Box" },
    { "type": "text", "id": "promo_emoji", "label": "Promo icon (emoji)", "default": "🐾" },
    { "type": "text", "id": "promo_title", "label": "Promo box title", "default": "Today's Pet Deal" },
    { "type": "text", "id": "promo_text", "label": "Promo box text", "default": "Free shipping on qualifying orders. Limited-time offer." },

    { "type": "header", "content": "Countdown Timer" },
    { "type": "checkbox", "id": "show_countdown", "label": "Show daily countdown to midnight", "default": true },
    { "type": "text", "id": "countdown_label", "label": "Countdown label text", "default": "Today's deal ends in" },

    { "type": "header", "content": "Free Shipping Bar" },
    { "type": "checkbox", "id": "show_free_shipping", "label": "Show free shipping bar", "default": true },
    { "type": "number", "id": "free_shipping_threshold_usd", "label": "Free shipping threshold (USD)", "info": "Must match Shopify Admin → Shipping → Free shipping rule. USD only — non-USD currencies show a static message instead.", "default": 60 },
    { "type": "text", "id": "free_shipping_prefix", "label": "Text before amount", "default": "You are" },
    { "type": "text", "id": "free_shipping_suffix", "label": "Text after amount", "default": "away from free shipping" },

    { "type": "header", "content": "Quantity Discount Message" },
    { "type": "checkbox", "id": "qty_discount_enabled", "label": "Show quantity discount offer", "default": false, "info": "Displays a locked/unlocked discount message near the quantity selector. Requires a Shopify automatic discount in Admin → Discounts (Minimum quantity of items, 25% off)." },
    { "type": "number", "id": "qty_discount_min", "label": "Required quantity to unlock", "default": 2 },
    { "type": "text", "id": "qty_discount_pct", "label": "Discount percentage text", "default": "25%" },
    { "type": "text", "id": "qty_discount_locked_heading", "label": "Locked heading", "default": "Add 1 More Item & Save 25% On Your Cart" },
    { "type": "text", "id": "qty_discount_locked_text", "label": "Locked subtext", "default": "You're only one item away from unlocking 25% off your entire cart — automatically applied at checkout." },
    { "type": "text", "id": "qty_discount_unlocked_heading", "label": "Unlocked heading", "default": "Your Whole Cart Is 25% Off" },
    { "type": "text", "id": "qty_discount_unlocked_text", "label": "Unlocked subtext", "default": "Your automatic 25% cart discount is unlocked and will apply at checkout." },

    { "type": "header", "content": "Multi-Buy Suggestion" },
    { "type": "text", "id": "multibuy_text", "label": "Multi-buy text", "default": "Buy 2 and keep one as a backup — perfect for multi-pet homes!" },


