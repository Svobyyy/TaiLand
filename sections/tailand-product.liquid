{% stylesheet %}
/* ============================================================
   TAILAND PRODUCT PAGE — tp-* prefix
   ============================================================ */

/* ---- Layout ---- */
.tp-wrap {
  max-width: 1280px;
  margin: 0 auto;
  padding: var(--tp-pt, 48px) 1.5rem 0;
}

.tp-main {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: start;
}

@media screen and (max-width: 899px) {
  .tp-main { grid-template-columns: 1fr; gap: 2rem; }
}

/* ============================================================
   GALLERY
   ============================================================ */

/* Sticky only on desktop.
   align-self: start is mandatory — without it the grid item stretches
   to the full column height and sticky never activates.
   top is set to 20px here as a safe fallback; JS overrides it at
   runtime with the actual rendered header height. */
@media screen and (min-width: 900px) {
  .tp-gallery {
    position: sticky;
    top: 20px;
    align-self: start;
    overflow: visible; /* never clip box-shadow of child elements */
  }
}

.tp-gallery__main {
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 20px;
  border: 2.5px solid var(--pc-text, #2d2d2d);
  box-shadow: 6px 6px 0 var(--pc-text, #2d2d2d);
  /* Do NOT use overflow:hidden or overflow:clip here —
     either can create an implicit scroll container that breaks
     position:sticky on the parent in certain Shopify theme wrappers.
     The image is kept away from corners via padding + object-fit:contain,
     so no clipping is needed for the border-radius to look correct. */
  overflow: visible;
  background: #FFF4D9;
  position: relative;
  padding: 1.25rem;
}

.tp-gallery__main-img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
  border-radius: 14px;
}

.tp-gallery__badge {
  position: absolute;
  top: 14px;
  left: 14px;
  z-index: 2;
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: var(--pc-sale-red, #e8372b);
  color: #fff;
  font-family: 'Fredoka', sans-serif;
  font-size: 0.9rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  padding: 5px 14px;
  border-radius: 999px;
  border: 2px solid var(--pc-text, #2d2d2d);
  box-shadow: 2px 2px 0 var(--pc-text, #2d2d2d);
  text-transform: uppercase;
}

.tp-gallery__thumbs {
  display: flex;
  gap: 10px;
  margin-top: 14px;
  flex-wrap: wrap;
}

.tp-gallery__thumb {
  width: 72px;
  height: 72px;
  border-radius: 12px;
  border: 2.5px solid var(--pc-text, #2d2d2d);
  box-shadow: 3px 3px 0 var(--pc-text, #2d2d2d);
  overflow: hidden;
  background: #FFF4D9;
  cursor: pointer;
  padding: 0;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
  flex-shrink: 0;
}

.tp-gallery__thumb:hover,
.tp-gallery__thumb.tp-active {
  transform: translate(-2px, -2px);
  box-shadow: 5px 5px 0 var(--pc-text, #2d2d2d);
}

.tp-gallery__thumb.tp-active { border-color: var(--pc-orange, #f59f2b); }

.tp-gallery__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }

/* ============================================================
   INFO PANEL
   ============================================================ */
.tp-info { display: flex; flex-direction: column; gap: 1.125rem; }

/* Breadcrumb */
.tp-breadcrumb {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.875rem;
  color: var(--pc-text, #2d2d2d);
  opacity: 0.6;
  flex-wrap: wrap;
}
.tp-breadcrumb a { color: inherit; text-decoration: none; }
.tp-breadcrumb a:hover { opacity: 1; text-decoration: underline; }

/* Paw rating */
.tp-paw-row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }

.tp-paws { display: flex; gap: 3px; }

.tp-paw { width: 22px; height: 22px; }
.tp-paw--on  { color: var(--pc-orange, #f59f2b); }
.tp-paw--off { color: var(--pc-text, #2d2d2d); opacity: 0.2; }

.tp-paw-text {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--pc-text, #2d2d2d);
  opacity: 0.75;
}

/* Title */
.tp-title {
  font-family: 'Fredoka', sans-serif;
  font-size: clamp(1.75rem, 3.5vw, 2.4rem);
  font-weight: 600;
  line-height: 1.15;
  color: var(--pc-text, #2d2d2d);
  margin: 0;
}

/* Subtitle */
.tp-subtitle {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 1.05rem;
  color: var(--pc-text, #2d2d2d);
  opacity: 0.7;
  margin: 0;
  line-height: 1.5;
}

/* Price */
.tp-price-row { display: flex; align-items: baseline; gap: 0.75rem; flex-wrap: wrap; }

.tp-price {
  font-family: 'Fredoka', sans-serif;
  font-size: 2.1rem;
  font-weight: 600;
  color: var(--pc-text, #2d2d2d);
}
.tp-price--sale { color: var(--pc-sale-red, #e8372b); }

.tp-compare {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 1.1rem;
  color: var(--pc-text, #2d2d2d);
  opacity: 0.4;
  text-decoration: line-through;
}

.tp-savings {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.82rem;
  font-weight: 800;
  color: var(--pc-sale-red, #e8372b);
  background: #ffeeed;
  border: 1.5px solid var(--pc-sale-red, #e8372b);
  border-radius: 999px;
  padding: 3px 10px;
}

/* Description — text only, strip embedded media */
.tp-description {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 1.02rem;
  line-height: 1.65;
  color: var(--pc-text, #2d2d2d);
  opacity: 0.85;
}

/* Hide any images / video / embeds inside product description.
   Product images belong in the gallery only. */
.tp-description img,
.tp-description video,
.tp-description iframe,
.tp-description figure,
.tp-description .shopify-block--image,
.tp-description [data-mce-fragment] img {
  display: none !important;
}

/* Also collapse empty paragraphs Shopify wraps around removed images */
.tp-description p:empty { display: none; }

/* Variants */
.tp-variants { display: flex; flex-direction: column; gap: 1rem; }

.tp-option-group { display: flex; flex-direction: column; gap: 0.5rem; }

.tp-option-label {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.82rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--pc-text, #2d2d2d);
}
.tp-option-label em {
  font-style: normal;
  font-weight: 500;
  text-transform: none;
  letter-spacing: 0;
  opacity: 0.65;
  margin-left: 6px;
}

.tp-pills { display: flex; flex-wrap: wrap; gap: 8px; }

.tp-pill {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.9rem;
  font-weight: 700;
  padding: 7px 18px;
  border-radius: 999px;
  border: 2.5px solid var(--pc-text, #2d2d2d);
  box-shadow: 3px 3px 0 var(--pc-text, #2d2d2d);
  background: #FFF4D9;
  color: var(--pc-text, #2d2d2d);
  cursor: pointer;
  transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
}
.tp-pill:hover { transform: translate(-2px, -2px); box-shadow: 5px 5px 0 var(--pc-text, #2d2d2d); }
.tp-pill.tp-selected {
  background: var(--pc-orange, #f59f2b);
  transform: translate(-2px, -2px);
  box-shadow: 5px 5px 0 var(--pc-text, #2d2d2d);
}
/* Sold-out/invalid combos stay clickable so shoppers can see the Sold Out state
   and the back-in-stock signup — just visually dimmed and struck through. */
.tp-pill.tp-unavailable { opacity: 0.45; text-decoration: line-through; box-shadow: none; }
.tp-variant-msg { font-family: 'Nunito Sans', sans-serif; font-size: 0.875rem; font-weight: 700; color: var(--pc-sale-red, #e8372b); padding: 8px 12px; background: rgba(232,55,43,0.08); border-radius: 8px; border-left: 3px solid var(--pc-sale-red, #e8372b); margin-top: 4px; }

.tp-variant-select-native { position: absolute; opacity: 0; pointer-events: none; width: 0; height: 0; }

/* Quantity */
.tp-qty-row { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }

.tp-qty-label {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.82rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--pc-text, #2d2d2d);
}

.tp-qty {
  display: flex;
  align-items: center;
  border: 2.5px solid var(--pc-text, #2d2d2d);
  border-radius: 999px;
  box-shadow: 3px 3px 0 var(--pc-text, #2d2d2d);
  background: #FFF4D9;
  overflow: hidden;
}

.tp-qty__btn {
  width: 42px; height: 42px;
  background: none; border: none;
  font-family: 'Fredoka', sans-serif;
  font-size: 1.4rem; font-weight: 600;
  color: var(--pc-text, #2d2d2d);
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  line-height: 1;
  transition: background 0.12s;
}
.tp-qty__btn:hover { background: #E8CFA0; }

.tp-qty__input {
  width: 44px; text-align: center;
  border: none;
  border-left: 2px solid var(--pc-text, #2d2d2d);
  border-right: 2px solid var(--pc-text, #2d2d2d);
  background: none;
  font-family: 'Fredoka', sans-serif;
  font-size: 1.1rem; font-weight: 600;
  color: var(--pc-text, #2d2d2d);
  height: 42px; padding: 0;
  -moz-appearance: textfield;
}
.tp-qty__input::-webkit-inner-spin-button,
.tp-qty__input::-webkit-outer-spin-button { -webkit-appearance: none; }

/* Promo box */
.tp-promo {
  background: #FFF4D9;
  border: 2.5px solid var(--pc-text, #2d2d2d);
  border-radius: 16px;
  box-shadow: 5px 5px 0 var(--pc-text, #2d2d2d);
  padding: 16px 18px;
}

.tp-promo__head { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
.tp-promo__emoji { font-size: 1.3rem; line-height: 1; }
.tp-promo__title { font-family: 'Fredoka', sans-serif; font-size: 1.15rem; font-weight: 600; color: var(--pc-text, #2d2d2d); }
.tp-promo__text { font-family: 'Nunito Sans', sans-serif; font-size: 0.9rem; color: var(--pc-text, #2d2d2d); opacity: 0.75; margin-bottom: 10px; }

/* Countdown */
.tp-countdown { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }

.tp-countdown__label {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.78rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.06em;
  color: var(--pc-text, #2d2d2d); opacity: 0.6;
}

.tp-countdown__units { display: flex; gap: 6px; align-items: center; }

.tp-countdown__unit {
  display: flex; flex-direction: column; align-items: center;
  background: var(--pc-orange, #f59f2b);
  border: 2px solid var(--pc-text, #2d2d2d);
  border-radius: 8px;
  box-shadow: 2px 2px 0 var(--pc-text, #2d2d2d);
  min-width: 38px; padding: 4px 6px 3px;
}

.tp-countdown__num { font-family: 'Fredoka', sans-serif; font-size: 1.15rem; font-weight: 600; color: #fff; line-height: 1; }
.tp-countdown__sub { font-family: 'Nunito Sans', sans-serif; font-size: 0.6rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; color: #fff; opacity: 0.85; line-height: 1; margin-top: 1px; }
.tp-countdown__sep { font-family: 'Fredoka', sans-serif; font-size: 1.2rem; font-weight: 700; color: var(--pc-text, #2d2d2d); opacity: 0.5; }
.tp-countdown__expired { font-family: 'Nunito Sans', sans-serif; font-size: 0.88rem; font-weight: 700; color: var(--pc-sale-red, #e8372b); }

/* Free shipping bar */
.tp-ship-bar {
  background: #FFF4D9;
  border: 2.5px solid var(--pc-text, #2d2d2d);
  border-radius: 14px;
  box-shadow: 4px 4px 0 var(--pc-text, #2d2d2d);
  padding: 12px 16px;
}

.tp-ship-bar__text {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.88rem; font-weight: 700;
  color: var(--pc-text, #2d2d2d);
  margin-bottom: 8px;
  display: flex; align-items: center; gap: 6px;
}
.tp-ship-bar__text svg { width: 18px; height: 18px; color: var(--pc-green, #2eaa5f); flex-shrink: 0; }

.tp-ship-bar__track { height: 8px; background: #E4DDD5; border-radius: 999px; overflow: hidden; }
.tp-ship-bar__fill { height: 100%; background: var(--pc-green, #2eaa5f); border-radius: 999px; }

/* Multibuy */
.tp-multibuy {
  background: linear-gradient(135deg, #fff8e7 0%, #fff3d5 100%);
  border: 2px dashed var(--pc-orange, #f59f2b);
  border-radius: 14px;
  padding: 12px 16px;
  display: flex; align-items: center; gap: 10px;
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.88rem; font-weight: 700;
  color: var(--pc-text, #2d2d2d);
}
.tp-multibuy__emoji { font-size: 1.3rem; flex-shrink: 0; }


/* CTA */
.tp-cta { display: flex; flex-direction: column; gap: 10px; }

.tp-btn-cart {
  display: flex; align-items: center; justify-content: center; gap: 8px;
  width: 100%; padding: 16px 24px;
  font-family: 'Fredoka', sans-serif; font-size: 1.2rem; font-weight: 600;
  color: var(--pc-white, #ffffff);
  background: var(--pc-green, #2eaa5f);
  border: 2.5px solid var(--pc-text, #2d2d2d);
  border-radius: 999px;
  box-shadow: 5px 5px 0 var(--pc-text, #2d2d2d);
  cursor: pointer;
  transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
}
.tp-btn-cart:hover:not(:disabled) { transform: translate(-2px,-2px); box-shadow: 7px 7px 0 var(--pc-text, #2d2d2d); background: var(--pc-green-dark, #228a4a); }
.tp-btn-cart:disabled { opacity: 0.5; cursor: not-allowed; }

/* Trust badges */
.tp-trust {
  display: grid; grid-template-columns: 1fr 1fr; gap: 8px;
  padding: 14px;
  background: #FFF4D9;
  border: 2.5px solid var(--pc-text, #2d2d2d);
  border-radius: 14px;
  box-shadow: 4px 4px 0 var(--pc-text, #2d2d2d);
}
.tp-trust__item { display: flex; align-items: center; gap: 7px; font-family: 'Nunito Sans', sans-serif; font-size: 0.8rem; font-weight: 700; color: var(--pc-text, #2d2d2d); }
.tp-trust__icon { width: 24px; height: 24px; flex-shrink: 0; color: var(--pc-green, #2eaa5f); }

/* ============================================================
   PRODUCT DESCRIPTION (below two-column section)
   ============================================================ */
.tp-desc-section {
  max-width: 860px;
  margin: 2.5rem auto 0;
  padding: 0 1.5rem;
}

/* Description text — brand-styled, no images */
.tp-desc-section .tp-description {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 1.05rem;
  line-height: 1.75;
  color: var(--pc-text, #2d2d2d);
  opacity: 0.85;
}

/* Hide all media inside product description — images belong in gallery only */
.tp-description img,
.tp-description video,
.tp-description iframe,
.tp-description figure,
.tp-description .shopify-block--image {
  display: none !important;
}
.tp-description p:empty { display: none; }

/* Nice formatting for description content */
.tp-description p { margin: 0 0 0.85rem; }
.tp-description p:last-child { margin-bottom: 0; }
.tp-description ul, .tp-description ol {
  padding-left: 1.4rem;
  margin: 0 0 0.85rem;
}
.tp-description li { margin-bottom: 0.3rem; }
.tp-description strong { font-weight: 800; }
.tp-description h2, .tp-description h3, .tp-description h4 {
  font-family: 'Fredoka', sans-serif;
  font-weight: 600;
  color: var(--pc-text, #2d2d2d);
  margin: 1.25rem 0 0.5rem;
}

/* ============================================================
   LOWER CONTENT
   ============================================================ */
.tp-lower { max-width: 1280px; margin: 0 auto; padding: 3rem 1.5rem 0; }

/* Accordions */
.tp-accordions { display: flex; flex-direction: column; gap: 10px; max-width: 820px; margin: 0 auto; }

.tp-acc {
  border: 2.5px solid var(--pc-text, #2d2d2d);
  border-radius: 14px; overflow: hidden;
  box-shadow: 3px 3px 0 var(--pc-text, #2d2d2d);
  background: #FFF4D9;
}
.tp-acc[open] { box-shadow: 5px 5px 0 var(--pc-text, #2d2d2d); }

.tp-acc summary {
  display: flex; align-items: center; justify-content: space-between;
  padding: 14px 20px; cursor: pointer; list-style: none;
  font-family: 'Fredoka', sans-serif; font-size: 1.1rem; font-weight: 600;
  color: var(--pc-text, #2d2d2d);
  gap: 1rem; user-select: none;
}
.tp-acc summary::-webkit-details-marker { display: none; }
.tp-acc__label { display: flex; align-items: center; gap: 10px; }

.tp-acc__chev {
  width: 20px; height: 20px; flex-shrink: 0;
  color: var(--pc-orange, #f59f2b);
  transition: transform 0.2s ease;
}
.tp-acc[open] .tp-acc__chev { transform: rotate(180deg); }

.tp-acc__body {
  padding: 14px 20px 16px;
  border-top: 1.5px solid rgba(45,45,45,0.12);
  font-family: 'Nunito Sans', sans-serif; font-size: 1rem; line-height: 1.65;
  color: var(--pc-text, #2d2d2d); opacity: 0.85;
}
.tp-acc__body p { margin: 0 0 0.75rem; }
.tp-acc__body p:last-child { margin-bottom: 0; }

/* ---- Product Story ---- */
.tp-story { max-width: 1280px; margin: 3.5rem auto 0; padding: 0 1.5rem; }

.tp-story__heading {
  font-family: 'Fredoka', sans-serif;
  font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 600;
  color: var(--pc-text, #2d2d2d);
  text-align: center; margin-bottom: 2rem;
}

.tp-story__grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem;
}
@media screen and (max-width: 899px) { .tp-story__grid { grid-template-columns: 1fr 1fr; } }
@media screen and (max-width: 599px) { .tp-story__grid { grid-template-columns: 1fr; } }

.tp-story__card {
  background: #FFF4D9;
  border: 2.5px solid var(--pc-text, #2d2d2d);
  border-radius: 18px; box-shadow: 5px 5px 0 var(--pc-text, #2d2d2d);
  overflow: hidden; display: flex; flex-direction: column;
}

.tp-story__img { width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block; }

.tp-story__card-body { padding: 16px 18px 18px; }
.tp-story__emoji { font-size: 1.6rem; margin-bottom: 8px; display: block; }
.tp-story__card-title { font-family: 'Fredoka', sans-serif; font-size: 1.15rem; font-weight: 600; color: var(--pc-text, #2d2d2d); margin-bottom: 6px; }
.tp-story__card-text { font-family: 'Nunito Sans', sans-serif; font-size: 0.92rem; line-height: 1.6; color: var(--pc-text, #2d2d2d); opacity: 0.75; }

/* ---- Specs table ---- */
.tp-specs { max-width: 820px; margin: 3rem auto 0; padding: 0 1.5rem; }

.tp-specs__heading {
  font-family: 'Fredoka', sans-serif; font-size: 1.4rem; font-weight: 600;
  color: var(--pc-text, #2d2d2d); text-align: center; margin-bottom: 1rem;
}

.tp-specs__table {
  border: 2.5px solid var(--pc-text, #2d2d2d);
  border-radius: 14px; overflow: hidden;
  box-shadow: 4px 4px 0 var(--pc-text, #2d2d2d);
}

.tp-specs__row {
  display: grid; grid-template-columns: 1fr 2fr;
  border-bottom: 1.5px solid rgba(45,45,45,0.12);
}
.tp-specs__row:last-child { border-bottom: none; }
.tp-specs__row:nth-child(even) { background: #FFF8EE; }

.tp-specs__key {
  padding: 12px 16px;
  font-family: 'Nunito Sans', sans-serif; font-size: 0.78rem; font-weight: 800;
  text-transform: uppercase; letter-spacing: 0.04em;
  color: var(--pc-text, #2d2d2d); opacity: 0.6;
}
.tp-specs__val {
  padding: 12px 16px;
  font-family: 'Nunito Sans', sans-serif; font-size: 0.92rem;
  color: var(--pc-text, #2d2d2d);
}

/* ---- Related products ---- */
.tp-related { max-width: 1280px; margin: 3rem auto 0; padding: 0 1.5rem; overflow: visible; }

.tp-related__heading {
  font-family: 'Fredoka', sans-serif;
  font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 600;
  color: var(--pc-text, #2d2d2d); text-align: center; margin-bottom: 1.5rem;
}
.tp-related__heading-hl {
  display: inline-block;
  position: relative;
  font-weight: 700;
  white-space: nowrap;
  padding-bottom: 8px;
}
.tp-related__heading-line {
  position: absolute;
  left: -3%;
  bottom: -2px;
  width: 106%;
  height: 12px;
  color: var(--pc-green, #4F8A2F);
  pointer-events: none;
  display: block;
}

/* ---- plt-card / plt-grid (shared with Pets Love These) ---- */
.plt-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
  list-style: none;
  margin: 0;
  padding: 6px 0 14px 0;
}
@media screen and (max-width: 1199px) {
  .plt-grid { grid-template-columns: repeat(3, 1fr); gap: 16px; }
}
@media screen and (max-width: 749px) {
  .plt-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; padding: 4px 0 12px 0; }
}
@media screen and (max-width: 479px) {
  .plt-grid { gap: 8px; }
}
.plt-card {
  display: flex;
  flex-direction: column;
  background: #FFF4D9;
  border: 3px solid var(--pc-text, #2B1B12);
  border-radius: 20px;
  box-shadow: 6px 8px 0 rgba(43, 27, 18, 0.82);
  overflow: hidden;
  transition: transform 0.12s ease, box-shadow 0.12s ease;
}
.plt-card:hover {
  transform: translate(3px, 4px);
  box-shadow: 3px 4px 0 rgba(43, 27, 18, 0.82);
}
.plt-card__media-wrap {
  position: relative;
  flex-shrink: 0;
  overflow: visible;
  container-type: inline-size;
  container-name: plt-card-media;
}
.plt-card__media-link {
  display: block;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background: var(--pc-white, #fff);
}
.plt-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.3s ease;
}
.plt-card:hover .plt-card__img { transform: scale(1.05); }
.plt-card__img--placeholder { padding: 20%; box-sizing: border-box; color: rgba(43, 27, 18, 0.2); }
.plt-badge-group {
  position: absolute;
  inset: 0;
  z-index: 2;
  pointer-events: none;
}
.plt-sale-badge,
.plt-soldout-badge {
  position: absolute;
  top: 10px;
  left: 10px;
  z-index: 2;
  padding: 8px 16px;
  background: var(--pc-sale-red, #D63C3C);
  color: var(--pc-white, #fff);
  font-family: 'Nunito Sans', sans-serif;
  font-size: 1rem;
  font-weight: 800;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  border-radius: 10px;
  border: 2.5px solid var(--pc-text, #2B1B12);
  box-shadow: 3px 3px 0 var(--pc-text, #2B1B12);
  line-height: 1.3;
  pointer-events: none;
  white-space: nowrap;
}
.plt-soldout-badge { background: var(--pc-text, #2B1B12); }
.plt-card--soldout .plt-card__img { opacity: 0.55; }
@media screen and (max-width: 749px) {
  .plt-sale-badge,
  .plt-soldout-badge { font-size: 0.82rem; padding: 6px 12px; top: 8px; left: 8px; }
}
.plt-card__body {
  padding: 14px 16px 18px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex: 1;
}
.plt-card__title-link { text-decoration: none; color: inherit; }
.plt-card__title {
  font-family: 'Fredoka', sans-serif;
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--pc-text, #2B1B12);
  margin: 0;
  line-height: 1.2;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.plt-card__price {
  display: flex;
  align-items: baseline;
  gap: 8px;
  flex-wrap: wrap;
  margin-top: 2px;
}
.plt-card__price-reg {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--pc-text, #2B1B12);
  line-height: 1.1;
}
.plt-card__price-sale {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--pc-sale-red, #D63C3C);
  line-height: 1.1;
}
.plt-card__price-compare {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 1rem;
  font-weight: 500;
  color: rgba(43, 27, 18, 0.45);
  text-decoration: line-through;
  line-height: 1.1;
}
.plt-card__btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  margin-top: auto;
  align-self: flex-start;
  padding: 11px 22px;
  background: var(--pc-green, #4F8A2F);
  color: var(--pc-white, #fff) !important;
  font-family: 'Nunito Sans', sans-serif;
  font-size: 1rem;
  font-weight: 800;
  text-decoration: none;
  border-radius: 999px;
  border: 2px solid var(--pc-text, #2B1B12);
  box-shadow: 3px 3px 0 var(--pc-text, #2B1B12);
  transition: background 0.15s ease, transform 0.1s ease, box-shadow 0.1s ease;
}
.plt-card__btn:hover {
  background: var(--pc-green-dark, #3E6F25);
  transform: translate(1px, 1px);
  box-shadow: 2px 2px 0 var(--pc-text, #2B1B12);
  color: var(--pc-white, #fff) !important;
}
@media screen and (max-width: 749px) {
  .plt-card__title { font-size: 1.05rem; }
  .plt-card__price-reg, .plt-card__price-sale { font-size: 1.25rem; }
  .plt-card__price-compare { font-size: 0.875rem; }
  .plt-card__btn { font-size: 0.9rem; padding: 9px 18px; }
}
@media screen and (max-width: 479px) {
  .plt-card__body { padding: 8px 10px 12px; gap: 5px; }
  .plt-card__title { font-size: 0.9rem; }
  .plt-card__price-reg, .plt-card__price-sale { font-size: 1.05rem; }
  .plt-card__price-compare { font-size: 0.75rem; }
  .plt-card__btn { font-size: 0.78rem; padding: 6px 10px; gap: 3px; width: 100%; justify-content: center; }
}

/* ---- FAQ ---- */
.tp-faq {
  max-width: 820px;
  margin: 4rem auto 0;
  padding: 0 1.5rem;
  text-align: center;
}

.tp-faq__heading {
  font-family: 'Fredoka', sans-serif;
  font-size: clamp(2rem, 4vw, 2.8rem);
  font-weight: 600;
  color: var(--pc-text, #2d2d2d);
  margin: 0 0 0.5rem;
  line-height: 1.1;
}

/* SVG wave underline matching landing page hero sections */
.tp-faq__wave {
  display: block;
  width: 180px;
  margin: 0 auto 2.25rem;
  overflow: visible;
}

.tp-faq__items { display: flex; flex-direction: column; gap: 10px; text-align: left; }

/* FAQ accordions are slightly taller than product accordions for readability */
.tp-faq .tp-acc summary {
  padding: 16px 22px;
  font-size: 1.15rem;
}

.tp-faq .tp-acc__body {
  padding: 14px 22px 18px;
  font-size: 1.02rem;
}

/* ---- Sold-out mode: hide upsells/urgency so the back-in-stock signup stands out ---- */
.tp-soldout-mode .tp-qty-row,
.tp-soldout-mode .tp-qty-disc,
.tp-soldout-mode .tp-promo,
.tp-soldout-mode .tp-ship-bar,
.tp-soldout-mode .tp-multibuy,
.tp-soldout-mode .tp-warning,
.tp-soldout-mode .tp-gallery__badge {
  display: none !important;
}

/* ---- Flagship: full-bleed alternating section bands (same technique as
   the description's .tp-feat__band / .tc-cream-paw-bg — white, then cream,
   alternating, starting with white). Wraps whichever flagship sections
   actually render (before/after, UGC, comparison, reviews) in sequence. ---- */
.tpx-band {
  padding: 3rem 0;
}

.tpx-band > .tpx-ugc,
.tpx-band > .tpx-cmp,
.tpx-band > .tpx-rev {
  margin-top: 0;
}

/* ---- Flagship: before/after slider ---- */
.tpx-ba__slider {
  position: relative;
  flex: 1.4 1 58%;
  min-width: 0;
  aspect-ratio: 4 / 3;
  border: 3px solid var(--pc-text, #2d2d2d);
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 6px 6px 0 var(--pc-text, #2d2d2d);
  cursor: ew-resize;
  user-select: none;
  touch-action: none;
}

@media screen and (max-width: 749px) {
  .tpx-ba__slider { width: 100%; flex: none; }
}

/* Text column yields space to the slider in before/after rows */
.tpx-ba .tp-feat__content { flex: 1 1 38%; }

.tpx-ba__simg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  pointer-events: none;
  display: block;
}

.tpx-ba__simg--after { z-index: 1; }
.tpx-ba__simg--before { z-index: 2; }

.tpx-ba__handle {
  position: absolute;
  top: 0;
  bottom: 0;
  width: 4px;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 2px 0 0 rgba(43, 27, 18, 0.35);
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 5;
  pointer-events: none;
}

.tpx-ba__handle-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60px;
  height: 60px;
  background: var(--pc-orange, #ee7b28);
  border: 2.5px solid var(--pc-text, #2d2d2d);
  border-radius: 50%;
  box-shadow: 3px 3px 0 var(--pc-text, #2d2d2d);
  cursor: ew-resize;
  pointer-events: auto;
  color: #fff;
  flex-shrink: 0;
  padding: 0;
}

.tpx-ba__handle-btn svg { width: 24px; height: 18px; display: block; }

.tpx-ba__slider .tpx-ba__tag {
  top: 14px;
  left: 14px;
  z-index: 4;
}

.tpx-ba__slider .tpx-ba__tag--after {
  left: auto;
  right: 14px;
}

/* Single-image fallback */
.tpx-ba__imgs {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14px;
  flex: 1;
  min-width: 0;
}

.tpx-ba__fig {
  position: relative;
  margin: 0;
  border: 2.5px solid var(--pc-text, #2d2d2d);
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 4px 4px 0 var(--pc-text, #2d2d2d);
}

.tpx-ba__img {
  display: block;
  width: 100%;
  height: 100%;
  aspect-ratio: 3 / 4;
  object-fit: cover;
}

.tpx-ba__tag {
  position: absolute;
  top: 10px;
  left: 10px;
  z-index: 1;
  padding: 4px 12px;
  font-family: 'Fredoka', sans-serif;
  font-size: 0.875rem;
  font-weight: 600;
  color: #fff;
  background: var(--pc-orange, #ee7b28);
  border: 2px solid var(--pc-text, #2d2d2d);
  border-radius: 999px;
}

.tpx-ba__tag--after { background: var(--pc-green, #2eaa5f); }

@media screen and (max-width: 749px) {
  .tpx-ba .tp-feat__content { margin-bottom: 18px; }
}

/* ---- Flagship: UGC videos ---- */
.tpx-ugc {
  max-width: 1280px;
  margin: 3rem auto 0;
  padding: 0 1.5rem;
}

.tpx-ugc__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  margin-top: 1.75rem;
}

/* A single video shouldn't stretch to fill the grid — center it at a natural width */
.tpx-ugc__grid:has(.tpx-ugc__item:only-child) {
  grid-template-columns: minmax(0, 320px);
  justify-content: center;
}

@media screen and (max-width: 749px) {
  .tpx-ugc__grid {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 8px;
  }
  .tpx-ugc__item { flex: 0 0 72%; scroll-snap-align: center; }
  /* Single video: no scroll row needed — center it like a normal block */
  .tpx-ugc__grid:has(.tpx-ugc__item:only-child) {
    overflow-x: visible;
    justify-content: center;
  }
  .tpx-ugc__grid:has(.tpx-ugc__item:only-child) .tpx-ugc__item { flex: 0 0 85%; }
}

.tpx-ugc__item {
  position: relative;
  border: 2.5px solid var(--pc-text, #2d2d2d);
  border-radius: 18px;
  overflow: hidden;
  box-shadow: 5px 5px 0 var(--pc-text, #2d2d2d);
}

.tpx-ugc__video {
  display: block;
  width: 100%;
  aspect-ratio: 9 / 16;
  object-fit: cover;
}

.tpx-ugc__play {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 64px;
  height: 64px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--pc-orange, #ee7b28);
  color: #fff;
  border: 2.5px solid var(--pc-text, #2d2d2d);
  border-radius: 50%;
  box-shadow: 3px 3px 0 var(--pc-text, #2d2d2d);
  cursor: pointer;
}

.tpx-ugc__play svg { width: 30px; height: 30px; margin-left: 3px; }

.tpx-ugc__play:hover { transform: translate(-50%, -50%) scale(1.06); }

/* ---- Flagship: comparison table ---- */
.tpx-cmp {
  max-width: 980px;
  margin: 3.5rem auto 0;
  padding: 0 1.5rem;
}

.tpx-cmp__scroll {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  margin-top: 1.75rem;
  /* Without paint containment the table's 560px min-width leaks into the
     document scroll extent on mobile despite the overflow clip (Chrome quirk). */
  contain: paint;
}

.tpx-cmp__table {
  width: 100%;
  min-width: 560px;
  border-collapse: separate;
  border-spacing: 0;
}

.tpx-cmp__table th,
.tpx-cmp__table td {
  padding: 14px 16px;
  text-align: center;
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.95rem;
  border-bottom: 2px solid rgba(43, 27, 18, 0.15);
  background: #fff;
}

.tpx-cmp__table thead th {
  font-family: 'Fredoka', sans-serif;
  font-size: 1rem;
  font-weight: 600;
  color: var(--pc-text, #2d2d2d);
  border-bottom: 2.5px solid var(--pc-text, #2d2d2d);
}

.tpx-cmp__feature {
  text-align: left;
  font-weight: 700;
  color: var(--pc-text, #2d2d2d);
}

/* Highlighted "ours" column */
.tpx-cmp__ours-h {
  background: var(--pc-orange, #ee7b28) !important;
  color: #fff !important;
  border: 2.5px solid var(--pc-text, #2d2d2d) !important;
  border-radius: 14px 14px 0 0;
}

.tpx-cmp__ours {
  background: #FFF4D9 !important;
  border-left: 2.5px solid var(--pc-text, #2d2d2d) !important;
  border-right: 2.5px solid var(--pc-text, #2d2d2d) !important;
}

.tpx-cmp__table tbody tr:last-child .tpx-cmp__ours {
  border-bottom: 2.5px solid var(--pc-text, #2d2d2d) !important;
  border-radius: 0 0 14px 14px;
}

.tpx-cmp__yes, .tpx-cmp__no {
  width: 26px;
  height: 26px;
  display: inline-block;
  vertical-align: middle;
}

/* ---- Flagship: photo reviews ---- */
.tpx-rev {
  max-width: 1280px;
  margin: 3.5rem auto 0;
  padding: 0 1.5rem;
}

.tpx-rev__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
  margin-top: 1.75rem;
}

@media screen and (max-width: 989px) {
  .tpx-rev__grid { grid-template-columns: repeat(2, 1fr); }
}

@media screen and (max-width: 749px) {
  .tpx-rev__grid {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 8px;
  }
  .tpx-rev__card { flex: 0 0 68%; scroll-snap-align: center; }
}

/* Polaroid snapshots — deliberately NOT the product-card look */
.tpx-rev__card {
  position: relative;
  margin: 0;
  background: #fff;
  border: 2px solid var(--pc-text, #2d2d2d);
  border-radius: 6px;
  padding: 12px 12px 0;
  box-shadow: 4px 5px 0 rgba(43, 27, 18, 0.35);
  display: flex;
  flex-direction: column;
  transition: transform 0.25s ease, box-shadow 0.25s ease;
}

/* Alternating pinned-photo tilt, straightens on hover */
.tpx-rev__grid .tpx-rev__card:nth-child(4n+1) { transform: rotate(-2deg); }
.tpx-rev__grid .tpx-rev__card:nth-child(4n+2) { transform: rotate(1.6deg); }
.tpx-rev__grid .tpx-rev__card:nth-child(4n+3) { transform: rotate(-1.2deg); }
.tpx-rev__grid .tpx-rev__card:nth-child(4n+4) { transform: rotate(2.2deg); }

.tpx-rev__card:hover {
  transform: rotate(0deg) scale(1.03);
  box-shadow: 6px 8px 0 rgba(43, 27, 18, 0.35);
  z-index: 2;
}

/* Tape strip on the top edge */
.tpx-rev__card::before {
  content: '';
  position: absolute;
  top: -12px;
  left: 50%;
  transform: translateX(-50%) rotate(-4deg);
  width: 92px;
  height: 26px;
  background: rgba(255, 236, 190, 0.85);
  border: 1px solid rgba(43, 27, 18, 0.18);
  box-shadow: 1px 1px 0 rgba(43, 27, 18, 0.15);
  z-index: 3;
}

.tpx-rev__img {
  display: block;
  width: 100%;
  aspect-ratio: 1 / 1;
  object-fit: cover;
  object-position: center;
  border: 1px solid rgba(43, 27, 18, 0.2);
}

.tpx-rev__body {
  padding: 12px 6px 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 5px;
}

.tpx-rev__paws { display: flex; gap: 3px; justify-content: center; }

.tpx-rev__paw {
  width: 19px;
  height: 19px;
  color: rgba(43, 27, 18, 0.15);
}

.tpx-rev__paw--on { color: var(--pc-orange, #ee7b28); }

.tpx-rev__quote {
  font-size: 0.95rem;
  font-style: italic;
  color: var(--pc-text, #2d2d2d);
  opacity: 0.8;
  line-height: 1.45;
  margin: 0;
}

.tpx-rev__name {
  font-family: 'Fredoka', sans-serif;
  font-size: 1.05rem;
  font-weight: 600;
  color: var(--pc-text, #2d2d2d);
}

/* Rotated cards need breathing room so they don't clip */
.tpx-rev__grid { padding: 14px 6px 10px; }

/* ---- Back in stock signup ---- */
.tp-bis {
  background: #FFF4D9;
  border: 2.5px solid var(--pc-text, #2d2d2d);
  border-radius: 16px;
  box-shadow: 4px 4px 0 var(--pc-text, #2d2d2d);
  padding: 18px 20px;
  margin-top: 14px;
}

.tp-bis__heading {
  font-family: 'Fredoka', sans-serif;
  font-size: 1.25rem;
  font-weight: 600;
  color: var(--pc-text, #2d2d2d);
  margin: 0 0 4px;
}

.tp-bis__text {
  font-size: 0.95rem;
  color: var(--pc-text, #2d2d2d);
  opacity: 0.8;
  margin: 0 0 12px;
  line-height: 1.45;
}

.tp-bis__form {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.tp-bis__input {
  flex: 1;
  min-width: 180px;
  padding: 0.7rem 0.9rem;
  font-size: 1rem;
  background: #fff;
  border: 2px solid var(--pc-text, #2d2d2d);
  border-radius: 10px;
  color: var(--pc-text, #2d2d2d);
}

.tp-bis__input:focus {
  outline: 2px solid var(--pc-orange, #ee7b28);
  outline-offset: 1px;
}

.tp-bis__btn {
  padding: 0.7rem 1.3rem;
  font-family: 'Fredoka', sans-serif;
  font-size: 1rem;
  font-weight: 600;
  color: #fff;
  background: var(--pc-green, #2eaa5f);
  border: 2px solid var(--pc-text, #2d2d2d);
  border-radius: 10px;
  box-shadow: 3px 3px 0 var(--pc-text, #2d2d2d);
  cursor: pointer;
  white-space: nowrap;
}

.tp-bis__btn:hover {
  transform: translate(2px, 2px);
  box-shadow: 1px 1px 0 var(--pc-text, #2d2d2d);
}

.tp-bis__success {
  font-size: 1rem;
  font-weight: 700;
  color: var(--pc-green-dark, #228a4a);
  margin: 0;
}

/* ---- Sticky mobile bar ---- */
.tp-sticky-bar {
  display: none;
  position: fixed; bottom: 0; left: 0; right: 0; z-index: 200;
  background: #FFF4D9;
  border-top: 2.5px solid var(--pc-text, #2d2d2d);
  box-shadow: 0 -4px 16px rgba(0,0,0,0.12);
  padding: 10px 16px;
  align-items: center; gap: 12px;
}
@media screen and (max-width: 899px) {
  .tp-sticky-bar { display: flex; }
  .tp-sticky-bar.tp-hidden { display: none; }
}

.tp-sticky-bar__info { flex: 1; min-width: 0; }
.tp-sticky-bar__title { font-family: 'Fredoka', sans-serif; font-size: 0.95rem; font-weight: 600; color: var(--pc-text, #2d2d2d); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.tp-sticky-bar__price { font-family: 'Nunito Sans', sans-serif; font-size: 0.88rem; font-weight: 700; color: var(--pc-text, #2d2d2d); }
.tp-sticky-bar__price--sale { color: var(--pc-sale-red, #e8372b); }

.tp-sticky-bar__btn {
  flex-shrink: 0; padding: 11px 22px;
  font-family: 'Fredoka', sans-serif; font-size: 1rem; font-weight: 600;
  color: var(--pc-white, #ffffff); background: var(--pc-green, #2eaa5f);
  border: 2px solid var(--pc-text, #2d2d2d);
  border-radius: 999px; box-shadow: 3px 3px 0 var(--pc-text, #2d2d2d);
  cursor: pointer; white-space: nowrap;
}
.tp-sticky-bar__btn:disabled { opacity: 0.5; cursor: not-allowed; box-shadow: none; }

/* ── Low Stock Warning Notice ──────────────────────────────── */
@keyframes tp-warn-pulse {
  0%, 100% { transform: scale(1); }
  50%       { transform: scale(1.18); }
}

.tp-warning {
  position: relative;
  background: #FFF4D9;
  border: 2.5px solid #EE7B28;
  border-radius: 16px;
  box-shadow: 5px 5px 0 #2B1B12;
  padding: 14px 18px 14px 16px;
  display: flex;
  align-items: flex-start;
  gap: 12px;
  overflow: hidden;
}

/* bold orange left stripe */
.tp-warning::before {
  content: '';
  position: absolute;
  top: 0; left: 0; bottom: 0;
  width: 5px;
  background: linear-gradient(180deg, #f59f2b 0%, #EE7B28 100%);
  border-radius: 13px 0 0 13px;
}

.tp-warning__icon {
  font-size: 1.55rem;
  line-height: 1;
  flex-shrink: 0;
  margin-top: 1px;
}

@media (prefers-reduced-motion: no-preference) {
  .tp-warning__icon { animation: tp-warn-pulse 2.2s ease-in-out infinite; }
}

.tp-warning__body { flex: 1; min-width: 0; }

.tp-warning__top {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 5px;
  flex-wrap: wrap;
}

.tp-warning__badge {
  display: inline-flex;
  align-items: center;
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.65rem;
  font-weight: 900;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #fff;
  background: #EE7B28;
  border: 1.5px solid #2B1B12;
  border-radius: 999px;
  padding: 2px 9px;
  box-shadow: 1.5px 1.5px 0 #2B1B12;
  line-height: 1.5;
}

.tp-warning__heading {
  font-family: 'Fredoka', sans-serif;
  font-size: 1.15rem;
  font-weight: 700;
  color: #2B1B12;
  margin: 0;
  line-height: 1.2;
}

.tp-warning__text {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.85rem;
  line-height: 1.55;
  color: #2B1B12;
  opacity: 0.72;
  margin: 4px 0 0;
}

.tp-warning__stock {
  display: inline-block;
  margin-top: 6px;
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.8rem;
  font-weight: 800;
  color: #e8372b;
  background: rgba(232,55,43,0.08);
  border: 1.5px solid rgba(232,55,43,0.3);
  border-radius: 999px;
  padding: 2px 10px;
}

/* ---- Bottom spacing ---- */
.tp-section-end { padding-bottom: var(--tp-pb, 64px); }

/* ---- Mobile tightening ---- */
@media screen and (max-width: 749px) {
  .tp-wrap, .tp-desc-section, .tp-lower, .tp-story, .tp-specs, .tp-related, .tp-faq {
    padding-left: 1rem; padding-right: 1rem;
  }
}

/* ============================================================
   FEATURE ROWS  (tp-feat-*)
   ============================================================ */

/* Full-bleed container — direct child bands span edge-to-edge */
.tp-feat {
  max-width: none;
  margin: 3.5rem 0 0;
  padding: 0;
}

/* Each band is a full-width stripe.
   Odd bands receive .tc-cream-paw-bg (cream + paw layer identical to
   homepage sections). Even bands are transparent — global paws show on white. */
.tp-feat__band {
  /* no max-width, no padding — full-bleed */
}

/* Inner row: centered content container within the band */
.tp-feat__row {
  display: flex;
  gap: 3.5rem;
  align-items: center;
  max-width: 1200px;
  margin: 0 auto;
  padding: 4.5rem 1.5rem;
}

.tp-feat__row--reverse { flex-direction: row-reverse; }

/* Image side */
.tp-feat__img-wrap {
  flex: 1 1 45%;
  min-width: 0;
  border: 3px solid var(--pc-text, #2B1B12);
  border-radius: 20px;
  box-shadow: 6px 8px 0 rgba(43, 27, 18, 0.82);
  overflow: hidden;
  background: #FFF4D9;
  flex-shrink: 0;
}

.tp-feat__img {
  width: 100%;
  aspect-ratio: 4 / 3;
  object-fit: cover;
  display: block;
  transition: transform 0.35s ease;
}

.tp-feat__row:hover .tp-feat__img { transform: scale(1.03); }

/* Text side */
.tp-feat__content {
  flex: 1 1 50%;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.tp-feat__eyebrow {
  display: inline-block;
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.78rem;
  font-weight: 800;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--pc-orange, #EE7B28);
  background: rgba(238, 123, 40, 0.1);
  border: 1.5px solid rgba(238, 123, 40, 0.25);
  border-radius: 999px;
  padding: 4px 14px;
  line-height: 1.4;
  width: fit-content;
}

.tp-feat__title {
  font-family: 'Fredoka', sans-serif;
  font-size: clamp(1.5rem, 2.8vw, 2rem);
  font-weight: 700;
  color: var(--pc-text, #2B1B12);
  margin: 0;
  line-height: 1.2;
}

.tp-feat__body {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 1rem;
  line-height: 1.75;
  color: var(--pc-text, #2B1B12);
  opacity: 0.82;
  max-width: 54ch;
}

.tp-feat__body p { margin: 0 0 0.75rem; }
.tp-feat__body p:last-child { margin-bottom: 0; }

.tp-feat__body h2,
.tp-feat__body h3 {
  font-family: 'Fredoka', sans-serif;
  font-size: clamp(1.4rem, 2.5vw, 1.9rem);
  font-weight: 700;
  color: var(--pc-text, #2B1B12);
  opacity: 1;
  margin: 0 0 0.75rem;
  line-height: 1.2;
}

.tp-feat__body ul,
.tp-feat__body ol {
  list-style: none;
  padding: 0;
  margin: 0.25rem 0 0;
  display: flex;
  flex-direction: column;
  gap: 0.55rem;
}

.tp-feat__body li {
  display: flex;
  align-items: flex-start;
  gap: 0.55rem;
  font-size: 0.95rem;
  font-weight: 600;
  opacity: 1;
  color: var(--pc-text, #2B1B12);
  line-height: 1.4;
}

.tp-feat__body li::before {
  content: '';
  flex-shrink: 0;
  display: inline-block;
  width: 18px;
  height: 18px;
  margin-top: 1px;
  background-color: var(--pc-green, #4F8A2F);
  border-radius: 50%;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 20 20' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpolyline points='5 10 8.5 13.5 15 6.5' stroke='white' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
  background-size: 14px 14px;
  background-repeat: no-repeat;
  background-position: center;
}

.tp-feat__bullets {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.625rem;
}

.tp-feat__bullet {
  display: flex;
  align-items: flex-start;
  gap: 0.6rem;
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--pc-text, #2B1B12);
  line-height: 1.4;
}

.tp-feat__check {
  flex-shrink: 0;
  width: 18px;
  height: 18px;
  margin-top: 1px;
  color: var(--pc-green, #4F8A2F);
}

@media screen and (max-width: 749px) {
  .tp-feat__row,
  .tp-feat__row--reverse {
    flex-direction: column;
    gap: 1.5rem;
    padding: 2.5rem 1rem;
  }
  .tp-feat__img-wrap { flex-basis: auto; width: 100%; }
  .tp-feat__content { flex-basis: auto; }
  .tp-feat { margin-top: 2.5rem; }
}

/* ── Quantity Discount Message ─────────────────────────────── */
/* Quantity discount box */
.tp-qty-disc {
  background: #FFF8E7;
  border: 3px solid #2B1B12;
  border-radius: 18px;
  box-shadow: 6px 6px 0 #C05000;
  padding: 18px 20px 16px 27px;
  position: relative;
  overflow: hidden;
  transition: border-color 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
}
/* Orange left stripe — locked */
.tp-qty-disc::before {
  content: '';
  position: absolute;
  top: 0; left: 0; bottom: 0;
  width: 9px;
  background: #D45E00;
  transition: background 0.3s ease, width 0.3s ease;
}
/* Unlocked overrides */
.tp-qty-disc[data-qty-disc-locked="false"] {
  border-color: #2D7D12;
  box-shadow: 6px 6px 0 #2D7D12;
  background: #F2FCE8;
  padding-left: 20px;
}
.tp-qty-disc[data-qty-disc-locked="false"]::before {
  width: 7px;
  background: linear-gradient(180deg, #5CB830 0%, #2D7D12 100%);
}

/* Two-column body */
.tp-qty-disc__body {
  display: flex;
  align-items: center;
  gap: 16px;
}

/* Big orange % stamp — locked only */
.tp-qty-disc__stamp {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 72px;
  height: 72px;
  background: #D45E00;
  border: 3px solid #2B1B12;
  border-radius: 14px;
  box-shadow: 3px 3px 0 #2B1B12;
  color: #fff;
  text-align: center;
  line-height: 1;
}
.tp-qty-disc[data-qty-disc-locked="false"] .tp-qty-disc__stamp { display: none; }
.tp-qty-disc__stamp-pct {
  font-family: 'Fredoka', sans-serif;
  font-size: 2rem;
  font-weight: 700;
  line-height: 1;
  display: block;
}
.tp-qty-disc__stamp-off {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.6rem;
  font-weight: 900;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  display: block;
  margin-top: 2px;
  opacity: 0.9;
}

/* Content column */
.tp-qty-disc__content { flex: 1; min-width: 0; }

/* Unlocked icon */
.tp-qty-disc__icon-wrap {
  display: none;
  font-size: 1.6rem;
  line-height: 1;
  margin-bottom: 6px;
}
.tp-qty-disc[data-qty-disc-locked="false"] .tp-qty-disc__icon-wrap { display: block; }

/* Badge */
.tp-qty-disc__badge {
  display: inline-flex;
  align-items: center;
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.65rem;
  font-weight: 900;
  letter-spacing: 0.13em;
  text-transform: uppercase;
  color: #fff;
  background: #D45E00;
  border: 2px solid #2B1B12;
  border-radius: 6px;
  padding: 3px 10px;
  box-shadow: 2px 2px 0 #2B1B12;
  line-height: 1.4;
  margin-bottom: 6px;
  transition: background 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
}
.tp-qty-disc[data-qty-disc-locked="false"] .tp-qty-disc__badge {
  background: #2D7D12;
  border-color: #2D7D12;
  box-shadow: 2px 2px 0 #1a5009;
}

/* Heading */
.tp-qty-disc__heading {
  font-family: 'Fredoka', sans-serif;
  font-size: 1.35rem;
  font-weight: 700;
  color: #2B1B12;
  margin: 0 0 4px;
  line-height: 1.18;
  transition: color 0.3s ease;
  letter-spacing: -0.01em;
}
.tp-qty-disc[data-qty-disc-locked="false"] .tp-qty-disc__heading {
  font-size: 1.4rem;
  color: #1A5009;
  letter-spacing: 0;
}

/* Subtext */
.tp-qty-disc__sub {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.82rem;
  font-weight: 600;
  color: rgba(43,27,18,0.72);
  margin: 0;
  line-height: 1.4;
  transition: color 0.3s ease;
}
.tp-qty-disc[data-qty-disc-locked="false"] .tp-qty-disc__sub {
  font-size: 0.9rem;
  color: rgba(26,80,9,0.82);
}

/* Progress */
.tp-qty-disc__progress {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 10px;
}
.tp-qty-disc__prog-track {
  display: flex;
  gap: 4px;
  flex: 1;
}
.tp-qty-disc__prog-step {
  height: 9px;
  flex: 1;
  background: rgba(43,27,18,0.13);
  border-radius: 5px;
  transition: background 0.3s ease;
}
.tp-qty-disc__prog-step.tp-prog-active { background: #D45E00; }
.tp-qty-disc[data-qty-disc-locked="false"] .tp-qty-disc__prog-step.tp-prog-active { background: #2D7D12; }
.tp-qty-disc__prog-label {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.72rem;
  font-weight: 800;
  color: rgba(43,27,18,0.6);
  white-space: nowrap;
  transition: color 0.3s ease;
}
.tp-qty-disc[data-qty-disc-locked="false"] .tp-qty-disc__prog-label { color: #2D7D12; }

/* Urgency strip — locked only */
.tp-qty-disc__urgency {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.8rem;
  font-weight: 800;
  color: #B04E00;
  margin: 12px 0 0;
  padding: 7px 12px;
  background: rgba(212,94,0,0.1);
  border-radius: 8px;
  border-left: 3px solid #D45E00;
  line-height: 1.4;
}
.tp-qty-disc[data-qty-disc-locked="false"] .tp-qty-disc__urgency { display: none; }

/* Almost state — 1 item away, stronger urgency */
.tp-qty-disc[data-qty-disc-almost="true"] { border-color: #B83200; box-shadow: 6px 6px 0 #B83200; }
.tp-qty-disc[data-qty-disc-almost="true"]::before { background: #B83200; }
.tp-qty-disc[data-qty-disc-almost="true"] .tp-qty-disc__badge { background: #B83200; letter-spacing: 0.06em; }
.tp-qty-disc[data-qty-disc-almost="true"] .tp-qty-disc__urgency {
  background: rgba(184,50,0,0.15);
  border-left-color: #B83200;
  color: #7A2200;
  font-size: 0.85rem;
}

/* Savings — unlocked only, shown by JS */
.tp-qty-disc__savings {
  display: none;
  font-family: 'Nunito Sans', sans-serif;
  font-size: 0.82rem;
  font-weight: 800;
  color: #1A5009;
  margin: 10px 0 0;
  padding: 6px 12px;
  background: rgba(45,125,18,0.1);
  border-radius: 8px;
  border-left: 3px solid #2D7D12;
  line-height: 1.4;
}

@media (prefers-reduced-motion: reduce) {
  .tp-qty-disc,
  .tp-qty-disc::before,
  .tp-qty-disc__badge,
  .tp-qty-disc__heading,
  .tp-qty-disc__sub,
  .tp-qty-disc__savings,
  .tp-qty-disc__prog-step,
  .tp-qty-disc__prog-label { transition: none; }
}
{% endstylesheet %}

{%- liquid
  assign tp_product       = product
  assign tp_variant       = tp_product.selected_or_first_available_variant
  assign tp_on_sale       = false
  if tp_variant.compare_at_price > tp_variant.price
    assign tp_on_sale = true
  endif
  assign tp_pt = section.settings.padding_top  | append: 'px'
  assign tp_pb = section.settings.padding_bottom | append: 'px'

  assign tp_exchange        = localization.country.currency.exchange_rate | default: 1
  if tp_exchange == 0
    assign tp_exchange = 1
  endif
  assign tp_threshold_cents = section.settings.free_shipping_threshold_usd | times: tp_exchange | times: 100 | round
  assign tp_cart_cents      = cart.total_price
  assign tp_progress        = 0
  if tp_threshold_cents > 0
    if tp_cart_cents >= tp_threshold_cents
      assign tp_progress = 100
    else
      assign tp_progress = tp_cart_cents | times: 100 | divided_by: tp_threshold_cents
    endif
  endif
  assign tp_remaining = tp_threshold_cents | minus: tp_cart_cents | money

  assign tp_has_warning = false
  for _wt in tp_product.tags
    assign _wt_lc = _wt | downcase
    if _wt_lc == 'warning'
      assign tp_has_warning = true
      break
    endif
  endfor
  assign tp_warn_inv_qty = 0
  if section.settings.warning_show_inventory and tp_variant.inventory_management == 'shopify' and tp_variant.inventory_policy == 'deny'
    if tp_variant.inventory_quantity > 0 and tp_variant.inventory_quantity <= 10
      assign tp_warn_inv_qty = tp_variant.inventory_quantity
    endif
  endif
-%}

<style>
  #tp-{{ section.id }} { --tp-pt: {{ tp_pt }}; --tp-pb: {{ tp_pb }}; }
  #shopify-section-{{ section.id }} { background: #FFFFFF; }
</style>

{%- comment -%}
  Product structured data (schema.org/JSON-LD) — lets Google show price and
  stock status as rich results in search. Deliberately NO aggregateRating/review
  block: the paw-rating row above is not real review data, and fabricated
  Review/AggregateRating schema is a Google Search spam violation that can
  trigger a manual action against the whole site. Add real rating schema only
  once Judge.me (or similar) provides genuine review data.
{%- endcomment -%}
{%- assign tp_ld_media = tp_product.media.first | default: tp_product.featured_media -%}
{%- if tp_ld_media != blank -%}
  {%- assign tp_ld_img = tp_ld_media.preview_image -%}
{%- else -%}
  {%- assign tp_ld_img = tp_product.featured_image -%}
{%- endif -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": {{ tp_product.title | json }},
  "description": {{ tp_product.description | strip_html | json }},
  {%- if tp_ld_img != blank -%}
  {%- assign tp_ld_img_url = tp_ld_img | image_url: width: 900 -%}
  {%- unless tp_ld_img_url contains 'https:' -%}{%- assign tp_ld_img_url = 'https:' | append: tp_ld_img_url -%}{%- endunless -%}
  "image": [{{ tp_ld_img_url | json }}],
  {%- endif -%}
  "sku": {{ tp_variant.sku | json }},
  "brand": {
    "@type": "Brand",
    "name": {{ shop.name | json }}
  },
  "offers": {
    "@type": "Offer",
    "url": {{ request.origin | append: tp_product.url | json }},
    "priceCurrency": {{ cart.currency.iso_code | default: shop.currency | json }},
    "price": {{ tp_variant.price | divided_by: 100.0 | json }},
    "priceValidUntil": "{{ 'now' | date: '%s' | plus: 31536000 | date: '%Y-%m-%d' }}",
    "availability": "https://schema.org/{% if tp_variant.available %}InStock{% else %}OutOfStock{% endif %}",
    "itemCondition": "https://schema.org/NewCondition",
    "hasMerchantReturnPolicy": {
      "@type": "MerchantReturnPolicy",
      "applicableCountry": ["US","CA","GB","AU","SK","CZ","DE","AT","FR","IT","ES","NL","BE","PL","IE"],
      "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
      "merchantReturnDays": 14,
      "returnMethod": "https://schema.org/ReturnByMail",
      "returnFees": "https://schema.org/ReturnFeesCustomerResponsibility"
    }
  }
}
</script>
{%- if tp_product.collections.size > 0 -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": {{ request.origin | json }} },
    { "@type": "ListItem", "position": 2, "name": {{ tp_product.collections.first.title | json }}, "item": {{ request.origin | append: tp_product.collections.first.url | json }} },
    { "@type": "ListItem", "position": 3, "name": {{ tp_product.title | json }} }
  ]
}
</script>
{%- endif -%}

<section id="tp-{{ section.id }}">
  {%- form 'product', tp_product, id: 'tp-form' -%}
    {{- '' -}}
    <input type="hidden" name="id" id="tp-variant-id" value="{{ product.selected_or_first_available_variant.id }}">

    <div class="tp-wrap{% unless tp_variant.available %} tp-soldout-mode{% endunless %}">
      <div class="tp-main">

        <!-- ======== GALLERY ======== -->
        <div class="tp-gallery">
          <div class="tp-gallery__main">

            {%- if section.settings.show_sale_badge and tp_on_sale -%}
              <div class="tp-gallery__badge">{{ section.settings.sale_badge_text }}</div>
            {%- endif -%}

            {%- assign tp_main_media = tp_product.media.first | default: tp_product.featured_media -%}
            {%- if tp_main_media != blank -%}
              {%- assign tp_main_alt = tp_main_media.alt | default: tp_product.title | escape -%}
              {%- assign tp_main_src = tp_main_media.preview_image -%}
            {%- else -%}
              {%- assign tp_main_alt = tp_product.title | escape -%}
              {%- assign tp_main_src = tp_product.featured_image -%}
            {%- endif -%}

            {%- if tp_main_src != blank -%}
              {{- tp_main_src | image_url: width: 900 | image_tag: id: 'tp-main-img', class: 'tp-gallery__main-img', alt: tp_main_alt, loading: 'eager', fetchpriority: 'high', width: 900, height: 900 -}}
            {%- endif -%}

          </div>

          {%- if tp_product.media.size > 1 -%}
            <div class="tp-gallery__thumbs">
              {%- for media in tp_product.media -%}
                {%- assign tp_th_alt = media.alt | default: tp_product.title | escape -%}
                {%- assign tp_th_full = media.preview_image | image_url: width: 900 -%}
                <button type="button"
                  class="tp-gallery__thumb{% if forloop.first %} tp-active{% endif %}"
                  data-src="{{ tp_th_full }}"
                  aria-label="{{ tp_th_alt }}">
                  {{- media.preview_image | image_url: width: 144 | image_tag: alt: tp_th_alt, loading: 'lazy', width: 72, height: 72 -}}
                </button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
        <!-- /gallery -->

        <!-- ======== INFO PANEL ======== -->
        <div class="tp-info">

          <!-- Breadcrumb -->
          <nav class="tp-breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span aria-hidden="true">/</span>
            {%- if tp_product.collections.size > 0 -%}
              <a href="{{ tp_product.collections.first.url }}">{{ tp_product.collections.first.title }}</a>
              <span aria-hidden="true">/</span>
            {%- endif -%}
            <span>{{ tp_product.title }}</span>
          </nav>

          <!-- Paw rating -->
          {%- if section.settings.show_paw_rating -%}
            {%- assign _tp_ri = product.id | modulo: 6 | plus: 45 -%}
            {%- assign _tp_rw = _tp_ri | divided_by: 10 -%}
            {%- assign _tp_rd = _tp_ri | modulo: 10 -%}
            {%- assign _tp_reviews = product.id | modulo: 301 | plus: 100 -%}
            {%- assign tp_paw_n = 5 -%}
            <div class="tp-paw-row">
              <div class="tp-paws" role="img" aria-label="{{ _tp_rw }}.{{ _tp_rd }} out of 5">
                {%- for i in (1..5) -%}
                  {%- if i <= tp_paw_n -%}
                    <svg class="tp-paw tp-paw--on" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <ellipse cx="6.5" cy="9" rx="2" ry="2.5"/>
                      <ellipse cx="10" cy="6.5" rx="2" ry="2.5"/>
                      <ellipse cx="14" cy="6.5" rx="2" ry="2.5"/>
                      <ellipse cx="17.5" cy="9" rx="2" ry="2.5"/>
                      <path d="M12 22.5C8.5 22.5 5.5 20.5 5.5 17.5C5.5 14.5 7.5 12.5 12 12.5C16.5 12.5 18.5 14.5 18.5 17.5C18.5 20.5 15.5 22.5 12 22.5Z"/>
                    </svg>
                  {%- else -%}
                    <svg class="tp-paw tp-paw--off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <ellipse cx="6.5" cy="9" rx="2" ry="2.5"/>
                      <ellipse cx="10" cy="6.5" rx="2" ry="2.5"/>
                      <ellipse cx="14" cy="6.5" rx="2" ry="2.5"/>
                      <ellipse cx="17.5" cy="9" rx="2" ry="2.5"/>
                      <path d="M12 22.5C8.5 22.5 5.5 20.5 5.5 17.5C5.5 14.5 7.5 12.5 12 12.5C16.5 12.5 18.5 14.5 18.5 17.5C18.5 20.5 15.5 22.5 12 22.5Z"/>
                    </svg>
                  {%- endif -%}
                {%- endfor -%}
              </div>
              <span class="tp-paw-text">{{ _tp_rw }}.{{ _tp_rd }} • {{ _tp_reviews }} happy pets</span>
            </div>
          {%- endif -%}

          <!-- Title -->
          <h1 class="tp-title">{{ tp_product.title }}</h1>

          <!-- Subtitle -->
          {%- if section.settings.subtitle != blank -%}
            <p class="tp-subtitle">{{ section.settings.subtitle }}</p>
          {%- endif -%}

          <!-- Price -->
          <div class="tp-price-row" id="tp-price-row">
            {%- if tp_on_sale -%}
              <span class="tp-price tp-price--sale" id="tp-price">{{ tp_variant.price | money }}</span>
              <span class="tp-compare" id="tp-compare">{{ tp_variant.compare_at_price | money }}</span>
              {%- assign tp_save_amt = tp_variant.compare_at_price | minus: tp_variant.price -%}
              <span class="tp-savings" id="tp-savings">Save {{ tp_save_amt | money }}</span>
            {%- else -%}
              <span class="tp-price" id="tp-price">{{ tp_variant.price | money }}</span>
              <span class="tp-compare" id="tp-compare" style="display:none"></span>
              <span class="tp-savings" id="tp-savings" style="display:none"></span>
            {%- endif -%}
          </div>

          <!-- Variant pills -->
          {%- unless tp_product.has_only_default_variant -%}
            <div class="tp-variants">
              {%- for option in tp_product.options_with_values -%}
                {%- assign tp_oi = forloop.index0 -%}
                <div class="tp-option-group" data-option-index="{{ tp_oi }}">
                  <div class="tp-option-label">
                    {{ option.name }}<em id="tp-sel-{{ tp_oi }}" aria-live="polite" aria-atomic="true">{{ option.selected_value }}</em>
                  </div>
                  <div class="tp-pills" role="group" aria-label="{{ option.name }}">
                    {%- for value in option.values -%}
                      {%- if option.selected_value == value -%}
                        {%- assign tp_pill_on = true -%}
                      {%- else -%}
                        {%- assign tp_pill_on = false -%}
                      {%- endif -%}
                      <button type="button"
                        class="tp-pill{% if tp_pill_on %} tp-selected{% endif %}"
                        data-option-index="{{ tp_oi }}"
                        data-value="{{ value | escape }}"
                        aria-pressed="{{ tp_pill_on }}"
                      >{{ value }}</button>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- endunless -%}

          <!-- Variant availability message -->
          <div id="tp-variant-msg" class="tp-variant-msg" aria-live="polite" style="display:none"></div>

          <!-- Variant data store (no name= so it does not submit a duplicate id) -->
          <select id="tp-variant-select" class="tp-variant-select-native" aria-hidden="true">
            {%- for variant in tp_product.variants -%}
              {%- assign tp_var_alt = variant.featured_media.alt | default: tp_product.title | escape -%}
              {%- if variant.featured_media != blank -%}
                {%- assign tp_var_img = variant.featured_media.preview_image | image_url: width: 900 -%}
              {%- else -%}
                {%- assign tp_var_img = '' -%}
              {%- endif -%}
              <option
                value="{{ variant.id }}"
                {% if variant == tp_variant %}selected{% endif %}
                {% unless variant.available %}disabled{% endunless %}
                data-price="{{ variant.price }}"
                data-compare="{{ variant.compare_at_price | default: 0 }}"
                data-img="{{ tp_var_img }}"
                data-alt="{{ tp_var_alt }}"
              >{{ variant.title }}</option>
            {%- endfor -%}
          </select>

          <!-- Quantity -->
          <div class="tp-qty-row">
            <span class="tp-qty-label">Qty</span>
            <div class="tp-qty">
              <button type="button" class="tp-qty__btn" id="tp-minus" aria-label="Decrease">&#8722;</button>
              <input type="number" name="quantity" id="tp-qty" class="tp-qty__input" value="1" min="1" aria-label="Quantity">
              <button type="button" class="tp-qty__btn" id="tp-plus" aria-label="Increase">&#43;</button>
            </div>
          </div>

          <!-- Quantity Discount Message -->
          {%- if section.settings.qty_discount_enabled -%}
            {%- assign _qdmin = section.settings.qty_discount_min | default: 2 -%}
            {%- assign _qdpct = section.settings.qty_discount_pct | default: '25%' -%}
            {%- assign _qdlh  = section.settings.qty_discount_locked_heading   | default: 'Add 2 Items — Get 25% Off Everything' -%}
            {%- assign _qdlt  = section.settings.qty_discount_locked_text      | default: 'No code needed. Discount applies automatically at checkout.' -%}
            {%- assign _qduh  = section.settings.qty_discount_unlocked_heading | default: 'Your Whole Cart Is 25% Off' -%}
            {%- assign _qdut  = section.settings.qty_discount_unlocked_text    | default: 'Your automatic 25% cart discount is unlocked and will apply at checkout.' -%}
            {%- assign _qd_cnt      = cart.item_count | default: 0 -%}
            {%- assign _qd_min1     = _qdmin | minus: 1 -%}
            {%- assign _qd_need     = _qdmin | minus: _qd_cnt -%}
            {%- if _qd_cnt >= _qdmin -%}
              {%- assign _qd_locked = 'false' -%}
              {%- assign _qd_almost = 'false' -%}
            {%- elsif _qd_cnt == _qd_min1 -%}
              {%- assign _qd_locked = 'true' -%}
              {%- assign _qd_almost = 'true' -%}
            {%- else -%}
              {%- assign _qd_locked = 'true' -%}
              {%- assign _qd_almost = 'false' -%}
            {%- endif -%}
            {%- capture _qd_prog_label -%}
              {%- if _qd_cnt >= _qdmin -%}Discount unlocked!
              {%- elsif _qd_need == 1 -%}Add 1 more item to unlock
              {%- else -%}Add {{ _qd_need }} more items to unlock{%- endif -%}
            {%- endcapture -%}
            {%- capture _qd_urgency -%}
              {%- if _qd_almost == 'true' -%}ONE MORE ITEM IN YOUR CART AND YOU GET {{ _qdpct }} OFF — NO CODE NEEDED!
              {%- elsif _qd_locked == 'true' -%}Add {{ _qd_need }} more item{%- if _qd_need != 1 -%}s{%- endif -%} to unlock {{ _qdpct }} off your entire order.
              {%- endif -%}
            {%- endcapture -%}
            <div class="tp-qty-disc"
                 data-qty-disc
                 data-qty-disc-locked="{{ _qd_locked }}"
                 data-qty-disc-almost="{{ _qd_almost }}"
                 data-qty-disc-min="{{ _qdmin }}"
                 data-qty-disc-pct="{{ _qdpct }}"
                 data-locked-heading="{{ _qdlh | escape }}"
                 data-locked-text="{{ _qdlt | escape }}"
                 data-unlocked-heading="{{ _qduh | escape }}"
                 data-unlocked-text="{{ _qdut | escape }}">
              <div class="tp-qty-disc__body">
                <div class="tp-qty-disc__stamp" aria-hidden="true">
                  <span class="tp-qty-disc__stamp-pct">{{ _qdpct }}</span>
                  <span class="tp-qty-disc__stamp-off">OFF</span>
                </div>
                <div class="tp-qty-disc__content">
                  <div class="tp-qty-disc__icon-wrap" aria-hidden="true">✅</div>
                  <span class="tp-qty-disc__badge" data-qty-disc-badge>UNLOCK CART DEAL</span>
                  <p class="tp-qty-disc__heading" data-qty-disc-heading>{{ _qdlh }}</p>
                  <p class="tp-qty-disc__sub" data-qty-disc-sub>{{ _qdlt }}</p>
                  <div class="tp-qty-disc__progress">
                    <div class="tp-qty-disc__prog-track" data-qty-disc-track>
                      {%- for i in (1.._qdmin) -%}
                        <div class="tp-qty-disc__prog-step{%- if _qd_cnt >= i %} tp-prog-active{%- endif -%}"></div>
                      {%- endfor -%}
                    </div>
                    <span class="tp-qty-disc__prog-label" data-qty-disc-prog-label>{{ _qd_prog_label | strip }}</span>
                  </div>
                </div>
              </div>
              <p class="tp-qty-disc__urgency" data-qty-disc-urgency>{{ _qd_urgency | strip }}</p>
              <p class="tp-qty-disc__savings" data-qty-disc-savings></p>
            </div>
          {%- endif -%}

          <!-- Promo box -->
          {%- if section.settings.promo_title != blank -%}
            <div class="tp-promo">
              <div class="tp-promo__head">
                {%- if section.settings.promo_emoji != blank -%}
                  <span class="tp-promo__emoji">{{ section.settings.promo_emoji }}</span>
                {%- endif -%}
                <span class="tp-promo__title">{{ section.settings.promo_title }}</span>
              </div>
              {%- if section.settings.promo_text != blank -%}
                <p class="tp-promo__text">{{ section.settings.promo_text }}</p>
              {%- endif -%}
              {%- if section.settings.show_countdown -%}
                <div class="tp-countdown" data-tailand-countdown>
                  <span class="tp-countdown__label">{{ section.settings.countdown_label | default: "Today's deal ends in" }}</span>
                  <div class="tp-countdown__units">
                    <div class="tp-countdown__unit"><span class="tp-countdown__num" data-cd-h>--</span><span class="tp-countdown__sub">Hrs</span></div>
                    <span class="tp-countdown__sep">:</span>
                    <div class="tp-countdown__unit"><span class="tp-countdown__num" data-cd-m>--</span><span class="tp-countdown__sub">Min</span></div>
                    <span class="tp-countdown__sep">:</span>
                    <div class="tp-countdown__unit"><span class="tp-countdown__num" data-cd-s>--</span><span class="tp-countdown__sub">Sec</span></div>
                  </div>
                  <noscript><span class="tp-countdown__label">Today's deal is available now.</span></noscript>
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}

          <!-- Free shipping bar -->
          {%- if section.settings.show_free_shipping and tp_threshold_cents > 0 -%}
            <div class="tp-ship-bar"
                 data-free-shipping-progress
                 data-free-shipping-threshold="{{ tp_threshold_cents }}"
                 data-fs-usd-cents="{{ section.settings.free_shipping_threshold_usd | times: 100 }}"
                 data-free-shipping-prefix="{{ section.settings.free_shipping_prefix | escape }}"
                 data-free-shipping-suffix="{{ section.settings.free_shipping_suffix | escape }}">
              <div class="tp-ship-bar__text">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                {%- if tp_progress >= 100 -%}
                  <span data-free-shipping-message>You unlocked <strong>free shipping!</strong> &#127881;</span>
                {%- else -%}
                  <span data-free-shipping-message>{{ section.settings.free_shipping_prefix }} <strong>{{ tp_remaining }}</strong> {{ section.settings.free_shipping_suffix }}</span>
                {%- endif -%}
              </div>
              <div class="tp-ship-bar__track">
                <div class="tp-ship-bar__fill" data-free-shipping-bar style="width:{{ tp_progress }}%"></div>
              </div>
            </div>
          {%- endif -%}

          <!-- Multi-buy -->
          {%- if section.settings.multibuy_text != blank -%}
            <div class="tp-multibuy">
              <span class="tp-multibuy__emoji">🐾</span>
              <span>{{ section.settings.multibuy_text }}</span>
            </div>
          {%- endif -%}


          <!-- Low Stock Warning -->
          {%- if section.settings.warning_enabled and tp_has_warning -%}
            <div class="tp-warning" role="status">
              <span class="tp-warning__icon" aria-hidden="true">🔥</span>
              <div class="tp-warning__body">
                <div class="tp-warning__top">
                  <span class="tp-warning__badge">Selling Fast</span>
                </div>
                <p class="tp-warning__heading">{{ section.settings.warning_heading }}</p>
                <p class="tp-warning__text">{{ section.settings.warning_body }}</p>
                {%- if tp_warn_inv_qty > 0 -%}
                  <span class="tp-warning__stock">Only {{ tp_warn_inv_qty }} left in stock</span>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}

          <!-- Add to Cart -->
          <div class="tp-cta">
            <button type="submit" name="add" id="tp-add-btn" class="tp-btn-cart"
              {% unless tp_variant.available %}disabled{% endunless %}>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
              <span id="tp-btn-text">
                {%- if tp_variant.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
              </span>
            </button>
          </div>

          <!-- Back in stock signup (shows only when selected variant is sold out) -->
          {%- if section.settings.show_back_in_stock -%}
            <div id="tp-bis" class="tp-bis"{% if tp_variant.available %} hidden{% endif %}>
              <p class="tp-bis__heading">Want it when it's back?</p>
              <p class="tp-bis__text">Leave your email and we'll let you know as soon as it's available again.</p>
              {%- comment -%}
                The real <form> lives OUTSIDE the product form (after endform) because
                browsers drop nested <form> tags. These controls reference it via the
                HTML form="" attribute — submitting here posts the customer form, not
                the surrounding product form.
              {%- endcomment -%}
              <div id="tp-bis-form-wrap" class="tp-bis__form">
                <label for="tp-bis-email" class="visually-hidden">Email address</label>
                <input id="tp-bis-email" type="email" name="contact[email]" form="tp-bis-form" class="tp-bis__input" placeholder="your@email.com" required autocomplete="email">
                <button type="submit" form="tp-bis-form" class="tp-bis__btn">Notify me</button>
              </div>
              <p class="tp-bis__success" id="tp-bis-success" hidden>You're on the list! We'll email you as soon as it's back. 🐾</p>
            </div>

            <script>
              (function () {
                var bis = document.getElementById('tp-bis');
                if (!bis) return;

                // Returning from a successful notify-me signup
                var params = new URLSearchParams(location.search);
                if (params.get('tc-bis') === '1') {
                  bis.hidden = false;
                  var wrap = document.getElementById('tp-bis-form-wrap');
                  var success = document.getElementById('tp-bis-success');
                  if (wrap) wrap.hidden = true;
                  if (success) success.hidden = false;
                  // They're subscribed now — stop the welcome popup from nagging,
                  // and strip markers so the popup script doesn't claim this signup.
                  try { localStorage.setItem('tcWelcome.done', '1'); } catch (e) {}
                  params.delete('tc-bis');
                  params.delete('customer_posted');
                  var qs = params.toString();
                  history.replaceState(null, '', location.pathname + (qs ? '?' + qs : ''));
                  return;
                }

                // Show/hide with variant availability by watching the ATC button label —
                // no changes needed inside the existing variant logic.
                var btnText = document.getElementById('tp-btn-text');
                if (!btnText) return;
                function syncBis() {
                  var t = btnText.textContent.trim();
                  if (t === 'Sold Out') bis.hidden = false;
                  else if (t === 'Add to Cart' || t === 'Unavailable') bis.hidden = true;
                  // transient labels ("Adding…") leave visibility unchanged
                }
                new MutationObserver(syncBis).observe(btnText, { childList: true, characterData: true, subtree: true });
                syncBis();
              })();
            </script>
          {%- endif -%}

          {%- comment -%}
            Sold-out mode (hides upsells: deal box, countdown, multibuy…) is intentionally
            OUTSIDE the show_back_in_stock check above — it must keep working even if the
            merchant turns the "notify me" signup off, since it watches the Add to Cart
            button label, not the BIS box.
          {%- endcomment -%}
          <script>
            (function () {
              var btnText = document.getElementById('tp-btn-text');
              var infoPanel = document.querySelector('.tp-wrap');
              if (!btnText || !infoPanel) return;
              function syncSoldOutMode() {
                var t = btnText.textContent.trim();
                if (t === 'Sold Out') infoPanel.classList.add('tp-soldout-mode');
                else if (t === 'Add to Cart' || t === 'Unavailable') infoPanel.classList.remove('tp-soldout-mode');
                // transient labels ("Adding…") leave the mode unchanged
              }
              new MutationObserver(syncSoldOutMode).observe(btnText, { childList: true, characterData: true, subtree: true });
              syncSoldOutMode();
            })();
          </script>

          <!-- Trust badges -->
          {%- if section.settings.show_trust_badges -%}
            <div class="tp-trust">
              <div class="tp-trust__item">
                <svg class="tp-trust__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                <span>{{ section.settings.trust_1 | default: 'Secure Checkout' }}</span>
              </div>
              <div class="tp-trust__item">
                <svg class="tp-trust__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 15L3 9l6-6"/><path d="M3 9h12a6 6 0 0 1 0 12H9"/></svg>
                <span>{{ section.settings.trust_2 | default: 'Easy Returns' }}</span>
              </div>
              <div class="tp-trust__item">
                <svg class="tp-trust__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                <span>{{ section.settings.trust_3 | default: 'Track Your Order' }}</span>
              </div>
              <div class="tp-trust__item">
                <svg class="tp-trust__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                <span>{{ section.settings.trust_4 | default: 'Pet-Friendly Pick' }}</span>
              </div>
            </div>
          {%- endif -%}

        </div>
        <!-- /info panel -->

      </div>
    </div>

  {%- endform -%}

  {%- comment -%} Back-in-stock form element — controls live inside the info panel and reference this via form="tp-bis-form" {%- endcomment -%}
  {%- if section.settings.show_back_in_stock -%}
    {%- form 'customer', id: 'tp-bis-form' -%}
      <input type="hidden" name="contact[tags]" value="back-in-stock,bis-{{ tp_product.handle }}">
      <input type="hidden" name="return_to" value="{{ tp_product.url }}?tc-bis=1">
    {%- endform -%}
  {%- endif -%}

  <!-- ======== FEATURE ROWS / DESCRIPTION ======== -->
  {%- assign tp_has_feat = false -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'feature_row' -%}{%- assign tp_has_feat = true -%}{%- break -%}{%- endif -%}
  {%- endfor -%}

  {%- assign tp_desc_norm   = tp_product.description | replace: '<hr/>', '<hr>' | replace: '<hr />', '<hr>' -%}
  {%- assign tp_desc_parts  = tp_desc_norm | split: '<hr>' -%}
  {%- assign tp_desc_rows   = false -%}
  {%- if tp_desc_parts.size > 1 -%}{%- assign tp_desc_rows = true -%}{%- endif -%}

  {%- if tp_has_feat -%}
    <div class="tp-feat">
      {%- assign tp_fr_idx = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type != 'feature_row' -%}{%- continue -%}{%- endif -%}
        {%- assign tp_fr_idx = tp_fr_idx | plus: 1 -%}
        {%- assign tp_fr_cls = 'tp-feat__row' -%}
        {%- if block.settings.layout == 'image_right' -%}
          {%- assign tp_fr_cls = 'tp-feat__row tp-feat__row--reverse' -%}
        {%- endif -%}
        {%- assign tp_fr_band = 'tp-feat__band' -%}
        {%- assign tp_fr_mod = tp_fr_idx | modulo: 2 -%}
        {%- if tp_fr_mod == 1 -%}{%- assign tp_fr_band = 'tp-feat__band tc-cream-paw-bg' -%}{%- endif -%}
        <div class="{{ tp_fr_band }}">
        <div class="{{ tp_fr_cls }}" {{ block.shopify_attributes }}>

          {%- if block.settings.image != blank -%}
            <div class="tp-feat__img-wrap">
              {{- block.settings.image | image_url: width: 900 | image_tag:
                    class: 'tp-feat__img',
                    alt: block.settings.title,
                    loading: 'lazy',
                    widths: '450, 600, 900',
                    sizes: '(max-width: 749px) 100vw, 45vw'
              -}}
            </div>
          {%- endif -%}

          <div class="tp-feat__content">
            {%- if block.settings.eyebrow != blank -%}
              <span class="tp-feat__eyebrow">{{ block.settings.eyebrow | escape }}</span>
            {%- endif -%}
            {%- if block.settings.title != blank -%}
              <h3 class="tp-feat__title">{{ block.settings.title | escape }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <div class="tp-feat__body">{{ block.settings.text }}</div>
            {%- endif -%}
            {%- assign tp_fr_bullets = block.settings.bullet_1 | append: '|||' | append: block.settings.bullet_2 | append: '|||' | append: block.settings.bullet_3 | append: '|||' | append: block.settings.bullet_4 -%}
            {%- assign tp_fr_bullet_arr = tp_fr_bullets | split: '|||' -%}
            {%- assign tp_fr_has_bullets = false -%}
            {%- for b in tp_fr_bullet_arr -%}
              {%- unless b == blank -%}{%- assign tp_fr_has_bullets = true -%}{%- break -%}{%- endunless -%}
            {%- endfor -%}
            {%- if tp_fr_has_bullets -%}
              <ul class="tp-feat__bullets">
                {%- for b in tp_fr_bullet_arr -%}
                  {%- if b == blank -%}{%- continue -%}{%- endif -%}
                  <li class="tp-feat__bullet">
                    <svg class="tp-feat__check" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <circle cx="10" cy="10" r="8.5" stroke="currentColor" stroke-width="2"/>
                      <polyline points="6.5 10 9 12.5 13.5 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span>{{ b | escape }}</span>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>

        </div>
        </div>
      {%- endfor -%}
    </div>
  {%- elsif tp_desc_rows -%}
    <div class="tp-feat">
      {%- comment -%}
        Feature-row images default to starting at the SECOND gallery image
        (offset 1), so the hero image isn't repeated. The 'first-image-description'
        product tag starts them at the first image (offset 0) instead.
      {%- endcomment -%}
      {%- assign tp_feat_img_offset = 1 -%}
      {%- for _ft in tp_product.tags -%}
        {%- assign _ft_lc = _ft | downcase -%}
        {%- if _ft_lc == 'first-image-description' -%}
          {%- assign tp_feat_img_offset = 0 -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}
      {%- assign tp_desc_idx = 0 -%}
      {%- for tp_part in tp_desc_parts -%}
        {%- assign tp_part_clean = tp_part | strip -%}
        {%- if tp_part_clean == blank -%}{%- continue -%}{%- endif -%}
        {%- assign tp_desc_idx = tp_desc_idx | plus: 1 -%}
        {%- assign tp_feat_img_idx = forloop.index0 | plus: tp_feat_img_offset -%}
        {%- assign tp_feat_img = tp_product.images[tp_feat_img_idx] -%}
        {%- assign tp_row_reverse = false -%}
        {%- assign tp_mod = forloop.index0 | modulo: 2 -%}
        {%- if tp_mod == 1 -%}{%- assign tp_row_reverse = true -%}{%- endif -%}
        {%- assign tp_desc_band = 'tp-feat__band' -%}
        {%- assign tp_desc_mod = tp_desc_idx | modulo: 2 -%}
        {%- if tp_desc_mod == 1 -%}{%- assign tp_desc_band = 'tp-feat__band tc-cream-paw-bg' -%}{%- endif -%}
        <div class="{{ tp_desc_band }}">
        <div class="tp-feat__row{% if tp_row_reverse %} tp-feat__row--reverse{% endif %}">
          {%- if tp_feat_img != blank -%}
            <div class="tp-feat__img-wrap">
              {{- tp_feat_img | image_url: width: 900 | image_tag:
                    class: 'tp-feat__img',
                    alt: tp_product.title,
                    loading: 'lazy',
                    widths: '450, 600, 900',
                    sizes: '(max-width: 749px) 100vw, 45vw'
              -}}
            </div>
          {%- endif -%}
          <div class="tp-feat__content">
            <div class="tp-feat__body">{{ tp_part_clean }}</div>
          </div>
        </div>
        </div>
      {%- endfor -%}
    </div>
  {%- elsif tp_product.description != blank -%}
    <div class="tp-desc-section">
      <div class="tp-description">{{ tp_product.description }}</div>
    </div>
  {%- endif -%}

  {%- comment -%}
    ===== Flagship sections =====
    Content is scoped per product via templates: each flagship product gets its
    own product.<name>.json template holding its own video/comparison/before-after/
    review blocks (assigned in Admin → Product → Theme template). Products on the
    shared template have no flagship blocks, so nothing renders there.
  {%- endcomment -%}
  {%- assign tp_is_main = true -%}

  {%- comment -%}
    Running counter for the flagship sections' alternating white/cream bands
    (same technique as the description's .tp-feat__band / .tc-cream-paw-bg).
    Only increments for sections that actually render, so the alternation
    never skips a color when a section has no content yet. Starts on white.
  {%- endcomment -%}
  {%- assign tpx_band_idx = 0 -%}

  <!-- ======== BEFORE / AFTER (main-product) ======== -->
  {%- if tp_is_main -%}
    {%- assign tpx_ba_blocks = section.blocks | where: 'type', 'before_after' -%}
    {%- assign tpx_has_ba = false -%}
    {%- for block in tpx_ba_blocks -%}
      {%- if block.settings.image_before != blank or block.settings.image_after != blank -%}{%- assign tpx_has_ba = true -%}{%- break -%}{%- endif -%}
    {%- endfor -%}
    {%- if tpx_has_ba -%}
      <div class="tp-feat">
        {%- for block in tpx_ba_blocks -%}
          {%- if block.settings.image_before == blank and block.settings.image_after == blank -%}{%- continue -%}{%- endif -%}
          {%- assign tpx_band_idx = tpx_band_idx | plus: 1 -%}
          {%- assign tpx_band_mod = tpx_band_idx | modulo: 2 -%}
          {%- assign tpx_band_cls = 'tp-feat__band' -%}
          {%- unless tpx_band_mod == 1 -%}{%- assign tpx_band_cls = 'tp-feat__band tc-cream-paw-bg' -%}{%- endunless -%}
          <div class="{{ tpx_band_cls }}">
            <div class="tp-feat__row tpx-ba" {{ block.shopify_attributes }}>
              <div class="tp-feat__content">
                {%- if block.settings.eyebrow != blank -%}
                  <span class="tp-feat__eyebrow">{{ block.settings.eyebrow | escape }}</span>
                {%- endif -%}
                {%- if block.settings.title != blank -%}
                  <h3 class="tp-feat__title">{{ block.settings.title | escape }}</h3>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <div class="tp-feat__body">{{ block.settings.text }}</div>
                {%- endif -%}
              </div>
              {%- if block.settings.image_before != blank and block.settings.image_after != blank -%}
                {%- comment -%} Interactive drag slider — same mechanism as the homepage Before & After {%- endcomment -%}
                {%- assign tpx_init = block.settings.initial_position | default: 50 -%}
                {%- assign tpx_clip = 100 | minus: tpx_init -%}
                {%- assign tpx_clip_style = 'clip-path: inset(0 ' | append: tpx_clip | append: '% 0 0)' -%}
                <div class="tpx-ba__slider" data-tpx-ba>
                  {{- block.settings.image_after | image_url: width: 900 | image_tag: class: 'tpx-ba__simg tpx-ba__simg--after', alt: block.settings.label_after, loading: 'lazy', widths: '450, 600, 900', sizes: '(max-width: 749px) 100vw, 55vw' -}}
                  {{- block.settings.image_before | image_url: width: 900 | image_tag: class: 'tpx-ba__simg tpx-ba__simg--before', alt: block.settings.label_before, loading: 'lazy', widths: '450, 600, 900', sizes: '(max-width: 749px) 100vw, 55vw', style: tpx_clip_style -}}
                  <div class="tpx-ba__handle" data-tpx-ba-handle style="left: {{ tpx_init }}%">
                    <button type="button" class="tpx-ba__handle-btn" aria-label="Drag to compare">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polyline points="7,2 2,7 7,12"/>
                        <polyline points="13,2 18,7 13,12"/>
                      </svg>
                    </button>
                  </div>
                  <span class="tpx-ba__tag" aria-hidden="true">{{ block.settings.label_before | default: 'Before' | escape }}</span>
                  <span class="tpx-ba__tag tpx-ba__tag--after" aria-hidden="true">{{ block.settings.label_after | default: 'After' | escape }}</span>
                </div>
              {%- else -%}
                {%- comment -%} Only one image set — plain labeled image fallback {%- endcomment -%}
                <div class="tpx-ba__imgs tpx-ba__imgs--single">
                  {%- if block.settings.image_before != blank -%}
                    <figure class="tpx-ba__fig">
                      <span class="tpx-ba__tag">{{ block.settings.label_before | default: 'Before' | escape }}</span>
                      {{- block.settings.image_before | image_url: width: 600 | image_tag: class: 'tpx-ba__img', alt: block.settings.label_before, loading: 'lazy', widths: '300, 450, 600', sizes: '(max-width: 749px) 88vw, 480px' -}}
                    </figure>
                  {%- endif -%}
                  {%- if block.settings.image_after != blank -%}
                    <figure class="tpx-ba__fig">
                      <span class="tpx-ba__tag tpx-ba__tag--after">{{ block.settings.label_after | default: 'After' | escape }}</span>
                      {{- block.settings.image_after | image_url: width: 600 | image_tag: class: 'tpx-ba__img', alt: block.settings.label_after, loading: 'lazy', widths: '300, 450, 600', sizes: '(max-width: 749px) 88vw, 480px' -}}
                    </figure>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>

      <script>
        (function () {
          'use strict';
          document.querySelectorAll('[data-tpx-ba]').forEach(function (el) {
            var beforeImg = el.querySelector('.tpx-ba__simg--before');
            var handle = el.querySelector('[data-tpx-ba-handle]');
            if (!beforeImg || !handle) return;

            var dragging = false;
            var cachedRect = null;

            function setPosition(clientX) {
              var rect = cachedRect || el.getBoundingClientRect();
              var pct = Math.min(100, Math.max(0, (clientX - rect.left) / rect.width * 100));
              beforeImg.style.clipPath = 'inset(0 ' + (100 - pct).toFixed(2) + '% 0 0)';
              handle.style.left = pct.toFixed(2) + '%';
            }

            el.addEventListener('mousedown', function (e) {
              cachedRect = el.getBoundingClientRect();
              dragging = true;
              setPosition(e.clientX);
              e.preventDefault();
            });
            el.addEventListener('touchstart', function (e) {
              cachedRect = el.getBoundingClientRect();
              dragging = true;
              setPosition(e.touches[0].clientX);
            }, { passive: true });
            el.addEventListener('touchmove', function (e) {
              if (dragging) setPosition(e.touches[0].clientX);
            }, { passive: true });
            el.addEventListener('touchend', function () { dragging = false; });
            window.addEventListener('mousemove', function (e) { if (dragging) setPosition(e.clientX); });
            window.addEventListener('mouseup', function () { dragging = false; cachedRect = null; });
          });
        })();
      </script>
    {%- endif -%}
  {%- endif -%}

  <!-- ======== UGC VIDEOS (main-product) ======== -->
  {%- if tp_is_main -%}
    {%- assign tpx_vid_blocks = section.blocks | where: 'type', 'ugc_video' -%}
    {%- assign tpx_has_vid = false -%}
    {%- for block in tpx_vid_blocks -%}
      {%- if block.settings.video != blank -%}{%- assign tpx_has_vid = true -%}{%- break -%}{%- endif -%}
    {%- endfor -%}
    {%- if tpx_has_vid -%}
      {%- assign tpx_band_idx = tpx_band_idx | plus: 1 -%}
      {%- assign tpx_band_mod = tpx_band_idx | modulo: 2 -%}
      {%- assign tpx_band_cls = 'tpx-band' -%}
      {%- unless tpx_band_mod == 1 -%}{%- assign tpx_band_cls = 'tpx-band tc-cream-paw-bg' -%}{%- endunless -%}
      <div class="{{ tpx_band_cls }}">
      <div class="tpx-ugc">
        <h2 class="tp-related__heading">
          {%- if section.settings.ugc_heading_plain != blank -%}
            <span class="tp-related__heading-plain">{{ section.settings.ugc_heading_plain | escape }}&nbsp;</span>
          {%- endif -%}
          {%- if section.settings.ugc_heading_hl != blank -%}
            <span class="tp-related__heading-hl">
              {{- section.settings.ugc_heading_hl | escape -}}
              <svg class="tp-related__heading-line" viewBox="0 0 300 14" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                <path d="M4 10 C40 5 80 12 140 7 C200 2 240 11 296 8" stroke="currentColor" stroke-width="6" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          {%- endif -%}
        </h2>
        <div class="tpx-ugc__grid">
          {%- for block in tpx_vid_blocks -%}
            {%- if block.settings.video == blank -%}{%- continue -%}{%- endif -%}
            <div class="tpx-ugc__item" {{ block.shopify_attributes }}>
              {{ block.settings.video | video_tag: playsinline: true, preload: 'metadata', muted: true, loop: true, class: 'tpx-ugc__video', image_size: '600x' }}
              <button type="button" class="tpx-ugc__play" aria-label="Play video">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5.5v13l11-6.5-11-6.5z"/></svg>
              </button>
            </div>
          {%- endfor -%}
        </div>
      </div>
      </div>

      <script>
        (function () {
          document.querySelectorAll('.tpx-ugc__item').forEach(function (item) {
            var video = item.querySelector('video');
            var btn = item.querySelector('.tpx-ugc__play');
            if (!video || !btn) return;
            btn.addEventListener('click', function () {
              // Pause any other playing UGC video first
              document.querySelectorAll('.tpx-ugc__video').forEach(function (v) {
                if (v !== video) { v.pause(); v.closest('.tpx-ugc__item').querySelector('.tpx-ugc__play').hidden = false; }
              });
              video.muted = false;
              video.controls = true;
              video.play();
              btn.hidden = true;
            });
            video.addEventListener('pause', function () { btn.hidden = false; });
            video.addEventListener('play', function () { btn.hidden = true; });
          });
        })();
      </script>
    {%- endif -%}
  {%- endif -%}

  <!-- ======== COMPARISON TABLE (main-product) ======== -->
  {%- if tp_is_main -%}
    {%- assign tpx_cmp_blocks = section.blocks | where: 'type', 'compare_row' -%}
    {%- if tpx_cmp_blocks.size > 0 -%}
      {%- assign tpx_band_idx = tpx_band_idx | plus: 1 -%}
      {%- assign tpx_band_mod = tpx_band_idx | modulo: 2 -%}
      {%- assign tpx_band_cls = 'tpx-band' -%}
      {%- unless tpx_band_mod == 1 -%}{%- assign tpx_band_cls = 'tpx-band tc-cream-paw-bg' -%}{%- endunless -%}
      <div class="{{ tpx_band_cls }}">
      <div class="tpx-cmp">
        <h2 class="tp-related__heading">
          {%- if section.settings.cmp_heading_plain != blank -%}
            <span class="tp-related__heading-plain">{{ section.settings.cmp_heading_plain | escape }}&nbsp;</span>
          {%- endif -%}
          {%- if section.settings.cmp_heading_hl != blank -%}
            <span class="tp-related__heading-hl">
              {{- section.settings.cmp_heading_hl | escape -}}
              <svg class="tp-related__heading-line" viewBox="0 0 300 14" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                <path d="M4 10 C40 5 80 12 140 7 C200 2 240 11 296 8" stroke="currentColor" stroke-width="6" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          {%- endif -%}
        </h2>
        <div class="tpx-cmp__scroll">
          <table class="tpx-cmp__table">
            <thead>
              <tr>
                <th class="tpx-cmp__feature-h" scope="col"><span class="visually-hidden">Feature</span></th>
                <th class="tpx-cmp__ours-h" scope="col">{{ section.settings.cmp_col_ours | default: 'Tailand' | escape }}</th>
                <th scope="col">{{ section.settings.cmp_col_alt1 | default: 'Other Brands' | escape }}</th>
                <th scope="col">{{ section.settings.cmp_col_alt2 | default: 'Cheap Alternatives' | escape }}</th>
              </tr>
            </thead>
            <tbody>
              {%- for block in tpx_cmp_blocks -%}
                <tr {{ block.shopify_attributes }}>
                  <th class="tpx-cmp__feature" scope="row">{{ block.settings.title | escape }}</th>
                  <td class="tpx-cmp__ours">
                    {%- if block.settings.ours -%}
                      <svg class="tpx-cmp__yes" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="11" fill="#5BB870"/><polyline points="7 12.5 10.5 16 17 8.5" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg><span class="visually-hidden">Yes</span>
                    {%- else -%}
                      <svg class="tpx-cmp__no" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="11" fill="#E8372B"/><path d="M8.5 8.5l7 7M15.5 8.5l-7 7" stroke="#fff" stroke-width="2.5" stroke-linecap="round"/></svg><span class="visually-hidden">No</span>
                    {%- endif -%}
                  </td>
                  <td>
                    {%- if block.settings.alt1 -%}
                      <svg class="tpx-cmp__yes" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="11" fill="#5BB870"/><polyline points="7 12.5 10.5 16 17 8.5" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg><span class="visually-hidden">Yes</span>
                    {%- else -%}
                      <svg class="tpx-cmp__no" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="11" fill="#E8372B"/><path d="M8.5 8.5l7 7M15.5 8.5l-7 7" stroke="#fff" stroke-width="2.5" stroke-linecap="round"/></svg><span class="visually-hidden">No</span>
                    {%- endif -%}
                  </td>
                  <td>
                    {%- if block.settings.alt2 -%}
                      <svg class="tpx-cmp__yes" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="11" fill="#5BB870"/><polyline points="7 12.5 10.5 16 17 8.5" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg><span class="visually-hidden">Yes</span>
                    {%- else -%}
                      <svg class="tpx-cmp__no" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="11" fill="#E8372B"/><path d="M8.5 8.5l7 7M15.5 8.5l-7 7" stroke="#fff" stroke-width="2.5" stroke-linecap="round"/></svg><span class="visually-hidden">No</span>
                    {%- endif -%}
                  </td>
                </tr>
              {%- endfor -%}
            </tbody>
          </table>
        </div>
      </div>
      </div>
    {%- endif -%}
  {%- endif -%}

  <!-- ======== PHOTO REVIEWS (main-product) ======== -->
  {%- if tp_is_main -%}
    {%- assign tpx_rev_blocks = section.blocks | where: 'type', 'review_photo' -%}
    {%- assign tpx_has_rev = false -%}
    {%- for block in tpx_rev_blocks -%}
      {%- if block.settings.image != blank -%}{%- assign tpx_has_rev = true -%}{%- break -%}{%- endif -%}
    {%- endfor -%}
    {%- if tpx_has_rev -%}
      {%- assign tpx_band_idx = tpx_band_idx | plus: 1 -%}
      {%- assign tpx_band_mod = tpx_band_idx | modulo: 2 -%}
      {%- assign tpx_band_cls = 'tpx-band' -%}
      {%- unless tpx_band_mod == 1 -%}{%- assign tpx_band_cls = 'tpx-band tc-cream-paw-bg' -%}{%- endunless -%}
      <div class="{{ tpx_band_cls }}">
      <div class="tpx-rev">
        <h2 class="tp-related__heading">
          {%- if section.settings.rev_heading_plain != blank -%}
            <span class="tp-related__heading-plain">{{ section.settings.rev_heading_plain | escape }}&nbsp;</span>
          {%- endif -%}
          {%- if section.settings.rev_heading_hl != blank -%}
            <span class="tp-related__heading-hl">
              {{- section.settings.rev_heading_hl | escape -}}
              <svg class="tp-related__heading-line" viewBox="0 0 300 14" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                <path d="M4 10 C40 5 80 12 140 7 C200 2 240 11 296 8" stroke="currentColor" stroke-width="6" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          {%- endif -%}
        </h2>
        <div class="tpx-rev__grid">
          {%- for block in tpx_rev_blocks -%}
            {%- if block.settings.image == blank -%}{%- continue -%}{%- endif -%}
            {%- assign tpx_rev_rating = block.settings.rating | default: 5 -%}
            <figure class="tpx-rev__card" {{ block.shopify_attributes }}>
              {%- assign tpx_rev_alt = block.settings.name | default: 'Customer photo' -%}
              {{- block.settings.image | image_url: width: 600 | image_tag: class: 'tpx-rev__img', alt: tpx_rev_alt, loading: 'lazy', widths: '300, 450, 600', sizes: '(max-width: 749px) 70vw, 300px' -}}
              <figcaption class="tpx-rev__body">
                <span class="tpx-rev__paws" role="img" aria-label="{{ tpx_rev_rating }} out of 5">
                  {%- for i in (1..5) -%}
                    <svg class="tpx-rev__paw{% if i <= tpx_rev_rating %} tpx-rev__paw--on{% endif %}" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <ellipse cx="6.5" cy="9" rx="2" ry="2.5"/><ellipse cx="10" cy="6.5" rx="2" ry="2.5"/><ellipse cx="14" cy="6.5" rx="2" ry="2.5"/><ellipse cx="17.5" cy="9" rx="2" ry="2.5"/><path d="M12 22.5C8.5 22.5 5.5 20.5 5.5 17.5C5.5 14.5 7.5 12.5 12 12.5C16.5 12.5 18.5 14.5 18.5 17.5C18.5 20.5 15.5 22.5 12 22.5Z"/>
                    </svg>
                  {%- endfor -%}
                </span>
                {%- if block.settings.quote != blank -%}
                  <p class="tpx-rev__quote">&ldquo;{{ block.settings.quote | escape }}&rdquo;</p>
                {%- endif -%}
                {%- if block.settings.name != blank -%}
                  <span class="tpx-rev__name">&ndash; {{ block.settings.name | escape }}</span>
                {%- endif -%}
              </figcaption>
            </figure>
          {%- endfor -%}
        </div>
      </div>
      </div>
    {%- endif -%}
  {%- endif -%}

  <!-- ======== LOWER CONTENT ======== -->
  <div class="tp-lower">

    {%- if section.settings.show_accordions -%}
      <div class="tp-accordions">
        {%- assign tp_acc_ids   = 'accordion_1,accordion_2,accordion_3,accordion_4,accordion_5' | split: ',' -%}
        {%- assign tp_acc_icons = '📋,🚚,🐾,💡,📦' | split: ',' -%}
        {%- for acc in tp_acc_ids -%}
          {%- assign tp_at = acc | append: '_title' -%}
          {%- assign tp_ab = acc | append: '_content' -%}
          {%- assign tp_ae = tp_acc_icons[forloop.index0] -%}
          {%- assign tp_at_val = section.settings[tp_at] -%}
          {%- assign tp_ab_val = section.settings[tp_ab] -%}
          {%- if tp_at_val != blank and tp_ab_val != blank -%}
            <details class="tp-acc">
              <summary>
                <span class="tp-acc__label">
                  <span aria-hidden="true">{{ tp_ae }}</span>{{ tp_at_val }}
                </span>
                <svg class="tp-acc__chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="tp-acc__body">{{ tp_ab_val }}</div>
            </details>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>

  <!-- ======== PRODUCT STORY ======== -->
  {%- assign tp_has_story = false -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'story_card' -%}{%- assign tp_has_story = true -%}{%- endif -%}
  {%- endfor -%}

  {%- if tp_has_story -%}
    <div class="tp-story">
      {%- if section.settings.story_heading != blank -%}
        <h2 class="tp-story__heading">{{ section.settings.story_heading }}</h2>
      {%- endif -%}
      <div class="tp-story__grid">
        {%- for block in section.blocks -%}
          {%- if block.type != 'story_card' -%}{%- continue -%}{%- endif -%}
          <div class="tp-story__card" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {%- assign tp_sc_alt = block.settings.image.alt | default: block.settings.title | escape -%}
              {{- block.settings.image | image_url: width: 600 | image_tag: class: 'tp-story__img', alt: tp_sc_alt, loading: 'lazy', width: 600, height: 450 -}}
            {%- endif -%}
            <div class="tp-story__card-body">
              {%- if block.settings.emoji != blank -%}
                <span class="tp-story__emoji" aria-hidden="true">{{ block.settings.emoji }}</span>
              {%- endif -%}
              {%- if block.settings.title != blank -%}
                <div class="tp-story__card-title">{{ block.settings.title }}</div>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div class="tp-story__card-text">{{ block.settings.text }}</div>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  <!-- ======== SPECS ======== -->
  {%- assign tp_has_specs = false -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'spec_row' -%}{%- assign tp_has_specs = true -%}{%- endif -%}
  {%- endfor -%}

  {%- if tp_has_specs -%}
    <div class="tp-specs">
      {%- if section.settings.specs_heading != blank -%}
        <h2 class="tp-specs__heading">{{ section.settings.specs_heading }}</h2>
      {%- endif -%}
      <div class="tp-specs__table">
        {%- for block in section.blocks -%}
          {%- if block.type != 'spec_row' -%}{%- continue -%}{%- endif -%}
          <div class="tp-specs__row" {{ block.shopify_attributes }}>
            <div class="tp-specs__key">{{ block.settings.spec_key }}</div>
            <div class="tp-specs__val">{{ block.settings.spec_val }}</div>
          </div>
        {%- endfor -%}
      </div>
